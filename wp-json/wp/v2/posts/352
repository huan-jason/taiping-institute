5c42\u5bc6\u65e0\u7f1d\u201d\u3002\u4eca\u5c31\u8d75\u5821\u592a\u6781\u62f3\u5341\u4e09\u5f0f\u624b\u6cd5\u3001\u4e09\u76d8\u516b\u6cd5\u3001\u80cc\u4e1d\u6263\u7406\u8bba\uff0c\u7c97\u6d45\u5206\u6790\u4ee5\u6c42\u4e0e\u540c\u9053\u7231\u597d\u8005\u5171\u63a2\u4e4b\uff0c\u4e0d\u8db3\u4e4b\u5904\uff0c\u8bf7\u4e13\u5bb6\u660e\u5e08\u4e0d\u541d\u8d50\u6559\u3002<\/p>\n\n\n\n<p>\u4e00\u3001\u8d75\u5821\u592a\u6781\u62f3\u4e4b\u52a8\u4f5c\u9634\u9633<\/p>\n\n\n\n<p>\u8d75\u5821\u5148\u5e08\u7559\u6709\u5341\u4e09\u5f0f\u624b\u6cd5\u8d77\u6e90\u56fe\u3002\u8c31\u8bc0\u4e91\uff1b\u672c\u592a\u6781\u62f3\u5341\u4e09\u5f0f\u624b\u6cd5\u7531\u5929\u9053\u8d77\u4e2d\u5305\u516d\u5341\u56db\u52bf\uff0c\u6bcf\u52bf\u8981\u7ec3\u591f\u5341\u4e09\u5b57\uff0c\u5373\u4e00\u5706\u3001\u4e24\u4eea\u3001\u56db\u8c61\u3001\u516b\u5366\u662f\u4e5f\u3002\u2026\u2026<\/p>\n\n\n\n<p>\u5f52\u7eb3\u4e3a\u5341\u4e09\u5b57\u5373\uff1a\u5706\u3001\u9886\u3001\u843d\u3001\u5f00\u3001\u5408\u3001\u51fa\u3001\u5165\u3001\u8fce\u3001\u62b5\u3001\u8fdb\u3001\u9000\u3001\u4e0a\u3001\u4e0b\u3002 \u5176\u4e2d\u9886\u4e3a\u9633\uff0c\u843d\u4e3a\u9634\uff1a\u5f00\u4e3a\u9633\uff0c\u5408\u4e3a\u9634\uff1b\u51fa\u4e3a\u9633\uff0c\u5165\u4e3a\u9634\uff1b\u8fce\u4e3a\u9633\uff0c\u62b5\u4e3a\u9634\uff1b\u8fdb\u4e3a\u9633\uff0c\u9000\u4e3a\u9634\uff1b\u4e0a\u4e3a\u9633\uff0c\u4e0b\u4e3a\u9634\u3002\u5706\u8d77\u5706\u7ec8\uff0c\u6b64\u5341\u4e09\u5b57\u662f\u8d75\u5821\u592a\u6781\u62f3\u884c\u529f\u8d70\u67b6\u4e2d\u7684\u7eb2\u9886\u3002\u6709\u9886\u5fc5\u6709\u843d\uff0c\u6709\u5f00\u5fc5\u6709\u5408\uff0c\u6709\u51fa\u5fc5\u6709\u5165\uff0c\u6709\u8fce\u5fc5\u6709\u62b5\uff0c\u6709\u8fdb\u5fc5\u6709\u9000\uff0c\u6709\u4e0a\u5fc5\u6709\u4e0b\u3002\u9759\u6781\u800c\u751f\u52a8\uff0c\u52a8\u6781\u800c\u751f\u9759\uff0c\u7531\u9759\u800c\u52a8\uff0c\u7531\u52a8\u800c\u9759\uff0c\u52a8\u4e3a\u9633\uff0c\u9759\u4e3a\u9634\uff0c\u9634\u9633\u8f6c\u6362\uff0c\u6f14\u53d8\u884d\u751f\uff0c\u5c42\u51fa\u4e0d\u7a77\uff0c\u56e0\u800c\u5305\u7f57\u4e07\u8c61\u3002\u884c\u529f\u8d70\u529f\u5982\u592a\u6781\uff0c\u201c\u4e00\u5904\u52a8\u800c\u5168\u8eab\u65e0\u4e0d\u52a8\u201d\uff0c\u201c\u7275\u4e00\u53d1\u800c\u52a8\u5168\u8eab\u201d\u3002\u4eba\u8eab\u5904\u5904\u6709\u9759\u52a8\uff0c\u5904\u5904\u6709\u9634\u9633\uff0c\u5904\u5904\u6709\u5f00\u5408\uff0c\u5904\u5904\u662f\u865a\u5b9e\u3002<\/p>\n\n\n\n<p>\u8d75\u5821\u592a\u6781\u62f3\u201c\u4e2d\u4e09\u76d8\u516b\u6cd5\u201d\u4e2d\u7684\u9634\u9633\u3002\u6240\u8c13\u4e09\u76d8\u5c31\u662f\u4e0a\u3001\u4e2d\u3001\u4e0b\u4e09\u76d8\u3002\u6bcf\u76d8\u4ff1\u6709\u516b\u6cd5\uff0c\u6bcf\u6cd5\u5404\u5206\u9634\u9633\u3002\u5f52\u7eb3\u4e3a\u4e00\u5706\u3001\u4e8c\u4eea\u3001\u56db\u8c61\u3001\u516b\u5366\u3002<\/p>\n\n\n\n<p>\u4e0a\u76d8\u624b\u4e4b\u516b\u6cd5\uff1a\u68da\u3001\u634b\u3001\u6324\u3001\u6309\u3001\u91c7\u3001\u634c\u3001\u8098\u3001\u9760\u3002\u7531\u4e00\u5706\u59cb\u751f\u4e0a\u4e0b\u4e24\u4eea\uff0c\u800c\u5206\u9634\u9633\uff0c\u4e24\u4eea\u751f\u56db\u8c61\uff0c\u6709\u592a\u9634\u3001\u592a\u9633\uff1b\u5c11\u9634\u3001\u5c11\u9633\u3002\u56db\u8c61\u751f\u516b\u5366\uff1a\u4e7e\u3001\u5151\u3001\u79bb\u3001\u9707\u3001\u5dfd\u3001\u574e\u3001\u826e\u3001\u5764\u3002\u624b\u8fd0\u516b\u5366\u9886\u843d\u51fa\u5165\u5f00\u5408\u8fce\u62b5\uff0c\u9634\u9633\u865a\u5b9e\uff0c\u5728\u6b64\u4e2d\u53d8\u6362\u3002<\/p>\n\n\n\n<p>\u4e2d\u76d8\u8eab\u4e4b\u516b\u6cd5\uff1a\u7eb5\u3001\u6a2a\u3001\u9ad8\u3001\u4f4e\u3001\u8fdb\u3001\u9000\u3001\u53cd\u3001\u4fa7\u3002\u884c\u529f\u8d70\u67b6\uff0c\u524d\u8fdb\u3001\u540e\u9000\u3001\u534a\u8fdb\u3001\u534a\u9000\u3001\u8fdb\u6781\u3001\u9000\u6781\u3001\u4fa7\u8f6c\u3001\u53cd\u8eab\uff0c\u9ad8\u4f4e\u3001\u4e0a\u4e0b\uff0c\u4ef0\u4fef\u2026\u2026\u8eab\u5f62\u53d8\u6362\uff0c\u865a\u5b9e\u8f6c\u5316\uff0c\u8c03\u8282\u91cd\u5fc3\uff0c\u4ff1\u662f\u9634\u9633\u53d8\u5316\u800c\u6765\u3002<\/p>\n\n\n\n<p>\u4e0b\u76d8\u817f\u4e4b\u516b\u6cd5\uff1a\u8dea\u3001\u6311\u3001\u7f20\u3001\u64a9\u3001\u5288\u3001\u907f\u3001\u6302\u3001\u8e6c\u3002\u811a\u8e0f\u4e94\u884c\u8fdb\u9000\u987e\u76fc\u5b9a\uff0c\u4e1c\u65b9\u5c5e\u6728\u4e3a\u9633\uff0c\u897f\u65b9\u5c5e\u91d1\u4e3a\u9634\uff1b\u5357\u65b9\u5c5e\u706b\u4e3a\u9633\uff0c\u5317\u65b9\u5c5e\u6c34\u4e3a\u9634\uff0c\u843d\u81f3\u4e2d\u571f\u800c\u5b9a\u4e5f\u3002\u884c\u529f\u8d70\u67b6\uff0c\u4e0a\u3001\u4e2d\u3001\u4e0b\u4e09\u76d8\u624b\u8fd0\u516b\u5366\uff0c\u8eab\u8d70\u592a\u6781\uff0c\u811a\u8e29\u4e94\u884c\u53d8\u5316\u5982\u7535\u5149\u77f3\u706b\uff0c\u5438\u65e5\u6708\u4e4b\u7075\u6c14\uff0c\u91c7\u5929\u5730\u4e4b\u7cbe\u534e\u3002<\/p>\n\n\n\n<p>\u8d77\u6e90\u56fe\u793a\u8bad\uff1a\u201c\u6d41\u884c\u8005\u6c14\uff0c\u4e3b\u5bb0\u8005\u7406\uff0c\u5bf9\u5f85\u8005\u6570\u201d\u662f\u8d75\u5821\u592a\u6781\u62f3\u7684\u884c\u62f3\u5b97\u65e8\u3002\u5176\u9634\u9633\u53d8\u5316\u5982\u7956\u5e08\u7237\u6240\u4e91\u201c\u5341\u4e09\u5f0f\u624b\u6cd5\u6bcf\u5b57\u8981\u7ec3\u591f\u516d\u5341\u56db\u52bf\uff0c\u6bcf\u52bf\u8981\u7ec3\u591f\u5341\u4e09\u5b57\uff0c\u5373\u4e00\u5706\u3001\u4e24\u4eea\u3001\u56db\u8c61\u3001\u516b\u5366\u2026\u2026\u201d\u9634\u9633\u662f\u4eba\u8eab\u7684\u6839\u672c\uff0c\u4e5f\u662f\u5929\u5730\u4e07\u7269\u7684\u6839\u672c\uff0c\u53e4\u4eba\u8bf4\u6cd5\u4e8e\u9634\u9633\u5408\u4e8e\u6570\u672f\u3002\u8d75\u5821\u592a\u6781\u62f3\u4eba\u8eab\u4e4b\u9634\u9633\u5408\u4e8e\u5929\u5730\u4e4b\u9634\u9633\uff0c\u516b\u5366\u751f\u516b\u5366\u751f\u751f\u606f\u606f\uff0c\u4e00\u6cd5\u751f\u4e07\u6cd5\u5706\u8d77\u5706\u7ec8\uff0c\u5e94\u4e86\u524d\u4eba\u8bf4\u7684\uff0c\u7531\u5929\u9053\u59cb\u800c\u7531\u5929\u9053\u7ec8\u8fbe\u5929\u4eba\u5408\u4e00\u4e4b\u6548\u5e94\u3002<\/p>\n\n\n\n<p>\u8d75\u5821\u592a\u6781\u62f3\u52a8\u4f5c\u662f\u4ee5\u8d70\u5706\u4e3a\u89c4\u5219\uff0c \u201c\u4ee5\u5706\u751f\u5706\uff0c\u4ee5\u5706\u514b\u5706\uff0c\u4ee5\u5706\u5316\u5706\u201d\uff0c\u5706\u7684\u987a\u9006\u53d8\u5316\u3001\u5706\u7684\u5f00\u5408\u3001\u5706\u7684\u865a\u5b9e\u3001\u9634\u9633\u4e92\u6839\uff0c\u751f\u751f\u606f\u606f\uff0c\u9634\u6781\u751f\u9633\uff0c\u9633\u6781\u751f\u9634\uff0c\u9634\u9633\u5408\u548c\uff0c\u9ad8\u5ea6\u5e73\u8861\uff0c\u9ad8\u5ea6\u534f\u8c03\uff0c\u9ad8\u5ea6\u7edf\u4e00\u3002\u4eba\u8eab\u4e4b\u592a\u6781\u4e0e\u5b87\u5b99\u65f6\u7a7a\u76f8\u543b\u5408\uff0c\u5176\u52a8\u4f5c\u8f7b\u7075\u5982\u201c\u4e09\u5c3a\u7eeb\u7f57\u6302\u5728\u65e0\u5f71\u6811\u4e0a\u201d\uff0c \u201c\u786c\u5982\u94a2\uff0c\u8f6f\u5982\u7ef5\uff0c\u6ed1\u5982\u9c7c\uff0c\u7c98\u5982\u80f6\u201d\uff0c\u9634\u9633\u53d8\u5316\u83ab\u6d4b\uff0c\u4ee4\u4eba\u6251\u6714\u8ff7\u79bb\u3002<\/p>\n\n\n\n<p>\u4e00\u3001\u201c\u80cc\u4e1d\u6263\u201d\u9634\u9633\u6d45\u8bf4<\/p>\n\n\n\n<p>\u4e09\u76d8\u79d8\u6cd5\u9634\u9633\u4e92\u53d8\u4e4b\u7406\uff0c\u5176\u4e2d\u7684\u5965\u5999\u7384\u673a\u5728\u4e8e\u5b83\u7684\u80cc\u4e1d\u6263\u4e4b\u7406\u3002\u8d75\u5821\u95e8\u4e2d\u79f0\u80cc\u4e1d\u6263\u4e3a\u592a\u6781\u62f3\u201c\u9634\u9633\u4e4b\u6bcd\u201d\u3001\u201c\u79d8\u4e2d\u4e4b\u79d8\u201d\u3002\u8d75\u5821\u7b2c\u4e5d\u4ee3\u5b97\u5e08\u675c\u5143\u5316\u5728\u300a\u592a\u6781\u62f3\u6b63\u5b97\u300b\u4e66\u4e2d\u8bba\uff0c\u201c\u2026\u2026\u56e0\u5176\u52a8\u4f5c\u7740\u7740\u6d51\u5706\uff0c\u4e0e\u5929\u5730\u4e4b\u65e0\u6781\u540c\uff0c\u7531\u7740\u7740\u6d51\u5706\u5386\u4e09\u76f4\u3001\u56db\u987a\u3001\u516d\u5408\u7b49\u7b49\u3002\u672c\u4eba\u8eab\u4e4b\u6d51\u5706\u800c\u9020\u4e3a\u80cc\u4e1d\u6263\uff0c\u4e0e\u5929\u5730\u540c\u6839\u6e90\uff0c\u5373\u4e0e\u5929\u5730\u4e4b\u6839\u6e90\u540c\uff0c\u5219\u4eba\u8eab\u4e4b\u80cc\u4e1d\u6263\u975e\u5373\u4e3a\u4eba\u8eab\u4e4b\u6bcd\u4e4e\u3002\u5373\u4e3a\u4eba\u8eab\u7ec3\u592a\u6781\u4e4b\u6bcd\uff0c\u5219\u592a\u6781\u62f3\u4e4b\u57fa\u5b9e\u8087\u4e8e\u6b64\u3002\u592a\u6781\u62f3\u4e4b\u57fa\u5b9e\u8087\u4e8e\u6b64\uff0c\u5219\u5176\u4e2d\u7ec3\u4e4b\u4e8c\u4eea\u56db\u8c61\u516b\u5366\u8bda\u65e0\u4e0d\u8087\u4e8e\u6b64\u77e3\u3002\u201d<\/p>\n\n\n\n<p>\u5929\u5730\u4e43\u4e00\u5927\u592a\u6781\uff0c\u4eba\u8eab\u4e43\u4e00\u5c0f\u592a\u6781\uff0c\u4eba\u8eab\u4e4b\u592a\u6781\u7684\u592a\u6781\u5728\u4e0b\u4e39\u7530\u3002\u901a\u8fc7\u5404\u79cd\u6709\u6548\u7684\u592a\u6781\u5185\u529f\u62f3\u67b6\u8bad\u7ec3\uff0c\u7ec3\u81f3\u4e39\u7530\u6df7\u5143\u6c14\u5145\u76c8\uff0c\u5373\u6240\u8c13\u9020\u51fa\u201c\u771f\u94c5\u6c5e\u201d\uff0c\u6b64\u80fd\u91cf\u805a\u96c6\u5728\u4e0b\u4e39\u7530\uff0c\u53ef\u968f\u610f\u5ff5\u53d1\u653e\u3002\u53e4\u4eba\u4e91\uff1a\u201c\u7ec3\u51fa\u4e39\u7530\u6df7\u5143\u6c14\uff0c\u4e07\u4e24\u9ec4\u91d1\u4e0d\u4e0e\u4eba\u201d\u3001 \u201c\u7ec3\u51fa\u4e39\u7530\u6df7\u5143\u6c14\uff0c\u6253\u904d\u5929\u4e0b\u65e0\u4eba\u654c\u201d\u3002\u6240\u4ee5\u8bf4\u4e39\u7530\u6df7\u5143\u6c14\u7684\u805a\u96c6\u4e0e\u53d1\u653e\u662f\u592a\u6781\u62f3\u7684\u6838\u5fc3\u3002\u675c\u5143\u5316\u5148\u5e08\u65e2\u7136\u79f0\u80cc\u4e1d\u6263\u4e3a\u4eba\u8eab\u7ec3\u592a\u6781\u201c\u9634\u9633\u4e4b\u6bcd\u201d\u3001\u201c\u79d8\u4e2d\u4e4b\u79d8\u201d\uff0c\u90a3\u4e48\u5fc5\u7136\u662f\u592a\u6781\u62f3\u4e2d\u6700\u6838\u5fc3\u7684\u4e1c\u897f\u3002\u5f20\u4e09\u4e30\u7956\u5e08\u8a00\u201c\u592a\u6781\u4e4b\u5148\uff0c\u672c\u4e3a\u65e0\u6781\uff0c\u9e3f\u8499\u4e00\u6c14\uff0c\u6d51\u7136\u4e0d\u5206\uff0c\u6545\u65e0\u6781\u4e3a\u592a\u6781\u4e4b\u6bcd\u201d\u3002\u90a3\u4e48\u6b64\u9e3f\u8499\u4e00\u6c14\u662f\u5426\u5c31\u662f\u4eba\u8eab\u5c0f\u592a\u6781\u4e4b\u5148\u5929\u6df7\u5143\u6c14\uff1f\u90a3\u4e48\u4eba\u8eab\u5148\u5929\u6df7\u5143\u6c14\u7684\u51dd\u7ec3\u662f\u5426\u5c31\u662f\u675c\u5143\u5316\u5b97\u5e08\u6240\u8bf4\u7684\u9634\u9633\u4e4b\u6bcd\u5373\u80cc\u4e1d\u6346\uff1f\u90a3\u4e48\u4eba\u8eab\u7ec3\u81f3\u5468\u8eab\u592a\u6781\u65f6\u5219\u5168\u8eab\u65e0\u5904\u4e0d\u592a\u6781\uff0c\u5168\u8eab\u65e0\u5904\u4e0d\u4e39\u7530\uff0c\u4e14\u5168\u8eab\u65e0\u5904\u4e0d\u80cc\u4e1d\u6263\u4e4e\uff1f<\/p>\n\
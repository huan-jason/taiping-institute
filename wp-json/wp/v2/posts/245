307\u7279\u522b\u9ad8\u8d85\u3001\u7a00\u5947\u4e0d\u5e73\u51e1\u7684\u795e\u529b\uff1b\u201c\u950b\u201d\u5373\u6307\u5203\uff0c\u300a\u91ca\u540d\u00b7\u91ca\u5175\u300b\uff1a\u201c\u5200\uff0c\u5176\u672b\u65e5\u950b\u201d\uff0c\u662f\u4e3a\u5200\u5251\u7b49\u5668\u68b0\u7684\u9510\u5229\u6216\u5c16\u7aef\u90e8\u5206\uff1b\u201c\u63e1\u201d\u624b\u6307\u5f2f\u66f2\u5408\u62e2\u6765\u6525\u4e4b\u610f\uff1b\u201c\u80dc\u201d\u4e24\u519b\u5bf9\u5792\u80fd\u8d62\u3001\u80fd\u627f\u53d7\uff0c\u751a\u81f3\u4e8e\u4ee5\u5c11\u80dc\u591a\u3002<\/p>\n\n\n\n<p>\u5982\u679c\u4ee5\u73b0\u6709\u7684\u5fa1\u5236\u5b9d\u5251\u6960\u6728\u7bb1\u954c\u523b\u96b6\u4e66\u800c\u5b9a\u5251\u94ed\u3001\u6570\u53f7\u4e3a30\u628a\uff0c\u800c\u73b0\u6b66\u5907\u5e93\u5b58\u5929\u3001\u5730\u3001\u4eba\u5b9d\u5251\u5b9e\u9645\u6570\u8ba1\u4e3a27\u628a\u3002\u4e7e\u9686\u671d\u5fa1\u5236\u5b9d\u5251\u662f\u4ece\u4e7e\u9686\u5341\u4e09\u5e74\u5236\u4f5c\uff0c\u81f3\u4e7e\u9686\u4e8c\u5341\u4e8c\u5e74\u5b8c\u6210\u3002\u4e7e\u9686\u5fa1\u7528\u5929\u3001\u5730\u3001\u4eba\u5b9d\u525130\u628a\uff0c\u5373\u6bcf\u4e2a\u5b57\u53f7\uff08\u5373\u5929\u3001\u5730\u3001\u4eba\uff09\u6765\u7b97\uff0c\u662f\u5404\u4e3a10\u628a\uff0c\u5176\u540e\u5e74\u4ee3\u5e76\u6ca1\u6709\u518d\u5236\u4f5c\u3002<\/p>\n\n\n\n<p>\u4e09<\/p>\n\n\n\n<p>\u603b\u7ba1\u5185\u52a1\u5e9c\u9020\u529e\u5904\u5404\u6210\u4f5c\u8655\u5728\u5236\u4f5c\u201c\u4e7e\u9686\u5e74\u5236\u201d\u5929\u3001\u5730\u3001\u4eba\u5b9d\u5251\u7684\u8fc7\u7a0b\u4e2d\uff0c\u59cb\u7ec8\u4e0e\u5236\u4f5c\u5fa1\u7528\u8170\u5200\u4e00\u6837\uff0c\u79c9\u627f\u4e7e\u9686\u8c15\u65e8\u884c\u4e8b\uff0c\u4ece\u521b\u4f5c\u521d\u59cb\u5373\u6388\u610f\u5200\u5251\u5148\u8981\u753b\u51fa\u56fe\u6837\uff0c\u8981\u6c42\u201c\u5c06\u505a\u5f97\u753b\u517d\u541e\u53e3\u5251\u672c\u6837\u4e00\u4ef6\uff0c\u9526\u541e\u53e3\u672c\u6837\u4e00\u4ef6\uff0c\u897f\u756a\u82b1\u541e\u53e3\u5251\u672c\u6837\u4e00\u4ef6\uff0c\u6301\u8fdb\u4ea4\u592a\u76d1\u80e1\u4e16\u6770\u5448\u89c8\uff0c\u5949\u65e8\uff1a\u2018\u517d\u541e\u53e3\u753b\u5168\uff0c\u518d\u770b\u756a\u82b1\u541e\u53e3\u679d\u53f6\u518d\u6574\u58ee\u4e9b\uff0c\u9526\u5730\u541e\u53e3\u4fd7\u6c14\u53e6\u753b\u597d\uff0c\u82b1\u6837\u5251\u4e0a\u518d\u6dfb\u4e00\u9053\u7ebf\uff0c\u4e2d\u95f4\u4e00\u9762\u505a\u4e7e\u9686\u5e74\u5236\uff0c\u4e00\u9762\u505a\u7b2c\u4e00\u81f3\u7b2c\u5341\uff0c\u94a6\u6b64\u3002\u201d\u4e7e\u9686\u5e1d\u81ea\u59cb\u81f3\u7ec8\u5bf9\u5fa1\u5236\u5b9d\u5251\u964d\u65e8\u3001\u6388\u610f\u3001\u5448\u89c8\u3001\u5ba1\u6279\u3001\u94a6\u5b9a\uff0c\u5e76\u8d23\u6210\u7ff0\u6797\u5b66\u58eb\u4eb2\u7b14\u4e66\u5199\u5b57\u6837\u3001\u62df\u540d\u3002<\/p>\n\n\n\n<p>\uff08\u4e00\uff09\u4e7e\u9686\u5fa1\u5236\u5b9d\u5251\u5f62\u5236<\/p>\n\n\n\n<p>\u201c\u4e7e\u9686\u5e74\u5236\u201d\u5929\u3001\u5730\u3001\u4eba\u5b9d\u5251\uff0c\u5251\u67c4\u5747\u4e3a\u6728\u8d28\u67c4\uff0c\u5916\u7f20\u660e\u9ec4\u4e1d\u7ee6\u5e26\uff0c\u62a4\u624b\u4e3a\u94c1\u9540\u91d1\u5448\u5143\u5b9d\u5f62\u72b6\uff0c\u67c4\u5934\u5448\u5982\u610f\u72b6\uff0c\u9ed1\u6f06\u5730\u96d5\u7f20\u679d\u83b2\u7eb9\u9970\uff0c\u4ee5\u6728\u80ce\u5236\u4f5c\u7684\u5251\u9798\u5305\u9970\u7ea2\u9ca8\u9c7c\u76ae\u3002\u5982\u201c\u51fa\u4e91\u201d\u5251\uff0c\u957f100\u5398\u7c73\u3002\u5251\u8eab\u94a2\u8d28\uff0c\u5203\u950b\uff0c\u5251\u8eab\u5e95\u90e8\u4e00\u9762\u6bc1\u91d1\u6a2a\u4e3a\u201c\u5730\u5b57\u4e00\u53f7\u201d\uff0c\u7eb5\u4e3a\u201c\u51fa\u4e91\u201d\uff1b\u53e6\u4e00\u9762\u6a2a\u4e3a\u201c\u4e7e\u9686\u5e74\u5236\u201d\uff0c\u7eb5\u4e3a\u92c4\u91d1\u3001\u94f6\u3001\u94dc\u4e1d\u7ec4\u6210\u7684\u6d77\u6c34\u4e91\u7eb9\u7b49\u56fe\u6848\u3002\u5251\u9798\u6728\u8d28\u9970\u7ea2\u9ca8\u9c7c\u76ae\uff0c\u748b\u3001\u73cc\u7686\u94c1\u92c4\u91d1\u96d5\u82b1\u7eb9\u9970\u3002\u6a2a\u675f\u94c1\u92c4\u91d1\u7b8d\u4e8c\u9053\uff0c\u9798\u80cc\u4e3a\u94c1\u92c4\u91d1\u63d0\u6881\u3002\u9644\u4e00\u76ae\u7b7e\u58a8\u4e66\u6ee1\u3001\u6c49\u6587\uff1a\u201c\u5730\u5b57\u4e00\u53f7\u51fa\u4e91\u5251\u4e00\u91cd\u4e8c\u5341\u516d\u4e24\u4e7e\u9686\u5e74\u5236\u3002\u201d<\/p>\n\n\n\n<p>\u518d\u5982\uff0c\u7ea2\u9ca8\u9c7c\u76ae\u9798\u201c\u70db\u5fae\u201d\u5251\uff0c\u957f99\u5398\u7c73\u3002\u5251\u8eab\u94a2\u8d28\uff0c\u5203\u950b\uff0c\u5251\u8eab\u5e95\u90e8\u4e00\u9762\u94f6\u6a2a\u4e3a\u201c\u5730\u5b57\u4e5d\u53f7\u201d\uff0c\u7eb5\u4e3a\u201c\u70db\u5fae\u201d\uff1b\u53e6\u4e00\u9762\u6a2a\u4e3a\u201c\u4e7e\u9686\u5e74\u5236\u201d\uff0c\u7eb5\u4e3a\u92c4\u91d1\u3001\u94f6\u3001\u94dc\u4e1d\u7ec4\u6210\u7684\u4e00\u8001\u8005\u5728\u661f\uff08\u5317\u6597\u4e03\u661f\uff09\u591c\u4e4b\u4e0b\uff0c\u501f\u70db\u629a\u6848\u89c2\u5251\u56fe\u6848\uff1b\u4e24\u9762\u540e\u63a5\u4ee5\u6bc1\u91d1\u3001\u94f6\u3001\u94dc\u4e1d\u6784\u6210\u4e91\u9f99\u53d8\u5f62\u56fe\u6848\u3002\u67c4\u6728\u8d28\uff0c\u5916\u7f20\u9ec4\u4e1d\u7ee6\u5e26\u3002\u62a4\u624b\u53ca\u67c4\u5934\u4e3a\u94c1\u9540\u91d1\u9970\u4ef6\uff0c\u4ee5\u9ed1\u6f06\u5730\u96d5\u78ec\u3001\u9c7c\u3001\u8760\u3001\u4e91\u7b49\u5409\u7965\u56fe\u6848\u3002\u5251\u9798\u6728\u8d28\u9970\u7ea2\u9ca8\u9c7c\u76ae\uff0c\u748b\u3001\u73cc\u7686\u94c1\u6bc1\u91d1\u96d5\u7eb9\u9970\u4e0e\u524d\u540c\u3002\u6a2a\u675f\u94c1\u92c4\u91d1\u7b8d\u4e8c\u9053\uff0c\u9798\u80cc\u4e3a\u94c1\u92c4\u91d1\u63d0\u6881\u3002\u9644\u4e00\u76ae\u7b7e\u58a8\u4e66\u6ee1\u3001\u6c49\u6587\uff1a\u201c\u5730\u5b57\u4e5d\u53f7\u70db\u5fae\u5251\u4e00\u91cd\u4e09\u5341\u4e24\u4e7e\u9686\u5e74\u5236\u3002\u201d<\/p>\n\n\n\n<p>\uff08\u4e8c\uff09\u4e7e\u9686\u5fa1\u5236\u5b9d\u5251\u6960\u6728\u7bb1<\/p>\n\n\n\n<p>\u201c\u4e7e\u9686\u5e74\u5236\u201d\u5929\u3001\u5730\u3001\u4eba\u5b9d\u5251\u5747\u914d\u6960\u6728\u7bb1\u76db\u88c5\uff0c\u7bb1\u4e0a\u6240\u933e\u523b\u7684\u96b6\u4e66\u7531\u7ff0\u6797\u5927\u5b66\u58eb\u4e66\u5199\u3002\u636e\u603b\u7ba1\u5185\u52a1\u5e9c\u9020\u529e\u5904\u6863\u6848\u8bb0\u8f7d\uff1a\u4e7e\u9686\u4e8c\u5341\u4e00\u5e74\u5341\u4e8c\u6708\u4e8c\u5341\u4e03\u65e5\uff0c\u90ce\u4e2d\u767d\u4e16\u79c0\u3001\u5458\u5916\u90ce\u91d1\u8f89\u5c06\u505a\u5f97\u9794\u7ea2\u5b50\u513f\u76ae\uff08\u7b14\u8005\u6ce8\uff1a\u5373\u7ea2\u9ca8\u9c7c\u76ae\uff09\u9798\u92c4\u91d1\u4ec0\u4ef6\u53e4\u5f0f\u5251\u4e09\u5341\u628a\uff0c\u6301\u8fdb\u5b89\u5728\u517b\u5fc3\u6bbf\u5448\u89c8\uff0c\u5949\u65e8\uff1a\u201c\u7740\u76db\u53e4\u5f0f\u5200\u4e09\u5341\u628a\u6960\u6728\u7bb1\u6837\u5f0f\u4e00\u6837\uff0c\u914d\u7bb1\u76db\u88c5\uff0c\u94a6\u6b64\u3002\u201d\u4e8c\u5341\u4e8c\u5e74\u4e94\u6708\u521d\u4e09\u65e5\uff0c\u90ce\u4e2d\u767d\u4e16\u79c0\u3001\u5458\u5916\u90ce\u91d1\u8f89\u5c06\u53e4\u5f0f\u5251\u4e09\u5341\u628a\uff0c\u914d\u5f97\u6960\u6728\u7bb1\u516d\u4ef6\uff0c\u5b89\u5728\u517b\u5fc3\u6bbf\u5448\u89c8\uff0c\u5949\u65e8\uff1a\u201c\u5251\u7bb1\u4ea4\u61cb\u52e4\u6bbf\u523b\u5b57\uff0c\u5176\u5251\u914d\u76ae\u7b7e\u5b50\u5199\u56db\u6837\u5b57\uff0c\u94a6\u6b64\u201d\uff1b\u201c\u5c06\u6960\u6728\u7bb1\u4ea4\u61cb\u52e4\u6bbf\u62df\u540d\u201d\uff0c\u201c\u4ea4\u4e8e\u654f\u4e2d\u5199\u5200\u540d\u523b\u5728\u5323\u76d6\u4e0a\u201d\u3002\u4e0a\u8ff0\u6240\u8c13\u201c\u5251\u914d\u76ae\u7b7e\u5b50\u5199\u56db\u6837\u5b57\u201d\uff0c\u5373\u4e3a\u6ee1\u3001\u8499\u3001\u85cf\u3001\u6c49\u6587\uff0c\u7531\u7ff0\u6797\u5b66\u58eb\u4eec\u58a8\u4e66\u3002\u61cb\u52e4\u6bbf\u4f4d\u4e8e\u7d2b\u7981\u57ce\u5185\u5ef7\u4e7e\u6e05\u5bab\u897f\u5e91\uff0c\u539f\u4e3a\u5eb7\u7199\u5e1d\u5e7c\u5e74\u8bfb\u4e66\u4e8e\u6b64\uff0c\u4e7e\u9686\u671d\u65f6\u4e3a\u7ff0\u6797\u4f8d\u503c\u5904\uff0c\u51e1\u56fe\u4e66\u7ff0\u58a8\u4e4b\u5177\u7686\u8d2e\u7109\uff0c\u662f\u4e3a\u4eba\u6587\u835f\u8403\u4e4b\u5730\u3002\u5f53\u65f6\uff0c\u4e8e\u654f\u4e2d\u65f6\u4efb\u56fd\u53f2\u9986\u3001\u4e09\u901a\u9986\u6b63\u603b\u88c1\u3001\u4e0a\u4e66\u623f\u603b\u5e08\u5085\uff0c\u4e3b\u6301\u7f16\u7e82\u8fc7\u5927\u91cf\u4e7e\u9686\u671d\u5b98\u4fee\u56fe\u4e66\u3002<\/p>\n\n\n\n<p>\u201c\u4e7e\u9686\u5e74\u5236\u201d\u5929\u3001\u5730\u3001\u4eba\u7e
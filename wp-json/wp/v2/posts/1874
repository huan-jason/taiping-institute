{"id":1874,"date":"2023-04-23T14:36:29","date_gmt":"2023-04-23T14:36:29","guid":{"rendered":"http:\/\/taipinginstitute.com\/?p=1874"},"modified":"2024-01-29T16:44:29","modified_gmt":"2024-01-29T16:44:29","slug":"%e6%9d%8e%e6%b0%8f%e6%9f%a5%e6%8b%b3","status":"publish","type":"post","link":"http:\/\/taipinginstitute.com\/2023\/04\/23\/%e6%9d%8e%e6%b0%8f%e6%9f%a5%e6%8b%b3\/","title":{"rendered":"\u674e\u6c0f\u67e5\u62f3"},"content":{"rendered":"\n<p>\u5c71\u6771\u4efb\u57ce\u674e\u6c0f\u67e5\u62f3\u662f\u6211\u570b\u9577\u62f3\u985e\u512a\u79c0\u62f3\u7a2e,\u662f\u67e5\u62f3\u4e09\u5927\u6d41\u6d3e\u4e4b\u4e00,\u4e5f\u662f\u56de\u65cf\u62f3\u8853\u4e4b\u4e00\u3002\u5b83\u6e90\u9060\u6d41\u9577,\u5f9e\u660e\u4ee3\u59cb\u5275,\u6b77\u7d93\u674e\u6c0f\u5e7e\u4ee3\u4eba\u7684\u7e7c\u627f\u548c\u767c\u5c55,\u6280\u85dd\u4e0d\u65b7\u5f97\u5230\u5145\u5be6\u8207\u63d0\u9ad8,\u9010\u6f38\u5f62\u6210\u7368\u5177\u4e00\u683c\u7684\u5b8c\u6574\u9ad4\u7cfb\u3002<\/p>\n\n\n\n<p>\u4e00\u3001\u6b77\u53f2\u6df5\u6e90<\/p>\n\n\n\n<p>\u64da\u674e\u5bb6\u300a\u674e\u6c0f\u7956\u8b5c\u300b\u8a18\u8f09:\u300c\u674e\u6c0f\u5148\u4eba\u300e\u963f\u91cc\u6c99\u300f,\u5728\u5510\u671d\u5b89\u53f2\u4e4b\u4e82\u6642,\u5927\u98df\u570b\u66fe\u6d3e\u4e09\u5343\u56de\u5175\u52a9\u5510\u5e73\u4e82,\u300e\u963f\u91cc\u6c99\u300f\u96a8\u8ecd\u53c3\u6230,\u4e8b\u5f8c\u5510\u738b\u5c07\u9019\u6279\u58eb\u5175\u8cdc\u5c45\u9577\u5b89,\u70ba\u5176\u4fee\u5efa\u6e05\u771f\u5bfa\u4e26\u5a36\u4e2d\u570b\u5973\u5b50\u5a5a\u914d,\u300e\u963f\u91cc\u6c99\u300f\u8cdc\u70ba\u674e\u59d3\u3002\u4ed6\u5011\u8b39\u5b88\u4f0a\u65af\u862d\u6559\u6559\u7fa9\u548c\u79ae\u4fd7,\u5b50\u5b6b\u7e41\u884d\u4e16\u4ee3\u76f8\u50b3\u3002\u660e\u6d2a\u6b66\u4e8c\u5341\u4e03\u5e74(1395\u5e74),\u674e\u6c0f\u7531\u9577\u5b89\u9077\u5c45\u5c71\u6771,\u5b9a\u5c45\u4efb\u57ce\u767d\u5bb6\u80e1\u540c\u3002<\/p>\n\n\n\n<p>\u674e\u5bb6\u4e16\u4ee3\u7fd2\u6b66,\u81ea\u5b9a\u5c45\u4efb\u57ce\u5f8c,\u674e\u5bb6\u6700\u65e9\u5728\u4efb\u57ce\u6240\u50b3\u64ad\u7684\u62f3\u8853\u7a31\u4e4b\u300c\u963f\u91cc\u6c99\u62f3\u300d,\u5f9e\u6b64\u300c\u963f\u91cc\u6c99\u62f3\u300d\u5ee3\u70ba\u6d41\u50b3\u3002\u300c\u963f\u91cc\u6c99\u300d\u7cfb\u963f\u62c9\u4f2f\u8a9e,\u4e2d\u6587\u97f3\u8b6f,\u5176\u4e2d\u300c\u6c99\u300d\u7684\u8a9e\u97f3\u6709\u6642\u8b6f\u8b80\u6210\u300c\u53c9\u300d\u3001\u300c\u63d2\u300d\u97f3\u3002\u300c\u963f\u91cc\u6c99\u62f3\u300d\u5f8c\u7a31\u300c\u53c9\u62f3\u300d\u3001\u300c\u63d2\u62f3\u300d,\u6e05\u672b\u81f3\u6c11\u570b\u521d\u5e74,\u90fd\u5982\u6b64\u7a31\u8b02,\u5f8c\u7d71\u7a31\u4e4b\u300c\u67e5\u62f3\u300d\u3002\u5728\u6fdf\u5be7\u6709\u300c\u4efb\u57ce\u53c9\u62f3\u963f\u91cc\u50b3,\u6d41\u50b3\u6c11\u9593\u5343\u9918\u5e74\u3002\u4e94\u5f62\u516d\u5408\u7686\u9f4a\u5099,\u6b4c\u980c\u7d55\u6280\u5ff5\u7956\u5148\u3002\u50b3\u6388\u62f3\u8853\u6574\u5341\u8def,\u5167\u5916\u525b\u67d4\u5b9c\u76f8\u9593\u300d\u7684\u6b4c\u8b20,\u9019\u662f\u4efb\u57ce\u7fd2\u6b66\u4e4b\u4eba\u5f9e\u53e4\u81f3\u4eca\u7684\u53e3\u982d\u79aa\u3002<\/p>\n\n\n\n<p>\u674e\u742a\u745e(1761\u20141846\u5e74),\u79c9\u627f\u5bb6\u50b3,\u7fd2\u7df4\u300c\u963f\u91cc\u6c99\u62f3\u300d\u53ca\u5200\u3001\u69cd\u3001\u68cd\u3001\u68d2\u3002\u6e05\u4e7e\u9686\u5e74\u9593(1784\u5e74)\u70ba\u671d\u4e2d\u8b77\u885b,\u4ed6\u6f5b\u5fc3\u7814\u7a76\u621a\u7e7c\u5149\u300a\u7d00\u6548\u65b0\u66f8\u2022\u62f3\u7d93\u300b\u3001\u5510\u9806\u4e4b\u300a\u6b66\u7de8\u300b\u3001\u4f55\u826f\u81e3\u300a\u9663\u8a18\u300b\u7b49\u5175\u6cd5\u6b66\u6280,\u5438\u53d6\u4e86\u524d\u4eba\u7684\u62f3\u6cd5\u3001\u62f3\u5f0f\u3001\u817f\u6cd5\u7b49,\u878d\u5165\u300c\u963f\u91cc\u6c99\u62f3\u300d\u4e4b\u4e2d\u3002\u4ed6\u96c6\u53d6\u773e\u5bb6\u4e4b\u9577,\u5275\u7de8\u4e86\u300c\u5341\u8def\u6417\u6376\u300d\u3001\u300c\u9d5d\u638c\u5f0f\u300d\u3001\u300c\u622a\u624b\u62f3\u300d\u7b49\u7368\u6709\u7684\u5957\u8def\u3002\u4ed6\u9084\u5728\u67e5\u62f3\u4e2d\u6dfb\u52a0\u4e86\u7279\u6709\u7684\u300c\u722a\u5f62\u300d,\u5f62\u6210\u300c\u4e01\u6b65\u63d2\u722a\u300d(\u9f8d\u64fa\u5c3e)\u3001\u300c\u76e4\u817f\u63d2\u722a\u300d(\u96d9\u9f8d\u51fa\u6c34)\u3001\u300c\u63d0\u819d\u63d2\u722a\u300d(\u76e4\u9f8d\u51fa\u6d1e)\u7b49\u7368\u7279\u7684\u674e\u6c0f\u67e5\u62f3\u52d5\u4f5c,\u8c50\u5bcc\u4e86\u674e\u6c0f\u67e5\u62f3\u9580\u7684\u5167\u5bb9,\u4f7f\u674e\u6c0f\u67e5\u62f3\u52d5\u4f5c\u66f4\u52a0\u5b8c\u7f8e,\u7d50\u69cb\u66f4\u52a0\u5408\u7406,\u98a8\u683c\u66f4\u52a0\u7368\u7279\u3002\u674e\u6c0f\u5f8c\u4eba\u7a31\u674e\u742a\u745e\u70ba\u674e\u6c0f\u67e5\u62f3\u59cb\u5b97\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u4e8c\u4ee3\u50b3\u4eba\u674e\u4fdd\u592a(1798\u20141873\u5e74),\u5e7c\u5e74\u96a8\u7236\u89aa\u674e\u742a\u745e\u7fd2\u67e5\u62f3\u53ca\u5200\u3001\u69cd\u3001\u68cd\u3001\u68d2,\u300c\u516d\u8def\u4ed9\u50b3\u6bcd\u5b50\u9318\u300d\u5275\u7de8\u4eba\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u4e09\u4ee3\u50b3\u4eba\u674e\u632f\u57fa(1834\u20141909\u5e74),\u5b57\u6a39\u5609,9\u6b72\u96a8\u7236\u89aa\u674e\u4fdd\u592a\u7fd2\u6b66,\u7cbe\u901a\u7956\u50b3\u67e5\u62f3\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u56db\u4ee3\u50b3\u4eba\u674e\u6069\u805a(1859\u20141932\u5e74),\u5b57\u6703\u4ead(\u532f\u4ead),1909\u5e74\u7531\u970d\u5143\u7532\u89aa\u8058\u65bc\u4e0a\u6d77\u7cbe\u6b66\u9ad4\u80b2\u6703\u4efb\u6559,1928\u5e74\u53c3\u52a0\u570b\u8003\u88ab\u6388\u4e88\u300c\u52c7\u58eb\u300d\u7a31\u865f\u3002\u56e0\u53d7\u5bb6\u98a8\u5f71\u97ff,\u4ed6\u6388\u5f92\u6975\u5176\u56b4\u683c,\u4e0a\u6d77\u59da\u96fb\u4fe0,\u4efb\u57ce\u6c99\u69ae\u6c11,\u5b50\u5973\u674e\u745e\u5f6a\u3001\u674e\u9cf3\u5f6a\u3001\u674e\u9f8d\u5f6a\u70ba\u5176\u4e3b\u8981\u50b3\u4eba\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u4e94\u4ee3\u50b3\u4eba\u6c99\u69ae\u6c11,\u56de\u65cf,1884\u5e74\u751f\u65bc\u4efb\u57ce,\u5352\u5e74\u4e0d\u8a73\u3002\u6c99\u69ae\u6c11\u5f9e\u5c0f\u611b\u6b66\u597d\u4fe0,8\u6b72\u5e2b\u5f9e\u674e\u6069\u805a\u7814\u7fd2\u67e5\u62f3\u3002\u6c99\u69ae\u6c11\u5929\u8cc7\u8070\u660e,\u52e4\u596e\u597d\u5b78,\u4e0d\u6015\u5403\u82e6,\u6df1\u5f97\u5e2b\u7236\u539a\u611b,\u674e\u6069\u805a\u5c07\u7956\u50b3\u67e5\u62f3\u53ca\u6240\u6709\u6b66\u529f\u5168\u90e8\u50b3\u6388\u4e88\u6c99\u69ae\u6c11,\u5f8c\u4eba\u7a31\u4e4b\u70ba\u300c\u6b66\u8056\u4eba\u6c99\u56db\u723a\u300d\u3002<\/p>\n\n\n\n<p>\u674e\u745e\u5f6a(1895\u20141946\u5e74),\u5b57\u9326\u5802,\u51fa\u8eab\u65bc\u6b66\u8853\u4e16\u5bb6,\u81ea\u5e7c\u96a8\u4f2f\u7236\u674e\u6069\u805a\u5728\u4e0a\u6d77\u7cbe\u6b66\u6703\u7fd2\u6b66,\u5728\u4f2f\u7236\u7cbe\u5fc3\u8abf\u6559\u4e0b\u6b66\u6210\u5f8c\u7559\u7cbe\u6b66\u6703\u4efb\u6559,\u5f8c\u53d7\u7e3d\u6703\u6d3e\u5f80\u65b0\u52a0\u5761\u4efb\u5357\u6d0b\u7cbe\u6b66\u5206\u6703\u6559\u7df4,\u4f7f\u674e\u6c0f\u67e5\u62f3\u9060\u50b3\u6d77\u5916\u3002<\/p>\n\n\n\n<p>\u674e\u9f8d\u5f6a(1903\u20141989\u5e74),\u5b57\u9cf3\u6c60,\u5e7c\u5e74\u5373\u96a8\u7236\u89aa\u674e\u6069\u805a\u7fd2\u7df4\u7956\u50b3\u6b66\u6280,1921\u5e74\u4efb\u7cbe\u6b66\u6703\u6559\u7fd2\u3002\u65b0\u4e2d\u570b\u6210\u7acb\u5f8c,\u4ed6\u4efb\u4e0a\u6d77\u6b66\u8853\u806f\u8abc\u6703\u57f7\u884c\u59d4\u54e1,\u5168\u570b\u7b2c\u4e00\u5c46\u904b\u52d5\u6703\u6b66\u8853\u88c1\u5224,1982\u5e74\u4efb\u6fdf\u5be7\u5e02\u6b66\u8853\u5354\u6703\u526f\u4e3b\u5e2d,\u6388\u5f92\u6709\u5289\u6771\u6d77\u3001\u8521\u6e05\u6cb3\u3001\u9586\u6210\u6c11\u3001\u5152\u5b50\u674e\u5e38\u53cb\u7b49\u4eba\u3002<\/p>\n\n\n\n<p>\u674e\u9cf3\u5f6a,\u674e\u6069\u805a\u4e4b\u5973,1911\u5e74\u51fa\u751f,\u81ea\u5e7c\u96a8\u7236\u89aa\u7fd2\u674e\u6c0f\u67e5\u62f3,8\u6b72\u9032\u5165\u7cbe\u6b66\u6703\u7fd2\u6b66,\u4e0b\u50b3\u5152\u5b50\u5289\u5143\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u516d\u4ee3\u4e3b\u8981\u50b3\u4eba\u5289\u6771\u6d77,\u56de\u65cf,1927\u5e74\u751f\u65bc\u4efb\u57ce,1936\u5e74\u5f9e\u5e2b\u6c99\u69ae\u6c11\u5148\u751f\u7fd2\u67e5\u62f3,\u5f8c\u53c8\u5e2b\u5f9e\u65bc\u674e\u9f8d\u5f6a\u5148\u751f\u7814\u7a76\u674e\u6c0f\u67e5\u62f3,1984\u5e74\u53c3\u52a0\u5168\u570b\u6b66\u8853\u89c0\u6469\u4ea4\u6d41\u5927\u6703\u7372\u4e00\u7b49\u734e,1985\u5e74\u53c3\u52a0\u5c71\u6771\u7701\u9ad4\u59d4\u7d44\u7e54\u7684\u300a\u67e5\u62f3\u300b\u4e00\u66f8\u7684\u7de8\u5beb\u5de5\u4f5c,\u66fe\u4efb\u6fdf\u5be7\u5e02\u6b66\u8853\u5354\u6703\u59d4\u54e1,\u6388\u5f92\u5b97\u932b\u5143\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u7b2c\u4e03\u4ee3\u50b3\u627f\u4eba\u5b97\u932b\u5143,1963\u5e74\u751f\u65bc\u5c71\u6771\u7701\u5fae\u5c71\u7e23,\u4e2d\u570b\u6b66\u5354\u6703\u54e1,\u4e2d\u570b\u6b66\u8853\u516d\u6bb5,\u570b\u5bb6\u4e00\u7d1a\u6b66\u8853\u88c1\u5224\u54e1,\u5c71\u6771\u7701\u6b66\u8853\u6bb5\u4f4d\u8003\u8a55\u54e1,\u5fae\u5c71\u7e23\u50b3\u7d71\u62f3\u7814\u7a76\u6703\u6703\u9577,\u5168\u570b\u7b2c\u516d\u5c46\u6b66\u8853\u529f\u529b\u5927\u8cfd\u88c1\u5224\u54e1\u3002<\/p>\n\n\n\n<p>\u4e8c\u3001\u674e\u6c0f\u67e5\u62f3\u7684\u5167\u5bb9\u3001\u6280\u6cd5\u7279\u9ede<\/p>\n\n\n\n<p>(\u4e00)\u674e\u6c0f\u67e5\u62f3\u7684\u5167\u5bb9\u6700\u521d\u6709\u5341\u8def\u6c99\u62f3\u4ee5\u53ca\u5200\u3001\u69cd\u3001\u68cd\u5404\u5341\u8d9f\u5957\u8def,\u4ee5\u5f8c\u5728\u4e0d\u65b7\u8207\u5176\u4ed6\u9580\u6d3e\u4ea4\u6d41\u4e2d\u9010\u6f38\u88dc\u5145\u4e86\u528d\u8853\u3001\u96d9\u9264\u3001\u9482\u3001\u6485\u3001\u96d9\u624b\u5e36\u7b49\u5668\u68b0\u3002\u674e\u6c0f\u67e5\u62f3\u7684\u5f92\u624b\u548c\u5668\u68b0\u5c0d\u7df4\u5167\u5bb9\u975e\u5e38\u8c50\u5bcc,\u6709\u67e5\u62f3\u5c0d\u62c6\u3001\u92ac\u5b50\u9318\u3001\u5341\u4e8c\u817f\u3001\u55ae\u5200\u69cd\u3001\u5927\u5200\u69cd\u3001\u96d9\u9264\u9032\u69cd\u3001\u6734\u5200\u69cd\u3001\u5c0d\u624e\u69cd\u3001\u5c0d\u5288\u5200\u3001\u767d\u624b\u5200\u3001\u767d\u624b\u69cd\u3001\u767d\u624b\u68cd\u3001\u5927\u93df\u69cd\u4ee5\u53ca\u9482\u9032\u69cd\u7b49\u3002<\/p>\n\n\n\n<p>1.\u817f\u6cd5\u7df4\u7fd2<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u91cd\u8996\u817f\u6cd5\u7df4\u7fd2,\u5176\u5167\u5bb9\u8c50\u5bcc,\u5982\u4f4e\u8e22\u3001\u5e73\u8e22\u3001\u4f4e\u8e29\u3001\u659c\u8e29\u3001\u8e6c\u817f\u3001\u8e39\u817f\u3001\u95d6\u817f\u3001\u6383\u817f\u3001\u7e8f\u817f\u3001\u9a30\u7a7a\u98db\u8173\u3001\u96d9\u98db\u8173\u3001\u9a30\u7a7a\u5916\u64fa\u817f\u7b49,\u5728\u5957\u8def\u4e2d\u90fd\u5408\u7406\u5206\u5e03\u800c\u53c8\u7e31\u6a6b\u4ea4\u5bc6\u3002\u7d9c\u5408\u5176\u817f\u6cd5\u53ef\u4ee5\u6b78\u7d50\u70ba\u5341\u4e94\u500b\u5b57,\u5373:\u8dfa\u3001\u5f48\u3001\u8e22\u3001\u8e39\u3001\u6f51\u3001\u6383\u3001\u52fe\u3001\u639b\u3001\u8d9f\u3001\u6392\u3001\u7e8f\u3001\u9ede\u3001\u64a9\u3001\u622a\u3001\u62d0\u3002<\/p>\n\n\n\n<p>2.\u62f3\u6cd5\u7df4\u7fd2<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u4ee5\u300c\u6417\u6376\u300d\u7df4\u7fd2\u62f3\u6cd5\u3002\u6417\u6376\u662f\u7531\u5f13\u3001\u99ac\u3001\u4ec6\u3001\u865b\u3001\u6b47\u3001\u4e01\u516d\u7a2e\u6b65\u5f62,\u62f3\u3001\u638c\u3001\u52fe\u4e09\u7a2e\u624b\u5f62,\u5f48\u3001\u639b\u3001\u8e39\u3001\u7bad\u3001\u5f48\u3001\u7e8f\u516d\u7a2e\u817f\u6cd5,\u5c0d\u3001\u6c96\u3001\u58d3\u3001\u6384\u3001\u7838\u3001\u67b6\u3001\u64a9\u3001\u683d\u3001\u6311\u7b49\u4e3b\u8981\u62f3\u6cd5,\u4ee5\u53ca\u4e94\u7a2e\u638c\u6cd5\u3001\u516d\u7a2e\u6b65\u6cd5\u3001\u5169\u7a2e\u52fe\u6cd5\u3001\u4e09\u7a2e\u8098\u6cd5\u3001\u4e00\u7a2e\u5e73\u8861\u52d5\u4f5c\u7d44\u6210\u7684\u57fa\u672c\u529f\u5957\u8def\u7df4\u7fd2,\u5176\u4e2d\u5c24\u4ee5\u7a81\u51fa\u529f\u67b6\u3001\u817f\u6cd5\u548c\u62f3\u6cd5\u70ba\u4e3b\u3002<\/p>\n\n\n\n<p>\u5957\u8def\u5206\u985e<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u9ad8\u7d1a\u5957\u8def\u5171\u5341\u8def\u67e5\u62f3,\u7d93\u674e\u5bb6\u5f8c\u4eba\u6f14\u7df4\u6574\u7406\u5206\u5225\u70ba:\u4e00\u8def\u6bcd\u5b50,\u4e8c\u8def\u9023\u74b0,\u4e09\u8def\u6416\u6ad3,\u56db\u8def\u516b\u65b9,\u4e94\u8def\u98a8\u9b54,\u516d\u8def\u7a81\u8972,\u4e03\u8def\u6885\u82b1,\u516b\u8def\u731b\u864e,\u4e5d\u8def\u98db\u9f8d,\u5341\u8def\u57cb\u4f0f\u3002<\/p>\n\n\n\n<p>4.\u7df4\u529f\u65b9\u6cd5<\/p>\n\n\n\n<p>(1)\u4ee5\u5341\u8def\u5f48\u817f\u3001\u4e09\u8def\u82b1\u817f\u3001\u5341\u8def\u6417\u6376\u70ba\u7fd2\u7df4\u57fa\u790e\u3002<\/p>\n\n\n\n<p>(2)\u4ee5\u80a9\u649e\u6c99\u888b\u7df4\u80a9\u529b,\u62cb\u6c99\u888b\u7df4\u81c2\u529b,\u7d5e\u68d2\u7df4\u624b\u8155\u529b\u3002<\/p>\n\n\n\n<p>(3)\u4ee5\u817f\u7e1b\u6c99\u888b\u8ca0\u91cd\u5f48\u8df3,\u589e\u5f37\u817f\u529b\u3002<\/p>\n\n\n\n<p>(4)\u4ee5\u62f3\u64ca\u6c99\u888b\u7df4\u62f3\u6cd5\u529f\u529b\u3002<\/p>\n\n\n\n<p>(5)\u4ee5\u8e22\u6a01\u7df4\u7fd2\u817f\u529f,\u5176\u6b21\u9084\u6709\u77f3\u9396\u3001\u77f3\u64d4\u3001\u63d0\u9435\u7403\u3001\u62c9\u6ed1\u8eca\u3001\u9ede\u92fc\u9322\u773c\u7b49\u7df4\u529f\u65b9\u6cd5\u3002<\/p>\n\n\n\n<p>\u674e\u6c0f\u67e5\u62f3\u62f3\u7406\u6709\u300c\u516d\u5408\u300d,\u5373\u300c\u5167\u4e09\u5408\u3001\u5916\u4e09\u5408\u300d,\u795e\u8207\u610f\u3001\u610f\u8207\u6c23\u3001\u6c23\u8207\u529b,\u624b\u8207\u8db3\u3001\u8098\u8207\u819d\u3001\u80a9\u8207\u80ef\u300c\u5167\u5916\u516d\u5408\u300d\u3002\u674e\u6c0f\u67e5\u62f3\u5f88\u591a\u653b\u9632\u52d5\u4f5c,\u90fd\u6b78\u7d0d\u65bc\u300c\u8e22\u6253\u6454\u62ff\u300d\u4e4b\u4e2d\u3002\u5728\u904b\u7528\u6642,\u9084\u8981\u9748\u6d3b\u6a5f\u52d5,\u9075\u5faa\u300c\u5341\u5b57\u8981\u8a23\u300d:\u7e2e\u3001\u5c0f\u3001\u7dbf\u3001\u8edf\u3001\u5de7\u3001\u932f\u3001\u901f\u3001\u786c\u3001\u8106\u3001\u6ed1\u3002<\/p>\n\n\n\n<p>(\u4e8c)\u674e\u6c0f\u67e5\u62f3\u7684\u6280\u64ca\u7279\u9ede\u662f\u91cd\u817f\u6cd5,\u591a\u6454\u6cd5,\u4e0d\u62d8\u5de6\u53f3,\u642d\u624b\u5373\u767c;\u5176\u7bc0\u594f\u7279\u9ede\u662f\u4e7e\u6de8\u5229\u7d22,\u52d5\u8fc5\u975c\u5b9a,\u52d5\u6642\u5982\u98a8\u99b3\u96fb\u63a3,\u5b9a\u52e2\u6642\u975c\u6b62\u7a69\u5b9a;\u5176\u6574\u9ad4\u7279\u9ede\u662f\u5f62\u795e\u517c\u5099,\u5167\u5916\u5408\u4e00,\u653b\u9632\u610f\u5ff5\u540c\u6642\u8cab\u6ce8\u65bc\u4e00\u62db\u4e00\u5f0f,\u4ee5\u6c23\u50ac\u529b,\u7cbe\u795e\u878d\u6ce8\u62f3\u5f0f,\u547c\u5438\u914d\u5408\u52d5\u4f5c,\u5f9e\u800c\u5448\u73fe\u51fa\u5b8c\u6574\u4e00\u9ad4\u3001\u5f62\u795e\u517c\u5099\u3001\u5167\u5916\u5408\u4e00\u7684\u98a8\u91c7\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u674e\u5f0f\u67e5\u62f3\u7684\u5f62\u6210\uff0c\u53ef\u4e0a\u6eaf\u5230\u674e\u5f0f\u67e5\u62f3\u4ee3\u8868\u4eba\u4e00\u4e00\u674e\u6069\u805a\u7684\u66fe\u7956\u7236\u674e\u742a\u745e\uff08\u674e\u5f0f\u67e5\u62f3\u59cb\u5b97\uff09\u3002\u674e\u742a\u745e \u5bf9\u5f62\u6210\u674e\u5f0f\u67e5\u62f3\u8d77\u5230\u4e86\u91cd\u8981\u7684\u4f5c\u7528\u3002\u4ed6\u79c9\u627f\u5bb6\u4f20\u7684\u201c\u67b6\u5b50\u62f3\u201d\u3001\u201c\u6363\u6376\u201d\u3001\u201c\u8eab\u6cd5\u52bf\u201d\uff0c\u4ee5\u53ca\u5200,\u67aa,\u68cd,\u68d2\u7b49\u6b66\u5b66\u3002<\/p>\n","protected":false},"author":1,"featured_media":1904,"comment_status":"closed","ping_status":"","sticky":false,"template":"","format":"standard","meta":{"pgc_sgb_lightbox_settings":"","footnotes":""},"categories":[5],"tags":[],"_links":{"self":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/1874"}],"collection":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/comments?post=1874"}],"version-history":[{"count":3,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/1874\/revisions"}],"predecessor-version":[{"id":1914,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/1874\/revisions\/1914"}],"wp:featuredmedia":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/media\/1904"}],"wp:attachment":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/media?parent=1874"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/categories?post=1874"},{"taxonomy":"post_ta
{"id":288,"date":"2021-08-05T22:02:46","date_gmt":"2021-08-05T22:02:46","guid":{"rendered":"http:\/\/taipinginstitute.com\/?p=288"},"modified":"2022-02-17T20:42:59","modified_gmt":"2022-02-17T20:42:59","slug":"%e5%ae%89%e5%be%bd%e5%ae%8b%e9%97%a8%e5%bf%83%e6%84%8f%e5%85%ad%e5%90%88%e6%8b%b3-%e5%ae%8b%e5%9b%bd%e5%ae%be","status":"publish","type":"post","link":"http:\/\/taipinginstitute.com\/2021\/08\/05\/%e5%ae%89%e5%be%bd%e5%ae%8b%e9%97%a8%e5%bf%83%e6%84%8f%e5%85%ad%e5%90%88%e6%8b%b3-%e5%ae%8b%e5%9b%bd%e5%ae%be\/","title":{"rendered":"\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3 &#8211; \u5b8b\u56fd\u5bbe"},"content":{"rendered":"\n<p>\u5fc3\u610f\u516d\u5408\u62f3\u76f8\u4f20\u4e3a\u5357\u5b8b\u540d\u5c06\u5cb3\u7236\u6240\u521b\uff0c\u5176\u8bf4\u59cb\u81ea\u6234\u9f99\u90a6\u4e8e\u4e7e\u9686\u5341\u4e94\u5e74\u5e8f\u5fc3\u610f\u62f3\u7ecf\u4e00\u6587\u3002\u5185\u79f0\u201d\u2026\u2026\u5f53\u7ae5\u5b50\u65f6\uff08\u6307\u5cb3\u6b66\u7a46\u738b\uff09\u53d7\u4e1a\u4e8e\u5e08\uff0c\u7cbe\u901a\u67aa\u6cd5\uff0c\u4ee5\u67aa\u4e3a\u62f3\uff0c\u7acb\u4e00\u6cd5\u4ee5\u6559\u5c06\u4f50\uff0c\u540d\u66f0\uff1a\u610f\u62f3\u3002\u795e\u5999\u83ab\u6d4b\uff0c\u76d6\u4ece\u53e4\u672a\u6709\u4e4b\u6280\u3002\u738b\u4ee5\u540e\u91d1\u5143\u660e\u4ee3\uff0c\u9c9c\u6709\u5176\u6280\u4e5f\u3002\u72ec\u6211\u59ec\u516c\u540d\u9645\u53ef\uff0c\u5b57\u9f99\u5cf0\uff0c\u751f\u4e8e\u6e05\u521d\uff0c\u4e3a\u84b2\u4e1c\u8bf8\u51af\u4eba\u6c0f\uff0c\u8bbf\u540d\u5e08\u4e8e\u7ec8\u5357\u5c71\uff0c\u5f97\u6b66\u7a46\u738b\u62f3\u8c31\uff0c\u540e\u6388\u4f59\u5e08 \u7ee7\u6b66\u5148\u751f\u4e8e\u79cb\u84b2\uff0c\u65f6\u4eba\u4e0d\u77e5\u5176\u52c7\uff0c\u5148\u751f\u4e60\u6b66\u5341\u6709\u4e8c\u5e74\u6280\u52c7\u65b9\u6210\uff0c\u5eb7\u7199\u7678\u9149\u79d1\u8fde\u6377\u4e09\u5143\uff0c\u94a6\u547d\u4e3a\u5c71\u897f\u9756\u8fdc\u603b\u9547\u5927\u90fd\u7763\uff0c\u81f4\u4ed5\u5f52\u7c4d\uff0c\u4f59\u6e38\u81f3\u6d1b\uff0c\u5148\u751f\u4ee5\u6b64\u62f3\u6388\u4f59\uff0c\u5b66\u4e4b\u5341\u6613\u5bd2\u6691\uff0c\u5148\u751f\u66f0\uff1a\u5b50\u52c7\u6210\u77e3\u3002\u4f59\u56de\u664b\u81f3\u6d1b\u9633\uff0c\u9047\u9a6c\u5b66\u793c\u516c\uff0c\u8c08\u827a\u751a\u6d3d\uff0c\u5c5e\u4f59\u4f5c\u5e8f\uff0c\u4f59\u4e0d\u6587\uff0c\u7109\u80fd\u4e3a\u5e8f\uff0c\u4f46\u89c1\u4e16\u6709\u80fd\u6562\u4e4b\u58eb\uff0c\u672a\u8d4f\u65e0\u517c\u4eba\u4e4b\u529b\uff0c\u53ca\u89c2\u5176\u827a\uff0c\u518d\u53e9\u5176\u5b66\u624b\u4e0d\u5e94\u5fc3\uff0c\u8bba\u4e0d\u5408\u9053\u8005\u4f55\u4e5f\uff0c\u4e0d\u5f97\u4e2a\u4e2d\u771f\u4f20\u6545\u4e5f\u2026\u2026\u3002\u59ec\u5e08\u4e4b\u540e\uff0c\u5fc3\u610f\u516d\u5408\u62f3\u5386\u5386\u53ef\u8003\uff0c\u4e00\u652f\u7531\u674e\u6d1b\u80fd\u4e13\u81f3\u6cb3\u5317\uff0c\u5728\u5341\u5927\u5f62\u57fa\u7840\u4e0a\uff0c\u53c8\u52a0\u4e24\u5f62\u5e76\u4e0d\u65ad\u521b\u65b0\u5b8c\u5584\uff0c\u53d6\u5176\u540d\u66f0\uff1a\u5f62\u610f\u62f3\u3002\u674e\u6d1b\u80fd\u4e3a\u6234\u9f99\u90a6\u4f20\u4eba\u3002\u5176\u6b66\u529f\u767b\u5cf0\u9020\u6781\uff0c\u4eba\u79f0\u201c\u795e\u62f3\u674e\u201d\u3002\u5176\u95e8\u4e0b\u5f1f\u5b50\u90ed\u4e91\u6df1\u66f4\u6709\u534a\u6b65\u5d29\u62f3\u6253\u5929\u4e0b\u4e4b\u7f8e\u540d\u3002\u56e0\u6b64\u5f62\u610f\u62f3\u5728\u5168\u56fd\u4e43\u81f3\u4e16\u754c\u4e0a\u5f71\u54cd\u9887\u5927\uff0c\u6d41\u4f20\u4e5f\u5e7f\u3002\u4e00\u652f\u7531\u9a6c\u5b66\u793c\u4f20\u81f3\u6cb3\u5357\uff0c\u7686\u56e0\u9a6c\u516c\u8eab\u4e3a\u56de\u6c11\uff0c\u8be5\u62f3\u5f53\u65f6\u56e0\u653f\u6cbb\u539f\u56e0\u53ea\u5728\u56de\u6c11\u4e2d\u4f20\u64ad\uff0c\u6545\u53d1\u5c55\u8f83\u6162\uff0c\u6d41\u4f20\u4e0d\u5e7f\u3002\u4f46\u5fc3\u610f\u62f3\u59cb\u7ec8\u4fdd\u6301\u7740\u539f\u4f20\u98ce\u683c\uff0c\u5386\u4ee3\u6770\u51fa\u5f1f\u5b50\u9a6c\u4e09\u5143\u3001\u9a6c\u5174\u3001\u5f20\u5fd7\u8bda\u3001\u674e\u653f\u3001\u4e70\u58ee\u56fe\u6570\u4eba\u800c\u5df2\u3002\u6cb3\u5357\u5fc3\u610f\u62f3\u7684\u6d41\u4f20\u5206\u90e8\u60c5\u51b5\uff1a\u6d1b\u9633\u4e00\u652f\u7531\u9a6c\u5174\u6240\u4f20\uff0c\u5176\u5b83\u652f\u7cfb\u57fa\u672c\u5c5e\u5357\u9633\u5f20\u4e13\u8bda\u6240\u4f20\u3002\u5f20\u5fd7\u8bda\u4f20\u9c81\u5c71\u674e\u653f\uff0c\u674e\u4f20\u5f20\u805a\uff0c\u5f20\u4f20\u4e70\u58ee\u56fe\u3001\u4e70\u4f20\u5468\u53e3\u8881\u51e4\u4eea\uff0c\u5f62\u6210\u5468\u53e3\u4e00\u7cfb\u3002\u8881\u4f20\u5362\u5d69\u9ad8\u3001\u5b8b\u56fd\u5bbe\u3001\u5c1a\u5b66\u793c\u3001\u6768\u6bbf\u537f\uff0c\u4e4b\u540e\u5362\u5b9a\u5c45\u4e0a\u6d77\u5e7f\u4e3a\u4f20\u64ad\u3002\u5f62\u6210\u4e0a\u6d77\u4e00\u7cfb\uff0c\u5b8b\u56fd\u5bbe\u5b9a\u5c45\u5b89\u5fbd\u868c\u57e0\u540e\u4e3a\u4e3a\u4f20\u64ad\u5f62\u6210\u868c\u57e0\u4e00\u7cfb\uff0c\u5f20\u5fd7\u8bda\u4f20\u9093\u53bf\u4eba\u5f20\u6d77\u6d32\uff0c\u5e76\u4e14\u7531\u674e\u653f\u4f20\u5357\u9633\u6c34\u6c0f\u5bb6\u65cf\uff0c\u5f62\u6210\u5357\u9633\u4e00\u7cfb\uff0c\u622a\u6b62\u76ee\u524d\u5fc3\u610f\u62f3\u6210\u540d\u4eba\u7269\u5747\u6709\u4f20\u4eba\u3002\u4ed6\u4eec\u5206\u90e8\u5728\u5168\u56fd\u5404\u5730\uff0c\u4f46\u4e60\u8005\u5c1a\u5c11\uff0c\u5728\u5168\u56fd\u8303\u56f4\u5185\uff0c\u4e60\u5fc3\u610f\u516d\u5408\u62f3\uff0c\u4eba\u6570\u8f83\u591a\uff0c\u5f71\u54cd\u8f83\u5927\u7684\u5730\u533a\u3002\u5f53\u5c5e\u5b89\u5fbd\u7701\u868c\u57e0\u5e02\uff0c\u4ec5\u4e00\u4e2a\u868c\u57e0\u5e02\u5fc3\u610f\u62f3\u5e0840-65\u5c81\u4e4b\u95f4\u7684\u5c31\u6709\u51e0\u5343\u4eba\u4e4b\u591a\u3002\u5b8b\u56fd\u5bbe\u5148\u751f\u65e0\u6127\u4e8e\u5f00\u5c71\u7956\u5e08\u3002<\/p>\n\n\n\n<p>\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u662f\u5f53\u524d\u5168\u56fd\u5fc3\u610f\u516d\u5408\u62f3\u56db\u5927\u533a\u57df\u4e2d\u7684\u4e00\u5757\u3002\u5df2\u7ecf\u670993\u5e74\u7684\u5386\u53f2\uff0c\u662f1917\u5e74\u7531\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u5f00\u5c71\u7956\u5e08\u5b8b\u56fd\u5bbe\u4ece\u8001\u5bb6\u6cb3\u5357\u7701\u5468\u53e3\u4ee3\u6765\u7684\uff0c\u4ed6\u5728\u868c\u57e0\u5f00\u5b97\u7acb\u6d3e\uff0c\u5c06\u4ed6\u6240\u4f20\u6388\u7684\u5fc3\u610f\u516d\u5408\u62f3\u547d\u540d\u4e3a\u201c\u5b8b\u95e8\u201d\u3002\u5b8b\u56fd\u5bbe\u3001\u6cb3\u5357\u5468\u53e3\u4eba\uff0c\u5e08\u4ece\u6cb3\u5357\u8881\u51e4\u4eea\u5904\u5b66\u5f97\u5fc3\u610f\u516d\u5408\u62f3\u4ee5\u540e\uff0c\u6765\u5230\u5b89\u868c\u57e0\uff0c\u4e3b\u6301\u4e07\u80dc\u9556\u5c40\uff0c\u5c06\u6cb3\u5357\u5fc3\u610f\u516d\u5408\u62f3\u4e5f\u5e26\u5230\u868c\u57e0\uff0c\u53c8\u7531\u5176\u5f1f\u5b50\u4ece\u868c\u57e0\u4f20\u64ad\u5230\u6574\u4e2a\u5b89\u5fbd\u4ee5\u53ca\u6c5f\u82cf\u7684\u5f90\u5dde\u3001\u5357\u4eac\u7b49\u5730\uff1b\u6210\u4e3a\u540d\u7b26\u5176\u5b9e\u7684\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u30021911\u5e74\u5e95\uff0c\u6d25\u6d66\u94c1\u8def\u5168\u7ebf\u901a\u8f66\uff0c\u4e8e\u662f\u868c\u57e0\u7684\u6c34\u9646\u4ea4\u901a\u6709\u4e86\u5f88\u5927\u7684\u53d1\u5c55\uff0c\u8d27\u7269\u8fd0\u8f93\u65e5\u6e10\u589e\u52a0\uff0c\u868c\u57e0\u7801\u5934\u4e5f\u5f00\u59cb\u5174\u65fa\u8d77\u6765\u3002\u5f53\u65f6\u7684\u5c01\u5efa\u628a\u5934\u3001\u9752\u6d2a\u5e2e\u72ec\u9738\u7801\u5934\uff0c\u7801\u5934\u5de5\u4eba\u4e3a\u517b\u5bb6\u7cca\u53e3\u5c31\u8d77\u6765\u6597\u4e89\uff0c\u6240\u4ee5\uff0c\u6253\u67b6\u3001\u6597\u6bb4\u7684\u4e8b\u4ef6\u65f6\u6709\u53d1\u751f\uff0c\u4e8e\u662f\u8bf7\u62f3\u6559\u5e08\u6559\u62f3\u4e60\u6b66\u4e4b\u98ce\u907d\u8d77\u3002\u5b8b\u56fd\u5bbe\u5148\u8f88\u5c31\u662f\u90a3\u65f6\u4ece\u6cb3\u5357\u5468\u53e3\u6765\u5230\u868c\u57e0\u3002<\/p>\n\n\n\n<p>\u5b8b\u56fd\u5bbe\u5927\u5e08\uff081884\uff0d1960\uff09\u6cb3\u5357\u5468\u53e3\u4eba\u3002\u5b8b\u56fd\u5bbe\u5728\u5468\u53e3\u65f6\u66fe\u62dc\u4e07\u80dc\u9556\u5c40\u7684\u9556\u5e08\u6768\u5c11\u540c\u4e3a\u5e08\u5b66\u8fc7\u5c11\u6797\u3001\u5f39\u817f\u4ee5\u53ca\u9500\u5b50\u62f3\u7b49\uff0c\u56e0\u548c\u5362\u5d69\u9ad8\u5927\u5e08\uff081873\uff0d1961\uff09\u662f\u62dc\u628a\u5144\u5f1f\uff0c\u53c8\u7ecf\u5362\u5d69\u9ad8\u5927\u5e08\u4ecb\u7ecd\u62dc\u8881\u51e4\u4eea\u9ad8\u5e08\u4e3a\u5e08\u5b66\u4e60\u5fc3\u610f\u516d\u5408\u62f3\u3002\u4ee5\u540e\u8881\u51e4\u4eea\u7684\u5f92\u5f1f\u5c1a\u5b66\u793c\u3001\u5362\u5d69\u9ad8\u3001\u6768\u6bbf\u9752\u3001\u5b8b\u56fd\u5bbe\u7b49\u4e0b\u82e6\u529f\u7ec3\u62f3\uff0c\u6b66\u529f\u5353\u7edd\u6210\u4e3a\u5468\u53e3\u56db\u6770\u3002\u519b\u9600\u6df7\u6218\u671f\u95f4\uff0c\u8881\u4e16\u51ef\u59d4\u4efb\u4ed6\u7684\u5c0f\u5b66\u540c\u5b66\u502a\u4e16\u5145\u4e3a\u5b89\u5fbd\u7763\u519b\uff0c\u7763\u519b\u5e9c\u5efa\u5728\u868c\u57e0\u3002\u868c\u57e0\u6210\u4e86\u5b89\u5fbd\u7684\u653f\u6cbb\u3001\u7ecf\u6d4e\u3001\u519b\u4e8b\u4e2d\u5fc3\u3002\u868c\u57e0\u5df2\u7ecf\u7531\u4e00\u4e2a\u5c0f\u9c7c\u6751\u53d8\u6210\u5546\u8d38\u96c6\u9547\u3002\u4e3a\u4e86\u5546\u4e1a\u53d1\u5c55\u7684\u9700\u8981\uff0c\u7531\u5546\u4f1a\u53ec\u96c6\u5546\u4e1a\u540c\u4ec1\u7ec4\u6210\u868c\u57e0\u5e02\u6d88\u9632\u961f\u3002\u5b8b\u56fd\u5bbe\u5927\u5e08\u65f6\u4efb\u868c\u57e0\u6d88\u9632\u961f\u6b66\u672f\u603b\u6559\u7ec3\uff0c\u5e76\u5728\u868c\u57e0\u6559\u7801\u5934\u5de5\u4eba\u62f3\u672f\u3002\u636e\u8bb0\u8f7d\u5f53\u65f6\u968f\u5b8b\u56fd\u5bbe\u5927\u5e08\u5b66\u5fc3\u610f\u516d\u5408\u62f3\u7684\u67092500\u591a\u4eba\u3002\u5b8b\u56fd\u5bbe\u5927\u5e08\u7684\u5f97\u529b\u5f92\u5f1f\u6709\u4f55\u987a\u6210\u3001\u891a\u884d\u7389\u3001\u674e\u6587\u5f6a\u3001\u5b5f\u5e86\u548c\uff08\u6392\u540d\u4e0d\u5206\u5148\u540e\uff09\u7b49\u4e0d\u4e0b\u51e0\u5341\u4eba\uff0c\u4e3a\u4e86\u6253\u7801\u5934\u7684\u9700\u8981\uff0c\u90fd\u5b66\u5f97\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u7684\u5b9e\u6218\u62f3\u6cd5\uff0c\u4ee5\u540e\uff0c\u8fd9\u4e9b\u5f92\u5f1f\u90fd\u5404\u6709\u4f20\u4eba\u3002\u5b8b\u56fd\u5bbe\u5927\u5e08\u7684\u7b2c\u4e09\u4ee3\u4f20\u4eba\u5982\u674e\u7389\u5b89\u3001\u674e\u7389\u8d35\u3001\u9a6c\u7433\u748b\u3001\u891a\u798f\u6210\u3001\u5b5f\u5b89\u5168\u3001\u5f20\u5b97\u7403\u7b49\u6570\u5343\u4eba\uff0c\u5c3d\u5f97\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u4e4b\u771f\u4f20\u3002\u5e76\u4e3a\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u7684\u7ee7\u627f\u548c\u53d1\u5c55\u505a\u51fa\u4e86\u5f88\u5927\u7684\u8d21\u732e\u3002<\/p>\n\n\n\n<p>\u5b89\u5fbd\u5b8b\u95e8\u868c\u57e0\u5730\u533a\u7684\u5fc3\u610f\u516d\u5408\u62f3\u80fd\u591f\u5f97\u5230\u53d1\u626c\u548c\u5149\u5927\u5b9e\u4e3a\u5b8b\u56fd\u5bbe\u5927\u5e08\u4e4b\u529f\u52b3\u3002\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u53c8\u7ecf\u5b8b\u56fd\u5bbe\u5927\u5e08\u53ca\u5176\u5f92\u5f1f\u7b49\u4eba\u5c06\u6b64\u62f3\u4f20\u5230\u5317\u4eac\u3001\u5357\u4eac\u3001\u9a6c\u978d\u5c71\u3001\u829c\u6e56\u3001\u5f90\u5dde\u3001\u6dee\u5317\u3001\u961c\u9633\u3001\u6dee\u5357\u7b49\u5730\u3002\u4e8e\u662f\uff0c\u5927\u6c5f\u5357\u5317\u3001\u6dee\u6cb3\u4e24\u5cb8\u666e\u53ca\u4e86\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u3002\u5fc3\u610f\u516d\u5408\u62f3\u7531\u6cb3\u5357\u7684\u9ec4\u6cb3\u6587\u5316\u4f20\u64ad\u5230\u5b89\u5fbd\uff0c\u4e30\u5bcc\u548c\u53d1\u5c55\u4e86\u6dee\u6cb3\u6587\u5316\u3002\u7531\u4e8e\u868c\u57e0\u5730\u5904\u6dee\u6cb3\uff0c\u4ea4\u901a\u4fbf\u5229\uff0c\u5f53\u65f6\u7684\u7801\u5934\u8239\u53ea\u4e91\u96c6\uff0c\u6845\u6746\u6797\u7acb\uff1b\u7801\u5934\u5de5\u4eba\u4e3a\u4e86\u6253\u7801\u5934\u7684\u9700\u8981\uff0c\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u662f\u7279\u522b\u8bb2\u7a76\u5b9e\u6218\u7684\uff0c\u90a3\u65f6\uff0c\u7801\u5934\u5de5\u4eba\u4e3a\u4e86\u751f\u5b58\u548c\u6d3b\u547d\uff0c\u4e00\u5929\u90fd\u80fd\u6253\u516b\u67b6\uff0c\u6240\u4ee5\uff0c\u53ea\u8981\u4f60\u662f\u7801\u5934\u5de5\u4eba\uff0c\u4f60\u8981\u517b\u6d3b\u4e00\u5bb6\u8001\u5c0f\uff0c\u5c31\u8981\u4e0b\u529f\u592b\u7ec3\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\uff0c\u968f\u65f6\u51c6\u5907\u6253\u7801\u5934\u3001\u51fa\u4f53\u529b\u625b\u6d3b\u6323\u94b1\u751f\u6d3b\uff0c\u8fd9\u4e9b\u4e60\u6b66\u8005\u90fd\u662f\u771f\u6253\u5b9e\u6218\u4e2d\u7ec3\u51fa\u6765\u7684\u3002<\/p>\n\n\n\n<p><strong>\u8fc7\u53bb\u5e74\u4ee3\u6253\u7801\u5934\u662f\u4e3a\u4e86\u751f\u5b58<\/strong><\/p>\n\n\n\n<p>\u3000\u3000\u8bf4\u8d77\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u7684\u5b9e\u6218\uff0c\u8fd9\u91cc\u8fd8\u6709\u4e00\u4e2a\u5c0f\u6545\u4e8b\uff1a\u89e3\u653e\u524d\uff0c\u6709\u4e00\u5929\uff0c\u5b8b\u95e8\u7684\u7b2c\u4e8c\u4ee3\u5f1f\u5b50\u90fd\u5728\u6cb3\u4e0b\u7ec3\u62f3\uff0c\u5f53\u65f6\u5b8b\u56fd\u5bbe\u8001\u5e08\u4e0d\u5728\u573a\uff0c\u8fd9\u4e9b\u4eba\u7531\u5c11\u6b66\u5e08\u891a\u884d\u7389\u548c\u4f55\u5927\u5634\u5e26\u9886\u5927\u5bb6\u7ec3\u529f\u5728\u573a\u3002\u8fd9\u65f6\u6cb3\u5824\u4e0a\u8d70\u8fc7\u6765\u4e8c\u4e2a\u4eba\uff0c\u90fd\u50cf\u5de8\u7075\u795e\u4e00\u6837\uff0c\u90fd\u662f\u5927\u4e2a\u5b50\uff0c\u539f\u6765\u662f\u5f1f\u5144\u4e24\uff0c\u5176\u4e2d\u4e00\u4e2a\u53eb\u5927\u726f\u725b\u7684\u4eba\u662f\u54e5\u54e5\uff0c\u957f\u67091\u7c73\u4e5d\u51e0\u7684\u4e2a\u5b50\uff0c\u4ed6\u8fc7\u6765\u6311\u6218\u8bf4\uff1a\u201c\u542c\u8bf4\u4f60\u4eec\u5b8b\u95e8\u62f3\u5389\u5bb3\uff0c\u6562\u4e0d\u6562\u548c\u6211\u8bd5\u8bd5\uff1f\u201d\u65e2\u7136\u6709\u4eba\u201c\u677f\u9f13\u201d\uff08\u868c\u57e0\u8bdd\u662f\u201c\u6311\u6218\u201d\u7684\u610f\u601d\uff09\uff0c\u5927\u5e08\u5144\u4f55\u5927\u5634\uff08\u5916\u53f7\uff09\u5bf9\u5e08\u5f1f\u891a\u884d\u7389\u8bf4\uff1a\u201c\u8d70\u3001\u884d\u7389\uff0c\u8001\u5e08\u4e0d\u5728\uff0c\u6211\u4e24\u53bb\u6559\u8bad\u6559\u8bad\u8fd9\u5bb6\u4f19\u3002\u201d\u891a\u884d\u7389\u8bf4\uff1a\u201c\u5e08\u5144\uff0c\u6740\u9e21\u4f55\u7528\u5bb0\u725b\u5200\uff0c\u4f60\u53ea\u8981\u5728\u65c1\u770b\u7740\uff0c\u6211\u6765\u6253\u4ed6\u3002\u201d\u5f1f\u5144\u4fe9\u4e0a\u4e86\u575d\u5b50\uff0c\u5230\u5927\u726f\u725b\u8ddf\u524d\u8bf4\uff1a\u201c\u662f\u6587\u6253\u8fd8\u662f\u6b66\u6597\uff1f\u201d\u5927\u726f\u725b\u770b\u770b\u6765\u4eba\uff0c\u5e76\u4e0d\u8ba4\u8bc6\uff0c\u4ed6\u770b\u770b\u891a\u884d\u7389\u5fc3\u8bf4\uff1a\u201c\u4e5f\u4e0d\u8fc7\u767e\u516b\u65a4\uff0c\u6ca1\u6709\u5565\u4e86\u4e0d\u8d77\u201d\uff0c\u5c31\u5bf9\u891a\u884d\u7389\u8bf4\uff1a\u201c\u6765\u5427\uff01\u201d\u5927\u726f\u725b\u4e00\u770b\u891a\u884d\u7389\u4e2a\u5934\u5e76\u4e0d\u5927\u5e76\u4e0d\u58ee\u5b9e\uff0c\u6709\u4e9b\u770b\u4e0d\u8d77\uff0c\u5fc3\u8bf4\uff1a\u201c\u4e00\u4e2a\u4e94\u767e\u65a4\u7684\u725b\u6211\u90fd\u80fd\u6454\u5012\uff0c\u8fd9\u6837\u4e00\u4e2a\u7626\u5c0f\u5b50\u96be\u9053\u8fd8\u7ecf\u7684\u4f4f\u6211\u6454\u5417\uff1f\u201d\u5c31\u6709\u4e9b\u8f7b\u89c6\u891a\u884d\u7389\u3002\u4ed6\u521a\u8bf4\u5b8c\uff1a\u201c\u6765\u5427\uff01\u201d\u8bdd\u6ca1\u843d\u97f3\uff0c\u891a\u884d\u7389\u4e00\u4e2a\u75be\u6b65\u7bad\u8e7f\u65e9\u5df2\u6765\u5230\u5927\u59d1\u725b\u8ddf\u524d\uff0c\u4e0a\u53bb\u4e00\u4e2a\u51b2\u5929\u70ae\uff0c\u4e00\u62f3\u6253\u5230\u5927\u726f\u725b\u7684\u5de6\u816e\u90e8\u52a8\u8109\u8840\u7ba1\u5904\uff0c\u53ea\u89c1\u5927\u726f\u725b\u5495\u549a\u4e00\u8de4\u6454\u5230\u5728\u5730\uff0c\u50cf\u5c0f\u5357\u5c71\u7684\u5854\u5012\u4e86\u4e00\u6837\uff0c\u6b63\u597d\u6454\u5230\u575d\u5b50\u65c1\uff0c\u811a\u4e0b\u4e00\u6ed1\uff0c\u987a\u7740\u575d\u4f53\u5495\u565c\u5495\u565c\u6eda\u4e0b\u575d\u5b50\u3002\u5728\u575d\u5b50\u5e95\u4e0b\u5b8b\u95e8\u7684\u5e08\u5144\u5f1f\u8fd8\u6ca1\u6709\u770b\u6e05\u695a\u662f\u600e\u4e48\u56de\u4e8b\uff0c\u53ea\u89c1\u575d\u5b50\u4e0a\u6eda\u4e0b\u4e00\u4e2a\u4eba\u6765\uff0c\u90fd\u7b11\u7740\u8bf4\uff1a\u201c\u5927\u726f\u725b\uff0c\u4f60\u5e73\u5e38\u6454\u725b\u6454\u7684\u5229\u901f\uff0c\u4eca\u5929\u9047\u5230\u884d\u7389\u600e\u4e48\u641e\u7684\uff0c\u4e0d\u6491\u4e00\u5bb6\u4f19\u5c31\u5230\u5730\u8d77\u4e0d\u6765\u4e86\u3002\u201d\u8bf4\u5b8c\u5927\u5bb6\u4e00\u8d77\u5927\u7b11\u3002\u5927\u726f\u725b\u534a\u5929\u624d\u722c\u8d77\u6765\u8bf4\uff1a\u201c\u4f60\u4eec\u5b8b\u95e8\u62f3\u771f\u5feb\uff0c\u4f69\u670d\uff01\u4f69\u670d\uff01\u201d\u8bf4\u5b8c\u7070\u6e9c\u6e9c\u5730\u5728\u4ed6\u5f1f\u5144\u4e24\u7684\u6276\u6301\u4e0b\u4e00\u8d77\u8d70\u4e86\u3002\u8fd9\u4ef6\u4e8b\u4e00\u76f4\u5230\u73b0\u5728\u5b8b\u95e8\u7b2c\u4e8c\u4ee3\u5e08\u53d4\u8bf4\u8d77\u6765\u8fd8\u771f\u771f\u5207\u5207\u3002\u8fd9\u5c31\u662f\u201c\u5b8b\u95e8\u5fc3\u610f\u62f3\u663e\u5a01\u529b\uff0c\u891a\u884d\u7389\u4e00\u62f3\u5b9a\u4e7e\u5764\u201d\u3002\u539f\u6765\uff0c\u8fd9\u4e2a\u53eb\u5927\u726f\u725b\u7684\u5bb6\u4f19\u662f\u4fc4\u7f57\u65af\u4eba\u751f\u7684\u79cd\uff0c\u5e73\u5e38\u6709\u4e00\u628a\u529b\u6c14\uff0c\u4e13\u95e8\u5728\u9a6c\u620f\u5267\u56e2\u91cc\u8868\u6f14\u6454\u725b\uff0c\u51e0\u767e\u65a4\u7684\u9ec4\u725b\u53ea\u8981\u7ecf\u4ed6\u624b\u4e00\u677f\uff0c\u725b\u5c31\u5012\u5730\u3002\u56e0\u6b64\u4ed6\u5f88\u9a84\u50b2\uff0c\u8c01\u77e5\u9053\uff0c\u4eba\u5e76\u4e0d\u662f\u725b\uff0c\u7279\u522b\u662f\u4e60\u6b66\u4e4b\u4eba\uff0c\u66f4\u4e0d\u53ef\u5c0f\u770b\u3002\u4e8b\u540e\u522b\u4eba\u95ee\u891a\u884d\u7389\u8bf4\uff1a\u201c\u4f60\u600e\u9ebd\u6253\u5927\u726f\u725b\u90a3\u9ebd\u9ebb\u5229\uff1f\u201d\u891a\u884d\u7389\u8bf4\uff1a\u201c\u4f60\u4eec\u4e0d\u662f\u5e38\u542c\u5e08\u5085\u8bf4\uff1a\u4e0a\u6253\u54bd\u5589\u4e0b\u6253\u9634\uff0c\u5de6\u53f3\u4e24\u808b\u5e76\u4e2d\u5fc3\u5417\uff1f\u201d\u6211\u5c31\u662f\u4e0a\u53bb\u7ed9\u4ed6\u4e00\u4e2a\u901a\u5929\u70ae\uff0c\u76f4\u63a5\u6253\u4ed6\u7684\u54bd\u5589\u5904\uff0c\u4ed6\u5934\u91cd\u811a\u8f7b\uff0c\u80fd\u4e0d\u5012\u5417\uff1f\u201d<\/p>\n\n\n\n<p>\u3000\u3000\u7136\u800c\uff0c\u6b66\u672f\u7528\u4e8e\u5b9e\u6218\u514d\u4e0d\u4e86\u5c31\u4f1a\u7528\u8fc7\u5934\u529b\uff0c\u8fd9\u6837\u4f1a\u6d88\u8017\u81ea\u5df1\u7684\u4f53\u80fd\uff0c\u96be\u514d\u4f1a\u77ed\u5bff\uff0c\u56e0\u6b64\uff0c\u5728\u62f3\u672f\u4e2d\u589e\u52a0\u4e00\u4e9b\u7ec3\u517b\u7ed3\u5408\u7684\u4e1c\u897f\u5728\u5185\uff0c\u8fd9\u5c31\u5f62\u6210\u4e86\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u5b9e\u6218\u548c\u517b\u751f\u5e76\u91cd\u7684\u53cc\u91cd\u5185\u5bb9\uff0c\u8fd9\u4e5f\u5c31\u662f\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u548c\u5176\u4ed6\u5fc3\u610f\u62f3\u4e00\u6837\uff0c\u5177\u6709\u5185\u517b\u5916\u7ec3\u7684\u5185\u6db5\u5728\u91cc\u9762\u3002\u5176\u5b9e\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u7684\u5185\u6db5\u4e2d\u4e5f\u514d\u4e0d\u4e86\u517b\u751f\u7684\u529f\u80fd\u3002\u800c\u4e14\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u5728\u5e73\u5e38\u7ec3\u4e60\u65f6\u5e76\u4e0d\u7528\u62d9\u529b\u3002\u5b8b\u5e08\u7237\u5e38\u8bf4\uff1a\u201c\u7ec3\u62f3\u65f6\uff0c\u6ca1\u9047\u5230\u654c\u4eba\u7528\u529b\u5e72\u4ec0\u4e48\uff1f\u201d\u53e4\u4eba\u4e0d\u662f\u5e38\u8bf4\uff1a\u201c\u6253\u7a7a\u62f3\u8d39\u529b\uff0c\u8bf4\u7a7a\u8bdd\u52b3\u795e\uff01\u201d\u8fd9\u5c31\u662f\u5b89\u5fbd\u5b8b\u95e8\u5fc3\u610f\u516d\u5408\u62f3\u7684\u5965\u5999\u6240\u5728\u3002<\/p>\n\n\n\n<p><strong>\u5b8b\u56fd\u5bbe\u5b97\u5e08\u5176\u4eba<\/strong><\/p>\n\n\n\n<p>\u5b8b\u56fd\u5bbe\u5148\u751f\uff0c\u751f\u4e8e1882\u5e74\u519c\u53867\u670828\u65e5\uff0c\u5352\u4e8e1960\u5e749\u670811\u65e5\uff0c\u4eab\u5e7478\u5c81\uff0c\u539f\u7c4d\u6cb3\u5357\u7701\u5468\u53e3\u5e02\u5fb7\u5316\u8857\u4eba\u3002\u5148\u751f\u53bb\u4e16\u540e\uff0c\u846c\u4e8e\u868c\u57e0\u5e02\u5357\u90ca\u71d5\u5c71\uff0c70\u5e74\u56e0\u4e2d\u56fd\u4eba\u6c11\u89e3\u653e\u519b\u5728\u6b64\u521b\u529e\u519b\u4e8b\u5766\u514b\u5b66\u6821\uff0c\u6545\u4e8e\u519c\u538610\u670820\u65e5\uff0c\u7531\u5b8b\u56fd\u5bbe\u4e4b\u5b59\u5b8b\u7389\u8d24\u4e0e\u7b2c\u4e09\u4ee3\u4f20\u4eba\u90ed\u5e7f\u8d35\u7b49\uff0c\u628a\u5893\u8fc1\u4e8e\u868c\u57e0\u5e02\u6cb3\u5317\u9ad8\u5bb6\u5eb5\u90ed\u5e7f\u8d35\u5148\u751f\u7684\u81ea\u7559\u5730\u91cc\u8fb9\u5b89\u846c\u3002\u6b64\u5730\u540e\u6210\u4e3a\u5b8b\u5bb6\u5893\u5730\uff0c\u5176\u4e49\u5b50\u674e\u6587\u5f6a\u592b\u5987\u5747\u957f\u7720\u4e8e\u6b64\u3002<\/p>\n\n\n\n<p>\u5b8b\u7236\u7cbe\u4e8e\u91d1\u94f6\u6253\u9020\u6280\u672f\uff0c\u5f00\u4e86\u4e24\u4e2a\u94f6\u5320\u7089\uff0c\u5728\u5f53\u65f6\u793e\u4f1a\u4e2d\u4e5f\u79f0\u5f97\u4e0a\u5bcc\u88d5\u5bb6\u5ead\uff0c\u201c\u7a77\u6587\u5bcc\u6b66\u201d\u5728\u90a3\u8352\u4e71\u4e4b\u5e74\uff0c\u4e3a\u4e86\u56fd\u5bb6\u7684\u5b89\u5b9a\uff0c\u4e5f\u4e3a\u4e86\u9632\u8eab\u5065\u4f53\uff0c\u8001\u4eba\u90fd\u652f\u6301\u5b69\u5b50\u4eec\u4e60\u6587\u7ec3\u6b66\uff0c\u5148\u751f\u81ea\u5e7c\u55dc\u6b66\u5982\u547d\uff0c1894\u5e74\u5341\u4e8c\u5c81\u7684\u5b8b\u56fd\u5bbe\u7531\u7236\u6bcd\u9001\u4e07\u80dc\u9556\u5c40\u62dc\u603b\u9556\u5934\u6768\u5c11\u540c\u5148\u751f\u5b66\u4e60\u5c11\u6797\u6d3e\u62f3\u68b0\uff0c\u5341\u8d9f\u5f39\u817f\u7b49\uff0c\u5728\u9556\u5c40\u671f\u95f4\u53c8\u5f97\u5230\u5404\u95e8\u5404\u6d3e\u9ad8\u624b\u7684\u6307\u70b9\u3002\u56e0\u5148\u751f\u52e4\u5b66\u82e6\u7ec3\uff0c\u5c0a\u5e08\u91cd\u9053\uff0c\u5148\u751f\u8c26\u865a\u597d\u5b66\uff0c\u5bf9\u81ea\u5df2\u7684\u6280\u672f\u7cbe\u76ca\u6c42\u7cbe\uff0c\u5e38\u5e38\u4e0e\u540c\u9053\u5207\u78cb\u6b66\u827a\uff0c\u53d6\u957f\u8865\u77ed\uff0c\u540e\u95fb\u542c\u8881\u51e4\u4eea\u3001\u5362\u5d69\u9ad8\u5e08\u5f92\uff0c\u529f\u592b\u5f88\u662f\u4e86\u5f97\uff0c\u7cbe\u901a\u5fc3\u610f\u516d\u5408\u62f3\u672f\uff0c\u8fdc\u8fd1\u62f3\u5e08\u65e0\u4eba\u80fd\u654c\uff0c\u5148\u751f\u4e8e\u662f\u524d\u53bb\u8f83\u6280\u3002\u201c\u884c\u5bb6\u4f38\u4f38\u624b\uff0c\u4fbf\u77e5\u6709\u6ca1\u6709\u201d\uff0c\u9ad8\u624b\u6bd4\u6b66\uff0c\u4e3e\u624b\u6295\u8db3\u4e4b\u95f4\u5373\u53ef\u770b\u51fa\u5bf9\u65b9\u7684\u5b9e\u529b\uff0c\u5362\u5d69\u9ad8\u8d70\u7684\u662f\u201c\u9e21\u5f62\u4e09\u89d2\u6b65\u201d\uff0c\u8d70\u5373\u8e29\uff0c\u8e29\u5373\u95ea\uff0c\u95ea\u5373\u6253\uff0c\u9000\u5373\u95ea\uff0c\u95ea\u5373\u8e29\uff0c\u8e29\u5373\u6253\uff0c\u6253\u4e2d\u53d8\uff0c\u5b88\u4e2d\u7528\u4e2d\u987e\u6253\u5408\u4e00\uff0c\u865a\u5b9e\u76f8\u517c\u5feb\u6162\u547c\u5e94\uff0c\u653b\u5b88\u517c\u5907\uff0c\u53d8\u5316\u65e0\u7a77\u3002\u800c\u5148\u751f\u957f\u9a71\u76f4\u5165\uff0c\u5927\u5f00\u5927\u5408\u7684\u6253\u6cd5\u663e\u7136\u5728\u4e0e\u5362\u6bd4\u6b66\u4e2d\u4e0d\u592a\u9002\u5e94\u3002\u5362\u4e5f\u770b\u51fa\u5148\u751f\u5c11\u6797\u529f\u592b\u6df1\u539a\uff0c\u662f\u96be\u5f97\u7684\u6b66\u5b66\u5947\u624d\uff0c\u867d\u5148\u751f\u4e0d\u6562\u5192\u7136\u653b\u51fb\uff0c\u4f46\u95ea\u5c55\u817e\u632a\u4e4b\u6cd5\u8fd8\u7b97\u7cbe\u5999\uff0c\u53cd\u5e94\u8fd8\u7b97\u654f\u6377\uff0c\u6545\u53cc\u65b9\u62f1\u624b\u505c\u6218\u3002\u4e24\u4eba\u6027\u60c5\u76f8\u6295\uff0c\u4e00\u89c1\u5982\u6545\uff0c\u540e\u7ed3\u4e3a\u91d1\u5170\uff0c\u76f4\u5230\u7ec8\u751f\u3002\u968f\u5373\u7531\u4e49\u5144\u5362\u5d69\u9ad8\u63a8\u8350\uff0c\u6309\u6c5f\u6e56\u89c4\u77e9\u9012\u8d34\u62dc\u8881\u51e4\u4eea\u4e3a\u5e08\uff0c\u5f53\u65f6\u5b59\u4e2d\u5c71\u5148\u751f\u6380\u8d77\u8f9b\u4ea5\u9769\u547d\uff0c\u4e3e\u56fd\u4e0a\u4e0b\u5021\u884c\u201c\u5c1a\u6b66\u7cbe\u795e\u201d\uff0c\u63a8\u7ffb\u5c01\u5efa\u738b\u671d\u52bf\u5728\u5fc5\u884c\uff0c\u6545\u800c\u8881\u51e4\u4eea\u8001\u5e08\u7834\u4f8b\u6536\u4e0b\u4e86\u7b2c\u4e00\u4e2a\u6c49\u65cf\u5f1f\u5b50\uff0c\u4ece\u6b64\u5148\u751f\u591c\u4ee5\u7ee7\u65e5\uff0c\u5728\u7262\u8bb0\u8981\u9886\u7684\u57fa\u7840\u4e0a\uff0c\u82e6\u7ec3\u5355\u5f0f\u5b50\uff0c\u65e5\u590d\u4e00\u65e5\uff0c\u5e74\u590d\u5e74\u4e00\u5e74\u3002\u5148\u751f\u4e89\u5206\u593a\u79d2\uff0c\u52e4\u5b66\u82e6\u7ec3\uff0c\u4ed6\u7684\u4e00\u8a00\u4e00\u884c\uff0c\u4e00\u4e3e\u4e00\u52a8\uff0c\u8001\u5e08\u770b\u5728\u773c\u91cc\u559c\u5728\u5fc3\u91cc\u3002\u5148\u751f\u7684\u54c1\u5fb7\u4ee5\u53ca\u806a\u6167\u4e0e\u597d\u5b66\u7ec8\u4e8e\u611f\u52a8\u4e86\u8001\u5e08\uff0c\u6240\u4ee5\u628a\u5e73\u751f\u6240\u5b66\u5168\u90e8\u4f20\u6388\u7ed9\u4e86\u5b8b\u56fd\u5bbe\u5148\u751f\u3002<\/p>\n\n\n\n<p>1911\u5e74\u5e95\uff0c\u6d25\u6d66\u94c1\u8def\u5168\u7ebf\u901a\u8f66\uff0c\u4e8e\u662f\u5b89\u5fbd\u868c\u57e0\u7684\u6c34\u9646\u4ea4\u901a\u6709\u4e86\u5f88\u5927\u7684\u53d1\u5c55\uff0c\u5f53\u65f6\u6b63\u662f\u519b\u9600\u6df7\u6218\u4e4b\u65f6\uff0c\u793e\u4f1a\u6cbb\u5b89\u6df7\u4e71\uff0c\u5e2e\u6d3e\u3001\u571f\u532a\u6b3a\u884c\u9738\u5e02\uff0c\u7801\u5934\u5de5\u4eba\u4e3a\u4e86\u517b\u5bb6\u7cca\u53e3\uff0c\u5c31\u96be\u514d\u4e0e\u9ed1\u5e2e\u3001\u5730\u75de\u4f5c\u6597\u4e89\uff0c\u56e0\u6b64\uff0c\u6253\u67b6\u6597\u6bb4\uff0c\u65f6\u6709\u53d1\u751f\u3002\u5b8b\u56fd\u5bbe\u5148\u751f\u5c31\u662f\u8fd9\u4e2a\u65f6\u5019\u6765\u5230\u4e86\u868c\u57e0\u3002\u5148\u751f\u66fe\u5728\u5927\u519b\u9600\u51af\u7389\u7965\u90e8\u4e0b\u62c5\u4efb\u8fc7\u6b66\u672f\u6559\u5b98\u30021913\u5e74\uff0c\u519b\u9600\u502a\u55e3\u51b2\uff08\u4eca\u5b89\u5fbd\u961c\u5357\u53bf\u67f4\u96c6\u9547\u502a\u5bb6\u5be8\u4eba\uff09\u88ab\u8881\u4e16\u51ef\u59d4\u4ee5\u5b89\u5fbd\u7763\u519b\u517c\u957f\u6c5f\u526f\u5de1\u9605\u4f7f\uff0c\u4e8e\u65f6\uff0c\u502a\u5728\u868c\u57e0\u5174\u5efa\u201c\u7763\u519b\u5e9c\u201d\uff0c\u5510\u5c11\u5019\u4e0e\u502a\u7684\u4f84\u5b50\u502a\u9053\u826f\u540c\u5728\u5929\u6d25\u201c\u8d35\u65cf\u5b66\u6821\u201d\u8bfb\u4e66\uff0c\u540e\u4e5f\u6295\u9760\u502a\u505a\u4e86\u201c\u8d22\u653f\u5385\u957f\u201d\u30021917\u5e74\uff0c\u5510\u5728\u868c\u57e0\u5927\u5174\u571f\u6728\uff0c\u5efa\u9020\u201c\u9038\u56ed\u201d\uff08\u5373\u5510\u5bb6\u82b1\u56ed\uff09\u3002\u5e76\u8bf7\u5362\u5d69\u9ad8\u3001\u5b8b\u56fd\u5bbe\u4e8c\u4f4d\u5148\u751f\u4e3a\u5176\u4fdd\u9556\u30021938\u5e74\uff0c\u502a\u6295\u9760\u4e86\u65e5\u672c\u4eba\uff0c\u5362\u3001\u5b8b\u4e0d\u613f\u4e3a\u6c49\u5978\u4f5c\u4e8b\uff0c\u653e\u5f03\u4f18\u539a\u7684\u5f85\u9047\u3001\u8212\u9002\u7684\u751f\u6d3b\uff0c\u968f\u540e\u5362\u8fc7\u957f\u6c5f\u5230\u4e0a\u6d77\u5b9a\u5c45\uff0c\u4f20\u6388\u5fc3\u610f\u516d\u5408\u62f3\uff0c\u5b8b\u5728\u868c\u57e0\u6559\u7a77\u82e6\u7684\u7801\u5934\u5de5\u4eba\uff0c\u76f4\u81f3\u53bb\u4e16\u3002<\/p>\n\n\n\n<p>\u868c\u57e0\u5730\u533a\uff0c\u5386\u6765\u5c31\u6709\u5c1a\u6b66\u4e4b\u98ce\uff0c\u968f\u5148\u751f\u5b66\u62f3\u8005\u4e0d\u4e0b\u6570\u5343\u4eba\uff0c\u7136\u5f97\u5176\u771f\u4f20\u8005\u4ec5\u674e\u6587\u5f6a\u3001\u674e\u514b\u4fed\u3001\u891a\u884d\u7389\u3001\u4f55\u987a\u6210\u3001\u5510\u
3\u6709\u4e00\u5bf9\u8054\uff1a\u201c\u5c11\u7956\u6d41\u4f20\u5929\u4e0b\u79cd\uff0c\u9716\u5e08\u6559\u51fa\u827a\u65e0\u7a77\u201d\u3002\u53e6\u4f20\u4e00\u5357\u5c11\u6797\u5bfa\u5bf9\u8054\uff1a\u201c\u6000\u62b1\u82f1\u96c4\u6c14\uff0c\u540d\u4f20\u4fa0\u58eb\u98ce\u201d\u3002<\/p>\n\n\n\n<p>\u4e3b\u8981\u4f20\u4eba\u6709\u5f20\u5927\u6c49\u3001\u5e06\u5bee\u5c71\u3001\u6797\u7c73\u7cd5\u3001\u674e\u817e\u8f89\u3001\u674e\u6e05\u8fde\uff08\u674e\u781a\u4e4b\u7236\uff09\u3001\u53f6\u6562\u3001\u82cf\u6587\u67cf\uff08\u65b0\u534e\u897f\u77f3\u72ee\u5df7\u4eba\uff09\u3001\u674e\u781a\u7b49\u3002\u674e\u781a\u5b57\u82e5\u8015\uff0c\u662f\u6d0b\u8001\u6d32\u56fd\u672f\u9986\u7b2c\u4e03\u4ee3\u4f20\u4eba\uff0c\u73b0\u4e3a\u6b66\u672f\u9986\u4e3b\u6301\u4eba\u3002<\/p>\n\n\n\n<p>\u4f55\u9633\u62f3\u5f92\u624b\u62f3\u5957\u8def\u6709\uff1a\u7ec3\u5934\u3001\u6253\u8282\u3001\u56db\u5927\u953b\u3001\u53cc\u7ee5\u3001\u53cc\u722a\u3001\u98de\u51e4\u4e0b\u7530\u3001\u4e8c\u5341\u516b\u5bbf\u3001\u6d1e\u5bbe\u9189\u9152\u3001\u9ec4\u8702\u51fa\u5de2\uff08\u5df2\u5931\u4f20\uff09\u3001\u5341\u9526\u6cd5\uff08\u5df2\u5931\u4f20\uff09\u3001\u4ed9\u4eba\u64c2\u9f13\u3002<\/p>\n\n\n\n<p>\u5668\u68b0\u6709\uff1a\u7c50\u724c\u3001\u5927\u5200\u3001\u6587\u6b66\u53c9\u3001\u94a9\u9570\u67aa\u3001\u67b7\u3001\u68cd\u3001\u94c1\u5c3a\uff08\u56db\u65b9\u68f1\uff09\u3001\u53cc\u5408\u5200\u3001\u53cc\u67b7\u3001\u53cc\u94a9\u9570\u3001\u53cc\u65a7\u3001\u66f2\u5c3a\u3001\u9e7f\u89d2\uff08\u6709\u53cc\u53c9\uff0c\u4e00\u957f\u4e00\u77ed\uff0c\u5c5e\u77ed\u5175\u5668\uff09\u3002<\/p>\n\n\n\n<p>\u5357\u5c11\u6797\u5d14\u6b8a\u7f18\u7956\u5e08\u6240\u4f20\u821e\u72ee\u6cd5\uff1b\u91d1\u72ee\u8c61\u5f81\u4f5b\u95e8\uff0c\u72ee\u5973\u95f4\u8c61\u5f81\u548c\u5c1a\uff0c\u72ee\u5973\u95f4\u624b\u4e2d\u7684\u7af9\u9752\u4ee3\u8868\u7075\u829d\u8349\uff0c\u6247\u4ee3\u8868\u82ad\u8549\u6247\u3002\u7075\u829d\u8349\u662f\u4f5b\u5bb6\u6240\u8ffd\u6c42\u4e4b\u5723\u7269\u3002\u91d1\u72ee\u5fc5\u987b\u505a\u51fa\u5bfb\u627e\u7075\u829d\u8349\u7684\u8868\u60c5\uff0c\u72ee\u5973\u95f4\u5728\u8868\u73b0\u51fa\u672c\u62f3\u79cd\u98ce\u683c\uff0c\u8eab\u624b\u529f\u592b\u3002<\/p>\n\n\n\n<p>\u53e6\u4e00\u4f55\u9633\u62f3\u5e08\u8521\u5c16\uff0c\u5341\u4e09\u5c81\u65f6\u5230\u9876\u7530\u4e0b\u5b66\u4e60\u53cc\u679d\u4ed4\u6218\u62f3\uff0c\u89e3\u653e\u521d\u5411\u65b0\u534e\u897f\u77f3\u72ee\u5df7\u7684\u82cf\u6587\u67cf\u5e08\u5b66\u4e60\u4f55\u9633\u62f3\u548c\u8fbe\u5c0a\u62f3\u3002\u82cf\u6587\u67cf\u5e08\u7684\u4f55\u9633\u62f3\u5b66\u4e8e\u6d0b\u8001\u6d32\u201c\u4f55\u9633\u5802\u201d\uff0c\u6587\u67cf\u5e08\u751f\u524d\u4e0e\u901a\u5143\u5e99\u4ea6\u6709\u5f80\u6765\u3002<\/p>\n\n\n\n<p>\u8521\u5c16\u5e08\u4e00\u4e5d\u4e94\u516b\u5e74\u5f00\u59cb\u5728\u4e94\u91d1\u5382\u6559\u62f3\uff0c\u7b2c\u4e00\u4e2a\u5b66\u751f\u662f\u9648\u6cfd\u6c11\uff0c\u540e\u6765\u5171\u6709\u4e00\u767e\u591a\u4eba\u5411\u5c16\u5e08\u5b66\u4e60\u4f55\u9633\u62f3\u3002\u6c5f\u5e86\u6811\uff08\u522b\u540d\u201c\u4e24\u5343\u201d\uff09\u4e8e\u4e00\u4e5d\u516d\u4e09\u5e74\u5411\u5c16\u5e08\u5b66\u4e60\u4f55\u9633\u62f3\uff0c\u662f\u5c16\u5e08\u7684\u4e3b\u8981\u5b66\u751f\u3002<\/p>\n\n\n\n<p>\u8521\u5c16\u5e08\u8fd8\u8bf7\u5176\u8868\u5144\u2014\u2014\u4e5d\u6e56\u5c0f\u6885\u6eaa\u9648\u5e94\u65f6\u5e08\u6765\u6f33\u6559\u6388\u592a\u7956\u62f3\uff0c\u5957\u8def\u6709\uff1a\u53cc\u9e70\u7b2c\u4e00\u5957\u3001\u7b2c\u4e8c\u5957\uff08\u5341\u516b\u6b65\uff09\u3001\u7b2c\u4e09\u5957\uff08\u571f\u7f57\u6c49\uff09\u3002\u6b64\u62f3\u7ef5\u7c98\u7d27\u51d1\uff0c\u4ee5\u67d4\u514b\u521a\uff0c\u521a\u67d4\u76f8\u6d4e\u3002<\/p>\n\n\n\n<p>\u8521\u5c16\u5e08\u4e8e\u4e00\u4e5d\u4e030\u5e74\u75c5\u901d\uff0c\u65f6\u5e74\u56db\u5341\u591a\u5c81\u3002<\/p>\n\n\n\n<p>\u4e00\u8d77\u4ea4\u6d41\u90fd\u662f\u6f33\u5dde\u7684\u6b66\u672f\u540c\u597d\uff0c\u6709\u7530\u4e30\u6751\u7684\u4f55\u9633\u5802\u4e94\u7956\u3001\u701b\u6d32\u4f55\u9633\u5802\u4e94\u7956\u7b49\u3002\u4e4b\u524d\u66fe\u6709\u51e0\u6b21\u548c\u7530\u4e30\u4f55\u9633\u5802\u4e94\u7956\u4ea4\u6d41\u8fc7\uff0c\u5bf9\u5176\u62f3\u6cd5\u6709\u4e00\u5b9a\u4e86\u89e3\u3002\u6b64\u6b21\u662f\u7b2c\u4e00\u6b21\u548c\u701b\u6d32\u4f55\u9633\u5802\u4e94\u7956\u4ea4\u6d41\uff0c\u6240\u4ee5\u6000\u7740\u4e00\u9897\u63a2\u7d22\u7684\u5fc3\u5f88\uff0c\u8ba4\u771f\u5730\u89c2\u770b\u7740\u701b\u6d32\u4f55\u9633\u5802\u4e94\u7956\u6f14\u7ec3\u7684\u5957\u8def\uff0c\u5148\u662f\u4e0a\u4ed6\u4eec\u7684\u57fa\u7840\u62f3\u201c\u7ec3\u5934\u201d\uff0c\u4e00\u542c\u5957\u8def\u540d\u5c31\u77e5\u9053\u4e0e\u9e64\u62f3\u6709\u4e00\u5b9a\u5173\u7cfb\uff0c\u6ca1\u679c\u4e0d\u5176\u7136\u4ed6\u4eec\u7ec3\u51fa\u6765\u7684\u786e\u5b9e\u662f\u9e64\u7684\u5473\u9053\uff0c\u529f\u67b6\u9ad8\uff0c\u624b\u6cd5\u548c\u9e64\u624b\u6cd5\u5f88\u63a5\u8fd1\uff0c\u7d27\u63a5\u4e00\u5957\u5176\u95e8\u6d3e\u4e2d\u7684\u8f83\u9ad8\u7ea7\u5957\u8def\u201c\u4e8c\u5341\u516b\u5bbf\u201d\uff0c\u5176\u8eab\u6cd5\u591a\u6709\u7f57\u6c49\u5473\uff0c\u6709\u5f88\u591a\u624b\u6cd5\u811a\u6cd5\u548c\u4e94\u7956\u9e64\u9633\u62f3\u6781\u4e3a\u76f8\u4f3c\uff0c\u4e0a\u6b65\u540e\u811a\u62d6\u9a6c\u8ddf\u8fdb\u3001\u76d8\u9f99\u8e22\u3001\u53cc\u98de\u8e22\u2026\u2026\u592a\u7cbe\u5f69\u4e86\u3002<\/p>\n\n\n\n<p>\u5ea7\u8c08\u4e2d\u5bf9\u4ed6\u4eec\u4f20\u627f\u8fdb\u4e00\u6b65\u505a\u4e86\u89e3\u3002\u701b\u6d32\u662f\u4f4d\u4e8e\u4e5d\u9f99\u6c5f\u8fb9\u4e0a\u7684\u4e00\u4e2a\u7801\u5934\uff0c\u6709\u4e00\u5ea7\u53e4\u5e99\u201c\u701b\u6d32\u4ead\u201d\uff0c\u56e0\u6b64\u800c\u5f97\u540d\u3002\u8001\u5e08\u5085\u8bf4\uff1a\u5728\u94c1\u516c\u8def\u6ca1\u6709\u56db\u901a\u516b\u8fbe\u7684\u65f6\u4ee3\u8fd0\u8f93\u884c\u4e3b\u8981\u9760\u8239\u8fd0\u4e3a\u4e3b\uff0c\u701b\u6d32\u81ea\u53e4\u5c31\u662f\u4e5d\u9f99\u6c5f\u7684\u91cd\u8981\u5185\u6cb3\u7801\u5934\uff0c\u4e0a\u6e38\u7684\u8239\u90fd\u8f7d\u8d27\u505c\u6cca\u701b\u6d32\uff0c\u53a6\u95e8\u7684\u8239\u4e5f\u5230\u701b\u6d32\u8f7d\u8d27\u51fa\u6d0b\uff0c\u53ef\u60f3\u800c\u77e5\u701b\u6d32\u53e4\u65f6\u7684\u7e41\u534e\u3002<\/p>\n\n\n\n<p>\u701b\u6d32\u4f55\u9633\u4e94\u7956\u7684\u4f20\u627f\uff1a<\/p>\n\n\n\n<p>1\uff0e&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;\u701b\u6d32\u4f55\u9633\u4e94\u7956\u662f\u4e00\u4f4d\u6765\u81ea\u6c38\u5b9a\u5728\u701b\u6d32\u5f00\u9152\u5e97\u540d\u53eb\u4f55\u9633\u7684\u62f3\u5e08\u6240\u4f20\u3002<\/p>\n\n\n\n<p>2\uff0e&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;\u4e94\u7956\u7684\u4f20\u8bf4\uff1a\u636e\u4f20\u627f\u6240\u8bf4\u5c11\u6797\u5bfa\u88ab\u711a\u4e4b\u540e\uff0c\u6709\u7b2c\u4e94\u4ee3\u4f20\u4eba\u5d14\u8bf8\u7f18\u7b49\u4e03\u4eba\u9003\u51fa\uff0c\u540e\u4e24\u4eba\u4e2d\u9014\u75c5\u4ea1\uff0c\u4f59\u4e94\u4eba\u6539\u540d\u6362\u59d3\u5165\u6c11\u95f4\uff0c\u540e\u79f0\u201c\u4e94\u4ee3\u7956\u5e08\u201d\uff0c\u5373\u201c\u4e94\u7956\u201d\u3002<\/p>\n\n\n\n<p>3\uff0e&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;\u4e94\u7956\u4f20\u5230\u4f55\u9633\u5df2\u7ecf\u662f\u7b2c\u4e09\u4ee3\u4e86\uff0c\u5230\u701b\u6d32\u53c8\u4f20\u81f3\u4eca\u7b2c\u4e03\u4ee3\uff08\u7528\u4e00\u4ee320\u5e74\u7b97\uff0c\u4f55\u9633\u5728\u701b\u6d32\u662f\u5e94\u8be5\u662f150\u5e74\u4ee5\u4e0a\u7684\u5386\u53f2\u4e86\uff09\u3002<\/p>\n\n\n\n<p>4\uff0e&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;\u701b\u6d32\u81f3\u4eca\u53ea\u4e60\u4f55\u9633\u5802\u4e94\u7956\u6ca1\u6709\u53c2\u6742\u522b\u7684\u62f3\u79cd\u3002<\/p>\n\n\n\n<p>5\uff0e&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;\u4ed6\u4eec\u7684\u5957\u8def\u6709\uff1a\u7ec3\u5934 \u53cc\u968f\u3001\u6253\u89d2\u3001\u4f0f\u864e\u3001\u56db\u5927\u6bb5\u3001\u98de\u51e4\u4e0b\u7530\u3001\u9752\u9f99\u7ffb\u624b\u3001\u4e8c\u5341\u516b\u5bbf\u3001\u6d1e\u5bbe\u9189\u9152\u3001\u5f20\u7ffc\u5fb7\u64c2\u9f13\u7b49\uff0c\u8fd8\u4f20\u6709\u59d1\u5a18\u68cd\u6cd5\u548c\u5d14\u8bf8\u7f18\u5f04\u72ee\u6cd5\u3002\u636e\u8bf4\u8fd8\u6709\u201c\u9f13\u6c34\u8fb9\u201d\u518d\u8bf4\u4e09\u4ee3\u524d\u5931\u4f20\u4e86\uff08\u522b\u95e8\u6d3e\u66fe\u53bb\u8fc7\u701b\u6d32\u5b66\u62f3\u7684\u8001\u62f3\u5e08\u6240\u8bf4\uff09\u3002\u4ece\u701b\u6d32\u7684\u5386\u53f2\u4e0a\u63a8\u7b97\uff0c\u4f55\u9633\u662f\u5728150\u5e74\u524d\u540e\u5230\u701b\u6d32\u5e76\u5728\u701b\u6d32\u5a36\u59bb\u751f\u5b50\uff081850\u5e74\u524d\u540e\uff09\u6b63\u4e0e\u4e94\u7956\u62f3\u9e64\u9633\u62f3\u7956\u5e08\u8521\u7389\u660e\uff081853-1910\uff09\u51fa\u751f\u540e\u7684\u65f6\u671f\u76f8\u7b26\u5408\uff0c\u8fd9\u6837\u8521\u7389\u660e\u548c\u4f55\u9633\u5b66\u4e60\u7684\u53ef\u80fd\u6027\u662f\u5b58\u5728\u7684\u3002\u518d\u770b\u701b\u6d32\u4f20\u627f\u7684\u62f3\u6cd5\u5f62\u4f3c\u7f57\u6c49\u5957\u8def\u540d\u79f0\u53cc\u968f\u3001\u6253\u89d2\u3001\u9f13\u6c34\u8fb9\uff08\u9f13\u63a8\u8fb9\uff09\uff0c\u53a6\u95e8\u65b0\u57b5\u4e94\u7956\u62f3\u8001\u62f3\u8c31\u91cc\u4e5f\u6709\u4e09\u5957\u62f3\u800c\u4e14\u62f3\u6cd5\u51fa\u5904\u5747\u6807\u660e\u4e3a\u7f57\u6c49\u3002<\/p>\n\n\n\n<p>\u4e34\u522b\u4e4b\u524d\u6211\u95ee\u701b\u6d32\u8001\u5e08\u5085\uff0c\u77e5\u9053\u4f55\u9633\u5e08\u539f\u7c4d\u4f55\u5904\uff1f\u4ed6\u8bf4\u53ea\u77e5\u9053\u6765\u81ea\u6c38\u5b9a\uff0c\u5728\u701b\u6d32\u5f00\u9152\u5e97\u5a36\u59bb\u751f\u5b50\uff0c\u540e\u6765\u513f\u5b50\u6b7b\u4e86\u8fd8\u6709\u4e24\u4e2a\u5973\u513f\uff0c\u542c\u8bf4\u4ed6\u7684\u5916\u66fe\u5b59\u6d3b\u4e86\u4e5d\u5341\u591a\u5c81\uff0c\u524d\u51e0\u5e74\u624d\u8fc7\u4e16.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u6e05\u4e7e\u9686\u5e74\u95f4\uff0c\u6709\u4e00\u6c38\u5b9a\u4eba\u6c0f\u4f55\u9633\uff0c\u5230\u5357\u95e8\u6d0b\u8001\u6d32\u5f00\u9152\u5e97\uff0c\u5e76\u5728\u6b64\u4f20\u6388\u5c11\u6797\u4e94\u7956\u62f3\u53ca\u5357\u5c11\u6797\u5d14\u6b8a\u7f18\u7956\u5e08\u7684\u821e\u72ee\u6cd5\uff0c\u5802\u53f7\u201c\u4f55\u9633\u5802\u201d\u3002\u6d0b\u8001\u6d32\u5730\u5904\u4e5d\u9f99\u6c5f\u8fb9\uff0c\u56e0\u6b64\u53c8\u79f0\u201c\u9f99\u6eaa\u701b\u6d32\u56fd\u672f\u793e\u201d\u3002\u6d0b\u8001\u6d32\u5bb6\u5bb6\u6237\u6237\u90fd\u6709\u7ec3\u4e24\u
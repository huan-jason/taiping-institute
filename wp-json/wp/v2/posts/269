{"id":269,"date":"2021-08-05T21:55:00","date_gmt":"2021-08-05T21:55:00","guid":{"rendered":"http:\/\/taipinginstitute.com\/?p=269"},"modified":"2022-02-22T20:24:45","modified_gmt":"2022-02-22T20:24:45","slug":"%e9%80%9a%e8%83%8c%e6%8b%b3%e4%bc%b8%e8%82%a9%e6%b3%95%e7%9a%84%e5%81%a5%e8%ba%ab%e4%b8%8e%e6%8a%80%e5%87%bb%e4%bd%9c%e7%94%a8","status":"publish","type":"post","link":"http:\/\/taipinginstitute.com\/2021\/08\/05\/%e9%80%9a%e8%83%8c%e6%8b%b3%e4%bc%b8%e8%82%a9%e6%b3%95%e7%9a%84%e5%81%a5%e8%ba%ab%e4%b8%8e%e6%8a%80%e5%87%bb%e4%bd%9c%e7%94%a8\/","title":{"rendered":"\u901a\u80cc\u62f3\u4f38\u80a9\u6cd5\u7684\u5065\u8eab\u4e0e\u6280\u51fb\u4f5c\u7528"},"content":{"rendered":"\n<p>\u4e94\u884c\u901a\u80cc\u95e8\u6d41\u4f20\u4e00\u53e5\u8bdd\uff1a\u4f38\u80a9\u662f\u901a\u80cc\u62f3\u4e4b\u6bcd\u3002\u53c8\u8bf4\uff0c\u80a9\u901a\u5219\u4e00\u901a\u767e\u901a\u3002\u7531\u6b64\u53ef\u89c1\u4f38\u80a9\u64cd\u6cd5\u5728\u4e94\u884c\u901a\u80cc\u62f3\u4e2d\u7684\u91cd\u8981\u6027\u3002\u4f38\u80a9\u5355\u64cd\u662f\u4e94\u884c\u901a\u80cc\u62f3\u5165\u95e8\u4e4b\u540e\u7684\u5fc5\u4fee\u4e4b\u8bfe\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u62f3\u8c31\u4e91\uff1a&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u5148\u4eba\u6d41\u4f20\u6df7\u5143\u6869\uff0c\u9634\u9633\u5965\u5999\u67d4\u514b\u521a\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u8fd0\u7528\u4f38\u8212\u80fd\u751f\u529b\uff0c\u5947\u51fa\u5de7\u5165\u7cbe\u5947\u53d8\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u6df7\u5143\u4e00\u4f53\u50cf\u592a\u6781\uff0c\u4f38\u80a9\u6296\u8155\u5999\u65e0\u7a77\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u64cd\u6cd5\u5386\u6765\u88ab\u4e60\u901a\u80cc\u62f3\u8005\u8ba4\u4e3a\u662f\u96be\u5ea6\u5927\u3001\u52b2\u529b\u6700\u4e0d\u6613\u638c\u63e1\u7684\u5355\u64cd\u52a8\u4f5c\uff0c\u53ea\u6709\u638c\u63e1\u4e86\u4f38\u80a9\u6cd5\uff0c\u624d\u80fd\u6dcb\u6f13\u5c3d\u81f4\u5730\u53d1\u6325\u51fa\u97ad\u52b2\uff0c\u609f\u51fa\u901a\u80cc\u62f3\u4e4b\u7cbe\u9ad3\u3002\u4e94\u884c\u901a\u80cc\u62f3\u2014\u2014\u4f38\u80a9\u6cd5\u72b9\u5982\u918d\u9190\u704c\u9876\uff0c\u53ef\u6253\u901a\u4efb\u3001\u7763\u4e8c\u8109\u3002\u4efb\u8109\u901a\uff0c\u5219\u6c14\u8840\u901a\uff1b\u7763\u8109\u901a\uff0c\u5219\u767e\u8109\u901a\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u64cd\u6cd5\u9634\u51fa\u9633\u5165\uff0c\u5faa\u73af\u8fd0\u52a8\uff0c\u5177\u6709\u66f2\u4e2d\u6c42\u76f4\u3001\u6025\u4f3c\u8fc5\u96f7\u3001\u51b7\u4f3c\u8131\u9c7c\u7684\u7279\u70b9\uff0c\u52b2\u529b\u4e0a\u8981\u6c42\u4e00\u4e2a\u201c\u6574\u201d\u5b57\uff0c\u5373\u6574\u4f53\u53d1\u529b\u2014\u2014\u6296\u70b8\u6309\u62d3\u3002\u80fd\u591f\u8fd0\u7528\u5185\u6c14\u53d1\u52b2\u662f\u4f38\u80a9\u64cd\u6cd5\u7684\u4e00\u4e2a\u975e\u5e38\u91cd\u8981\u73af\u8282\u3002\u4e94\u884c\u901a\u80cc\u8981\u6c42\u4ee5\u610f\u50ac\u6c14\uff0c\u4ee5\u6c14\u50ac\u529b\uff0c\u6c14\u529b\u5408\u4e00\u8d2f\u4e8e\u638c\u3001\u6307\uff08\u97ad\u68a2\uff09\uff0c\u6539\u80f8\u5f0f\u547c\u5438\u4e3a\u8179\u5f0f\u547c\u5438\uff0c\u6539\u6d45\u547c\u5438\u4e3a\u6df1\u547c\u5438\uff0c\u6700\u540e\u7ec3\u6210\u81ea\u53d1\u7684\u4e39\u7530\u547c\u5438\uff0c\u4ece\u800c\u8fbe\u5230\u8212\u7b4b\u6d3b\u8840\u7684\u529f\u6548\u3002\u8840\u65fa\u5219\u6c14\u8db3\uff0c\u6c14\u8db3\u5219\u529b\u58ee\u3002\u5185\u6c14\u4e0e\u4f38\u80a9\u64cd\u6cd5\u6709\u7740\u5bc6\u5207\u7684\u5173\u7cfb\u2014\u2014\u6c14\u968f\u5f62\u52a8\uff0c\u6c14\u4e3a\u5f62\u7528\u3002\u521a\u5f00\u59cb\u953b\u70bc\u65f6\uff0c\u8981\u4fdd\u6301\u6b63\u786e\u7684\u59ff\u52bf\uff0c\u5373\u4e09\u6298\u3001\u4e5d\u6263\u3001\u4e94\u62a4\u3001\u516b\u65ad\u3002\u8981\u6c42\u5934\u9886\u9876\u52b2\uff0c\u7a7a\u80f8\u7d27\u80cc\uff0c\u584c\u8170\u677e\u80ef\uff0c\u6c89\u80a9\u5760\u8098\uff0c\u5e73\u89c6\u524d\u65b9\uff1b\u540c\u65f6\u7cbe\u795e\u96c6\u4e2d\uff0c\u4e24\u817f\u5f2f\u66f2\uff08\u9ad8\u4f4e\u90fd\u53ef\uff09\uff0c\u5c3d\u91cf\u964d\u4f4e\u8eab\u4f53\u91cd\u5fc3\uff0c\u4f7f\u4e0b\u76d8\u7a33\u56fa\uff0c\u8fd9\u6837\u80fd\u591f\u6709\u5229\u4e8e\u8fd0\u6c14\u53d1\u52b2\uff08\u56fe1\u30012\uff09\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u6280\u51fb\u4e4b\u9645\uff0c\u6c14\u6c89\u8005\u80dc\uff0c\u6c14\u6d6e\u8005\u8d25\u3002\u8c03\u606f\u5185\u529f\u662f\u5728\u4f38\u80a9\u624b\u6cd5\u3001\u6b65\u6cd5\u3001\u547c\u5438\u4e2d\u540c\u6b65\u8fdb\u884c\u3002\u9633\u638c\u65f6\u5438\u6c14\u4e3a\u4f73\uff0c\u9634\u638c\u65f6\u5410\u6c14\u4e3a\u5999\uff0c\u7ec3\u4e60\u65f6\u5fc5\u987b\u4e0e\u9053\u5bb6\u7684\u5bfc\u5f15\u5410\u7eb3\u672f\u76f8\u7ed3\u5408\uff0c\u8981\u53e3\u95ed\u3001\u9f7f\u53e9\u3001\u820c\u9876\u4e0a\u816d\u3001\u7528\u9f3b\u5438\u6c14\uff0c\u4e5f\u53ef\u9f3b\u5438\u3001\u53e3\u547c\u3002\u4e24\u80f3\u81c2\u5728\u4f38\u62c9\u8fd0\u52a8\u65f6\u7528\u610f\u4e0d\u7528\u529b\uff0c\u4e00\u5b9a\u8981\u4fdd\u6301\u7a7a\u80f8\u59ff\u52bf\uff0c\u8fd9\u6837\u624d\u80fd\u6c14\u6c89\u4e39\u7530\uff0c\u5426\u5219\uff0c\u5bfc\u81f4\u80f8\u6ee1\u6c14\u6025\uff0c\u611f\u5230\u4e4f\u529b\u3002\u8fd8\u5e94\u6ce8\u610f\u5927\u62c7\u6307\u987b\u7d27\u6263\u52b3\u5bab\u7a74\uff0c\u540c\u65f6\u6536\u7f29\u8c37\u9053\uff08\u63d0\u809b\u95e8\uff09\uff0c\u53ea\u6709\u8fd9\u6837\u80fd\u5c01\u95ed\u5185\u6c14\uff0c\u4f7f\u6c14\u901a\u8fc7\u4efb\u8109\u3001\u4f1a\u9634\u8fbe\u5230\u7763\u8109\uff0c\u5e76\u4e0a\u5347\u5230\u767e\u4f1a\uff0c\u7136\u540e\u518d\u964d\u5230\u4eba\u4e2d\u3001\u5151\u7aef\u3001\u627f\u6d46\u3001\u4efb\u8109\uff0c\u56de\u5230\u4e39\u7530\u7a74\uff0c\u8fd9\u6837\u5468\u800c\u590d\u59cb\uff0c\u4e45\u7ec3\u4e4b\uff0c\u80fd\u4ea7\u751f\u5185\u52b2\uff0c\u5373\u4eba\u4eec\u5e38\u8bf4\u7684\u771f\u6c14\u3002\u84c4\u6c14\u5219\u6c14\u805a\u4e8e\u4e00\u5904\uff0c\u51fb\u4e4b\u4e0d\u80fd\u4f24\uff0c\u63a8\u4e4b\u4e0d\u80fd\u53bb\uff0c\u6349\u4e4b\u5373\u6765\uff0c\u653e\u4e4b\u5219\u6563\uff0c\u82e5\u79bb\u82e5\u5408\uff0c\u80fd\u805a\u80fd\u5206\uff0c\u800c\u8fd0\u884c\u4e8e\u7ecf\u7edc\u4e4b\u95f4\uff0c\u53ef\u4f7f\u5185\u3001\u5916\u52b2\u529b\u7ec3\u4e60\u8fbe\u5230\u5916\u80fd\u5f3a\u5065\u7b4b\u9aa8\uff0c\u5185\u80fd\u575a\u56fa\u5185\u810f\u7684\u6700\u4f73\u529f\u6548\uff0c\u4f7f\u8eab\u4f53\u5185\u52b2\u529f\u592b\u4e0e\u5916\u52b2\u529f\u592b\u66f4\u52a0\u534f\u8c03\u7edf\u4e00\u3002\u4f38\u80a9\u64cd\u6cd5\u2014\u2014\u4f38\u7f29\u5f80\u8fd4\u6f14\u7ec3\u65f6\uff0c\u53ef\u611f\u89c9\u5230\u6c14\u8840\u7545\u901a\uff0c\u5934\u8111\u6e05\u65b0\uff0c\u601d\u7ef4\u654f\u6377\uff0c\u7cbe\u529b\u5145\u6c9b\uff0c\u6c14\u529b\u500d\u589e\u3002\u521d\u7ec3\u4f38\u80a9\u5355\u64cd\u65f6\u5e94\u505a\u5230\u547c\u5438\u4e0d\u53ef\u6025\u4fc3\uff0c\u8981\u4fdd\u6301\u5747\u5300\u3001\u7ec6\u957f\uff0c\u51fa\u5165\u7ef5\u7ef5\uff0c\u800c\u540e\u7f13\u7f13\u589e\u52a0\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u6296\u8155\u4e4b\u6b4c\u8bc0\uff1a&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u6296\u8155\u901a\u80cc\u7cbe\uff0c\u795e\u51fa\u9b3c\u5165\u5999\u65e0\u7a77\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u82e5\u80fd\u609f\u89c9\u5176\u4e2d\u7406\uff0c\u5316\u5f31\u4e3a\u5f3a\u5c55\u5176\u80fd\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u97ad\u52b2\u5728\u901a\u80cc\u62f3\u6cd5\u4e2d\u662f\u6781\u5176\u91cd\u8981\u7684\u529f\u592b\uff0c\u800c\u8981\u60f3\u6253\u51fa\u97ad\u52b2\uff0c\u5219\u987b\u81c2\u957f\u51fb\u8fdc\u3002\u8981\u60f3\u81c2\u957f\uff0c\u5c31\u5fc5\u987b\u4e60\u7ec3\u4f38\u80a9\u4e4b\u6cd5\u3002\u4f38\u80a9\u4e0d\u662f\u5355\u7eaf\u7684\u4f38\u76f4\uff0c\u800c\u662f\u542b\u6709\u62bb\u62c9\u3001\u7275\u5f15\u3001\u63a2\u94bb\u4e4b\u610f\uff0c\u76ee\u7684\u662f\u201c\u62bb\u7b4b\u62d4\u9aa8\u201d\uff0c\u901a\u8fc7\u5bf9\u7b4b\u3001\u808c\u8089\u53ca\u5173\u8282\u7684\u957f\u671f\u62bb\u62c9\u3001\u7275\u5f15\uff0c\u4f7f\u4e24\u81c2\u814b\u4e0b\u5927\u7b4b\u62c9\u957f\uff08\u4f38\u80a9\u65f6\u5173\u8282\u53ef\u53d1\u51fa\u8f7b\u5fae\u58f0\u54cd\uff09\uff0c\u653e\u957f\u97ad\u52b2\uff0c\u6253\u51fa\u76ae\u97ad\u58f0\u3002\u4f38\u80a9\u5355\u64cd\u6cd5\u638c\u63e1\u7684\u5982\u4f55\uff0c\u5c06\u76f4\u63a5\u5f71\u54cd\u5230\u97ad\u52b2\u7684\u53d8\u5316\u548c\u624b\u6cd5\u7684\u8fd0\u7528\u3002\u4f38\u80a9\u7eaf\u7cb9\u662f\u81ea\u7136\u5730\u4f38\uff0c\u9010\u6e10\u6316\u6398\u4eba\u4f53\u6f5c\u80fd\uff0c\u7ec3\u4e60\u65f6\u7edd\u4e0d\u53ef\u7528\u731b\u529b\u3001\u62d9\u529b\u3001\u50f5\u529b\uff0c\u66f4\u4e0d\u80fd\u8ffd\u6c42\u6240\u8c13\u201c\u795e\u529f\u201d\u3001\u201c\u795e\u638c\u201d\uff0c\u800c\u8d85\u51fa\u4eba\u4f53\u627f\u53d7\u8303\u56f4\uff0c\u4f24\u5bb3\u8eab\u4f53\uff0c\u635f\u5bb3\u5065\u5eb7\u3002\u7ec3\u4e60\u4f38\u80a9\u65f6\uff0c\u819d\u3001\u80ef\u3001\u80a9\u3001\u8098\u3001\u8155\u7b49\u4e3b\u8981\u5173\u8282\u5e94\u987a\u5176\u81ea\u7136\uff0c\u4ee5\u4fdd\u8bc1\u5468\u8eab\u6c14\u8109\u3001\u8840\u8109\u7545\u901a\uff0c\u800c\u4e14\u8981\u7ec3\u51fa\u8212\u670d\u3001\u81ea\u7136\u3001\u8f7b\u677e\u3001\u987a\u7545\u7684\u611f\u89c9\uff08\u5c31\u50cf\u65e9\u6668\u8d77\u5e8a\u540e\u4f38\u61d2\u8170\u4e00\u6837\u8212\u670d\uff09\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u6c89\u80a9\u5760\u8098\u5728\u4f38\u80a9\u8fd0\u52a8\u4e2d\u8d77\u7740\u975e\u5e38\u91cd\u8981\u7684\u4f5c\u7528\u3002\u6c89\u80a9\u9996\u5148\u987b\u677e\u80a9\uff0c\u5207\u5fcc\u50f5\u786c\uff0c\u80a9\u5173\u8282\u50f5\u5219\u529b\u81f3\u80a9\u800c\u6b62\uff0c\u65e0\u6cd5\u8fbe\u5230\u624b\u6307\uff08\u97ad\u68a2\uff09\u3002\u6c89\u80a9\u5760\u8098\u6709\u5229\u4e8e\u81c2\u90e8\u7684\u62bb\u62c9\uff0c\u7279\u522b\u662f\u8098\u5c16\u91cc\u88f9\u800c\u6709\u4e0b\u5760\u4e4b\u52bf\uff0c\u4f7f\u8098\u7a9d\u53cd\u590d\u6536\u7f29\u3001\u653e\u677e\uff0c\u808c\u529b\u4f5c\u7528\u4e8e\u8098\u5c16\uff08\u8098\u5173\u8282\u6709\u660e\u663e\u7684\u611f\u89c9\uff09\u65f6\uff0c\u4e5f\u5c31\u5bf9\u8be5\u8098\u5173\u8282\u7684\u9644\u7740\u70b9\u4ea7\u751f\u4e86\u7275\u62c9\u3001\u6469\u64e6\u3001\u523a\u6fc0\uff0c\u80fd\u591f\u589e\u52a0\u8840\u6db2\u5faa\u73af\u3001\u4fc3\u8fdb\u751f\u957f\u6fc0\u7d20\u7684\u5206\u6ccc\u3002\u7531\u4e8e\u4f38\u80a9\u8fd0\u52a8\u662f\u5728\u201c\u4e09\u6298\u4e5d\u6263\u201d\u6761\u4ef6\u7684\u7ea6\u675f\u4e0b\uff0c\u4f7f\u80a9\u3001\u8098\u3001\u624b\u4e09\u70b9\u5728\u4e2d\u7ebf\u6709\u89c4\u5219\u5730\u5f80\u8fd4\u62bb\u62c9\uff0c\u5728\u76f4\u4e2d\u6c42\u8212\u5c55\u3001\u62e7\u62bb\uff0c\u4f7f\u80f3\u81c2\u62d4\u957f\uff0c\u52b2\u529b\u8fbe\u638c\u3001\u6307\u68a2\u8282\uff0c\u624b\u5c31\u4f1a\u6709\u9ebb\u80c0\u611f\u3001\u70ed\u6d41\u611f\uff0c\u624b\u638c\u3001\u6307\u5c16\u5c31\u4f1a\u6c89\u5b9e\u6709\u529b\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u53e6\u5916\uff0c\u8170\u662f\u5168\u8eab\u4e3b\u5bb0\uff0c\u9634\u9633\u638c\u51fa\u624b\u6324\u6eda\uff0c\u56de\u624b\u634b\u5e26\uff0c\u521a\u67d4\u53d8\u5316\u81ea\u5982\uff0c\u4f46\u90fd\u987b\u5408\u819d\u5750\u80ef\uff0c\u4ee5\u8170\u4e3a\u8f74\u5de6\u53f3\u8f6c\u52a8\uff08\u56fe3\uff09\u3002\u987a\u80ef\u62e7\u8170\uff0c\u4e0d\u4f46\u662f\u5bf9\u8eab\u8eaf\u7684\u62bb\u62d4\uff0c\u800c\u4e14\u53ef\u4ee5\u7a33\u56fa\u4e0b\u76d8\uff0c\u5728\u9634\u9633\u6362\u52bf\u4e2d\u4f7f\u5168\u8eab\u4e4b\u52b2\u8d2f\u6ce8\u4e8e\u624b\u638c\u3001\u6307\u5c16\uff0c\u4ece\u800c\u52a0\u5927\u62bb\u7b4b\u62d4\u9aa8\u7684\u5e45\u5ea6\u3001\u5f3a\u5ea6\u53ca\u87ba\u65cb\u67d4\u5f39\u6027\u3002\u5148\u5e08\u845b\u592a\u7136\u5148\u751f\u8ba4\u4e3a\uff1a\u521a\u52b2\u662f\u4ece\u9aa8\u4e2d\u953b\u70bc\u51fa\u6765\u7684\uff0c\u67d4\u52b2\u662f\u4ece\u4f38\u80a9\uff08\u7b4b\uff09\u4e2d\u953b\u7ec3\u51fa\u6765\u7684\uff0c\u4e24\u52b2\u5408\u4e00\uff0c\u5c31\u53ef\u4ee5\u6253\u51fa\u901a\u80cc\u62f3\u653e\u957f\u51fb\u8fdc\u7684\u76ae\u97ad\u52b2\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u6709\u591a\u79cd\u7ec3\u6cd5\uff0c\u5305\u62ec\u4e0a\u4f38\u80a9\u3001\u4e2d\u4f38\u80a9\u3001\u4e0b\u4f38\u80a9\u3001\u53cd\u4f38\u80a9\u7b49\u3002\u521d\u5b66\u8005\u5927\u591a\u4ee5\u7ec3\u4e2d\u4f38\u80a9\u4e3a\u4e3b\uff08\u6613\u5b66\uff09\uff0c\u5176\u8981\u9886\u662f\u201c\u51fa\u624b\u4e0d\u79bb\u5fc3\uff0c\u56de\u624b\u4e0d\u79bb\u808b\u201d\u3002\u5177\u4f53\u52a8\u4f5c\u4e3a\uff1a\u81ea\u7136\u7ad9\u7acb\uff0c\u8eab\u4f53\u7f13\u7f13\u4e0b\u8e72\uff0c\u53f3\u811a\u5411\u524d\u8fc8\u51fa\u6210\u865a\u6b65\uff0c\u91cd\u5fc3\u524d\u4e09\u540e\u4e03\uff0c\u5de6\u638c\u4e3a\u9634\u638c\uff08\u638c\u5fc3\u671d\u4e0b\uff09\u6cbf\u4e2d\u7ebf\u5411\u524d\u7f13\u7f13\u4f38\u51fa\u81f3\u6700\u5927\u9650\u5ea6\u540e\uff0c\u53d8\u4e3a\u9633\u638c\uff08\u8f6c\u53d8\u65f6\u52b2\u529b\u8fbe\u638c\u8f6e\uff0c\u7528\u7f20\u4e1d\u52b2\uff09\uff0c\u968f\u4e4b\u56de\u62c9\uff0c\u52b2\u5982\u62c9\u8f66\uff0c\u4e0d\u53ef\u505c\u6ede\u3002\u5f85\u5de6\u638c\u6536\u81f3\u808b\u90e8\u65f6\uff0c\u53f3\u638c\u540c\u65f6\u5411\u524d\u7f13\u7f13\u4f38\u51fa\uff0c\u5982\u6b64\u53cd\u590d\u6f14\u7ec3\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u5f53\u53cc\u81c2\u5728\u6c89\u80a9\u5760\u8098\u4ea4\u66ff\u8fd0\u52a8\u65f6\uff0c\u624b\u81c2\u5982\u540c\u62c5\u7740\u4e00\u7897\u6eda\u70eb\u7684\u5f00\u6c34\uff0c\u9634\u9633\u638c\u4e00\u524d\u4e00\u540e\u5728\u4e2d\u7ebf\u5e73\u7a33\u53d8\u5316\uff0c\u4e24\u638c\u5728\u8ddd\u5fc3\u7a9d\u7ea67\u5bf8\uff08\u4e00\u638c\uff09\u65f6\uff0c\u9633\u638c\u62c9\u52b2\u4e0e\u9634\u638c\u63a8\u52b2\u91cd\u5408\uff0c\u6b64\u65f6\u7684\u52b2\u80fd\u84c4\u5168\u8eab\u4e4b\u52b2\u529b\uff0c\u5982\u63a8\u3001\u6413\u3001\u6469\u64e6\u7740\u7269\u4f53\u4e00\u6837\uff0c\u72b9\u5982\u9f7f\u8f6e\u76f8\u4e92\u54ac\u5408\uff0c\u4e25\u5bc6\u5747\u5300\uff0c\u76f4\u529b\u5411\u524d\uff0c\u52b2\u4f3c\u6cc9\u6d8c\uff0c\u53c8\u5982\u6d6a\u91cc\u884c\u821f\u8fde\u7ef5\u4e0d\u65ad\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u201c\u7c98\u8d34\u8fde\u968f\u201d\u662f\u4f38\u80a9\u64cd\u6cd5\u5b9e\u6218\u52b2\u6cd5\uff0c\u5b83\u53d1\u52b2\u5982\u592a\u6781\u62f3\uff0c\u4f46\u4e0d\u901a\u8fc7\u5f27\u7ebf\u5316\u89e3\u654c\u52b2\uff0c\u4e3b\u5f20\u76f4\u7ebf\u53d1\u529b\uff0c\u5728\u5b88\u4e2d\u6253\u4e2d\u4e2d\u53d8\u5316\uff0c\u9634\u638c\u4e3a\u5f00\u5373\u653b\uff0c\u9633\u638c\u4e3a\u5408\u5373\u5b88\uff0c\u5e76\u5728\u4e00\u51fa\u4e00\u5165\u4e2d\u53d8\u5316\u51fa\u5f15\u52b2\u3001\u62ff\u52b2\u3001\u584c\u6309\u52b2\u3001\u6324\u94bb\u52b2\u3001\u6296\u8155\u52b2\u3001\u7f20\u4e1d\u52b2\u7b49\uff0c\u5185\u3001\u5916\u52b2\u529b\u5408\u4e00\uff08\u72b9\u5982\u6728\u5320\u7535\u94bb\u4e4b\u94bb\u4e4b\u5165\u6728\uff09\uff0c\u6324\u6eda\u634b\u5e26\u800c\u51fa\uff0c\u5176\u52b2\u52c7\u731b\u5947\u5999\uff0c\u77ac\u95f4\u53ef\u5316\u89e3\u654c\u4e4b\u52b2\u529b\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u51fa\u624b\u6709\u52bf\uff1a\u5728\u5b88\u4f4f\u4e2d\u7ebf\u65f6\uff0c\u987a\u654c\u52b2\u8d34\u4f4f\uff0c\u9aa4\u7136\u53d1\u529b\uff0c\u5148\u7a81\u7834\u654c\u4e4b\u4e2d\u7ebf\uff0c\u540e\u51fb\u654c\u4e4b\u8981\u5bb3\uff0c\u52bf\u867d\u82e5\u873b\u8713\u70b9\u6c34\uff0c\u800c\u529b\u53ef\u900f\u654c\u4e4b\u810f\u8151\uff0c\u51fa\u624b\u5982\u540c\u79bb\u5f26\u4e4b\u7bad\u9510\u5165\u5176\u8eab\u5185\uff0c\u4e43\u5f97\u4f38\u80a9\u2014\u2014\u653e\u957f\u51fb\u8fdc\u4e4b\u771f\u8c1b\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u4f38\u80a9\u56de\u624b\u6709\u6cd5\uff1a\u9634\u638c\u51fa\u624b\u51fb\u654c\u65f6\uff0c\u9633\u638c\u56de\u624b\u4e0d\u8d70\u7a7a\uff0c\u8d34\u7c98\u8fde\u968f\u3001\u7d27\u7d27\u8ddf\u4e0a\u4e09\u624b\uff08\u5f15\u624b\u3001\u7ba1\u624b\u3001\u6253\u624b\uff09\uff0c\u4ee4\u654c\u906d\u51fb\u6253\u540e\u65e0\u6cd5\u9632\u624b\uff0c\u5e76\u987a\u52bf\u634b\u5e26\u52fe\u62ff\u53cd\u64d2\u654c\u624b\uff0c\u5373\u53d8\u4e3a\u987a\u624b\u7275\u7f8a\u4e4b\u7528\uff08\u56fe4\u30015\uff09\u3002\u9634\u9633\u4e24\u638c\u52b2\u529b\u76f8\u901a\uff0c\u76f8\u4f34\u4e3a\u4f0d\uff0c\u53d8\u5316\u65e0\u7a77\u3002\u540c\u65f6\u8fce\u5176\u673a\u800c\u7834\u5176\u6cd5\uff0c\u4ee5\u8fbe\u5230\u4ee5\u5c0f\u80dc\u5927\u3001\u4ee5\u5f31\u80dc\u5f3a\u3001\u56db\u4e24\u62e8\u5343\u65a4\u7684\u6280\u51fb\u6700\u9ad8\u5883\u754c\u3002&nbsp;<\/p>\n\n\n\n<p>\u3000\u3000\u5728\u6b65\u6cd5\u4e0a\uff0c\u4f38\u80a9\u5355\u64cd\u6700\u8bb2\u7a76\u201c\u5bd2\u9e21\u817f\u3001\u9e64\u5f62\u6b65\u201d\uff08\u56fe6\uff09\uff0c\u8fd0\u52a8\u53d8\u5316\u65f6\uff0c\u5176\u52b2\u529b\u6839\u4e8e\u811a\u3001\u53d1\u4e8e\u817f\u800c\u5f62\u4e8e\u6307\u3002\u56e0\u6b64\uff0c\u68a2\u52a8\u8db3\u5148\u52a8\uff0c\u8981\u6c42\u811a\u8dbe\u7d27\u7d27\u6263\u4f4f\u5730\u9762\uff0c\u91cd\u5fc3\u7a33\u5b9a\uff0c\u624b\u638c\u4e0e\u817f\u6cd5\u914d\u5408\u9ed8\u5951\u2014\u2014\u52a8\u9759\u865a\u5b9e\u3001\u521a\u67d4\u7f13\u6025\u3002\u5982\u6b64\u5728\u6280\u51fb\u8fd0\u52a8\u65f6\uff0c\u53ef\u8fdb\u9000\u5c01\u95ed\uff0c\u53d8\u5316\u5de7\u5999\uff0c\u6709\u864e\u8e72\u733f\u8dc3\u3001\u9e64\u843d\u9e70\u626c\u4e4b\u52bf\u3002\u53e6\u5916\uff0c\u4e60\u7ec3\u4f38\u80a9\u5355\u64cd\uff0c\u6bcf\u6b21\u987b\u7ec330\u5206\u949f\u4ee5\u4e0a\uff08\u7ec3\u529f\u5730\u70b9\u6700\u597d\u9009\u62e9\u5728\u6811\u6797\u4e1b\u4e2d\u6216\u5c0f\u6cb3\u8fb9\uff0c\u4ee5\u6e05\u6668\u592a\u9633\u5347\u8d77\u65f6\u6700\u4f73\uff09\uff0c\u53ef\u51cf\u5c11\u8102\u80aa\uff0c\u589e\u52a0\u808c\u8089\uff0c\u5c24\u5176\u5bf9\u817f\u90e8\u3001\u80a9\u90e8\u3001\u9888\u690e\u75be\u75c5\u4ee5\u53ca\u5931\u7720\u3001\u8bb0\u5fc6\u529b\u51cf\u9000\u3001\u4e9a\u5065\u5eb7\u72b6\u6001\u7b49\u6709\u9632\u6cbb\u7684\u529f\u6548\uff0c\u5177\u6709\u72ec\u7279\u7684\u5065\u8eab\u3001\u795b\u75c5\u4f5c\u7528\u3002\u8fd9\u9879\u8fd0\u52a8\u5bf9\u4e0b\u80a2\u957f\u9aa8\uff08\u5982\u80a1\u9aa8\u3001\u8153\u9aa8\u3001\u80eb\u9aa8\uff09\u65bd\u52a0\u7684\u538b\u529b\uff0c\u662f\u4fc3\u5176\u751f\u957f\u7684\u4e00\u79cd\u826f\u597d\u7684\u673a\u68b0\u523a\u6fc0\uff0c\u4ece\u800c\u5bf9\u62bb\u7b4b\u62d4\u9aa8\u3001\u52a0\u5927\u97ad\u52b2\u653e\u957f\u51fb\u8fdc\u8d77\u91cd\u5927\u4f5c\u7528\u3002\u4f38\u80a9\u8fd0\u52a8\u4e0d\u4ec5\u53ef\u4f7f\u81c2\u957f\u51fb\u8fdc\uff0c\u8fd8\u53ef\u4fc3\u8fdb\u4eba\u7684\u5f62\u6001\u7684\u5747\u8861\u53d1\u5c55\uff0c\u4f7f\u5f62\u4f53\u66f4\u4fee\u957f\u3001\u82d7\u6761\uff0c\u5e76\u4e14\u5bf9\u63d0\u9ad8\u4eba\u7684\u601d\u7ef4\u80fd\u529b\u3001\u667a\u529b\u53d1\u5c55\u6709\u5f88\u597d\u7684\u4fc3\u8fdb\u4f5c\u7528\u3002&nbsp;<\/p>\n\n\n\n<p>\
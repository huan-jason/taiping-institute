{"id":249,"date":"2021-08-05T21:44:11","date_gmt":"2021-08-05T21:44:11","guid":{"rendered":"http:\/\/taipinginstitute.com\/?p=249"},"modified":"2022-02-21T20:26:03","modified_gmt":"2022-02-21T20:26:03","slug":"%e5%86%99%e7%9c%9f%e7%a7%98%e5%ae%97%e6%8b%b3","status":"publish","type":"post","link":"http:\/\/taipinginstitute.com\/2021\/08\/05\/%e5%86%99%e7%9c%9f%e7%a7%98%e5%ae%97%e6%8b%b3\/","title":{"rendered":"\u5199\u771f\u79d8\u5b97\u62f3"},"content":{"rendered":"\n<p>\u71d5\u9752\u62f3\u548c\u79d8\u5b97\u62f3\u5176\u5b9e\u662f\u4e00\u5bb6. &nbsp;\u8bf4\u8d77\u71d5\u9752\u62f3,\u5f88\u591a\u4eba\u4f1a\u89c9\u5f97\u964c\u751f,\u4f46\u63d0\u53ca\u79d8\u5b97\u62f3,\u5927\u5bb6\u8033\u719f\u80fd\u8be6,\u4f46\u5b9e\u9645\u4e0a\u71d5\u9752\u62f3\u79d8\u5b97\u62f3\u4e0d\u5206\u5bb6\u3002\u201d\u5f20\u798f\u796f\u8bf4,\u71d5\u9752\u62f3\u76f8\u4f20\u7531\u5cb3\u98de\u7684\u5e08\u7236\u5468\u4f97\u6240\u521b,\u5468\u4f97\u7684\u53e6\u4e00\u540d\u5f1f\u5b50\u5362\u4fca\u4e49\u5c06\u6b64\u62f3\u4f20\u7ed9\u4e86\u6881\u5c71\u597d\u6c49\u71d5\u9752,\u540e\u4eba\u4ee5\u5176\u540d\u79f0\u4e3a\u201c\u71d5\u9752\u62f3\u201d\u3002&nbsp;\u201c\u6709\u53f2\u6599\u8bb0\u8f7d\u7684\u71d5\u9752\u62f3\u6700\u65e9\u53ef\u8ffd\u6eaf\u5230\u4e7e\u9686\u5e74\u95f4\u7684\u6b66\u672f\u5927\u5e08\u5b59\u901a,\u4eba\u79f0\u2018\u4e07\u80fd\u624b\u2019,\u5584\u4e8e\u6b64\u62f3\u3002\u4ed6\u5c06\u6b64\u62f3\u4f20\u7ed9\u5929\u6d25\u9759\u6d77\u5c0f\u6cb3\u5357\u6751\u970d\u5143\u7532\u7684\u66fe\u7956\u4ee5\u53ca\u5c71\u4e1c\u3001\u6ca7\u5dde\u7b49\u5730\u3002\u201d\u5f20\u798f\u796f\u7684\u5f92\u5f1f\u674e\u658c\u8bf4,\u73b0\u5728\u5f88\u5c11\u6709\u4eba\u628a\u71d5\u9752\u62f3\u548c\u970d\u5143\u7532\u8054\u7cfb\u5728\u4e00\u8d77,\u970d\u5143\u7532\u66fe\u7528\u6b64\u62f3\u6253\u8d25\u4e86\u4fc4\u56fd\u5927\u529b\u58eb,\u4e3a\u56fd\u4e89\u5149,\u970d\u5143\u7532\u7684\u79d8\u5b97\u62f3\u548c\u71d5\u9752\u62f3\u662f\u540c\u4e00\u4e2a\u62f3\u79cd,\u53ea\u662f\u540d\u5b57\u4e0d\u4e00\u6837\u800c\u5df2\u3002\u3000\u201c\u71d5\u9752\u62f3\u5b9e\u6218\u6027\u5f88\u5f3a,\u5728\u8fc7\u53bb\u5c5e\u4e8e\u79d8\u4f20\u529f\u592b,\u4f20\u5185\u4e0d\u4f20\u5916\u7684\u95e8\u89c4\u5e08\u8bad\u4f7f\u5176\u5145\u6ee1\u4e86\u795e\u5947\u8272\u5f69\u3002\u201d\u5f20\u798f\u796f\u8bf4,\u8fd9\u4e2a\u62f3\u79cd\u5728\u5c71\u4e1c\u6d4e\u5357\u6709\u7740\u81ea\u5df1\u7684\u5386\u53f2\u4f20\u6f14,\u6c11\u56fd\u521d\u671f\u6b66\u672f\u5bb6\u8d75\u57f9\u8d77\u5148\u751f\u5c31\u662f\u7cbe\u901a\u71d5\u9752\u62f3\u7684\u9ad8\u624b\u4e4b\u4e00\u3002<\/p>\n\n\n\n<hr class=\"wp-block-separator\"\/>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u5199\u771f\u79d8\u5b97\u62f3-\u59dc\u5bb9\u6a35\u8457\">\u5199\u771f\u79d8\u5b97\u62f3&nbsp;\u59dc\u5bb9\u6a35\u8457<\/h1>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u79d8\u5b97\u827a\u4e4b\u6e90\u6d41\">\u79d8\u5b97\u827a\u4e4b\u6e90\u6d41<\/h1>\n\n\n\n<p>\u79d8\u5b97\u827a\u8005\uff0c\u5c11\u6797\u6d3e\u4e2d\u4e00\u652f\u4e4b\u603b\u540d\u79f0\u4e5f\u3002\u4ea6\u66f0\u79d8\u5b97\u95e8\uff0c\u79d8\u8e28\u95e8\uff0c\u730a\u7314\u95e8\uff0c\u7686\u4e00\u97f3\u4e4b\u8f6c\u4e5f\u3002\u5176\u4e2d\u5305\u62ec\u79d8\u5b97\u5927\u5200\uff0c\u5355\u5200\uff0c\u53cc\u5200\uff0c\u5355\u62d0\uff0c\u53cc\u62d0\uff0c\u68cd\u6cd5\uff0c\u68d2\u6cd5\uff0c\u79d8\u5b97\u7ec3\u624b\u62f3\uff0c\u79d8\u5b97\u8c79\u62f3\uff0c\u79d8\u5b97\u5927\u4e94\u864e\uff0c\u5c0f\u4e94\u864e\uff0c\u79d8\u5b97\u9760\uff0c\u516b\u6298\uff0c\u516b\u6253\uff0c\u5341\u516b\u94a9\uff0c\u5c0f\u8fdb\u62f3\uff0c\u5957\u73af\u6563\uff0c\u7ef5\u638c\u62f3\uff0c\u4e8c\u90ce\u68cd\uff0c\u4e09\u8def\u6761\uff0c\u516d\u8def\u6761\uff0c\u4ee5\u53ca\u5927\u67aa\u672f\u7b49\uff0c\u4e0d\u4e0b\u516d\u4e03\u5341\u79cd\u3002\u5179\u7f16\u4e3a\u79d8\u5b97\u67b6\uff0c\u7cfb\u65af\u672f\u521d\u6b65\u5fc5\u987b\u5b66\u4e60\u4e4b\u62f3\u67b6\uff0c\u6545\u4ea6\u540d\u79d8\u5b97\u6bcd\u62f3\u3002\u76d6\u975e\u6b64\u4e0d\u80fd\u8fbe\u8fdb\u9636\u4e4b\u76ee\u7684\uff0c\u800c\u6709\u8e90\u7b49\u4e4b\u5f0a\u3002\u65af\u672f\u521b\u81ea\u5c11\u6797\uff0c\u53d1\u660e\u4e8e\u5510\u4e4b\u672b\u53f6\u3002\u81f3\u5b8b\u4e4b\u4e2d\u53f6\u6709\u5bcc\u7fc1\u5362\u4fca\u4e49\u8005\uff0c\u5b66\u4e8e\u5c11\u6797\uff0c\u5f97\u65af\u672f\u4e4b\u5927\u6210\uff0c\u9068\u6e38\u5929\u4e0b\u3002\u867d\u7cfb\u5916\u5bb6\uff0c\u800c\u786e\u6709\u5929\u7136\u4e4b\u5185\u529f\u3002\u5f53\u65f6\u592a\u6781\u5c1a\u672a\u53d1\u660e\uff0c\u65af\u672f\u56fa\u8db3\u4ee5\u6267\u62f3\u672f\u754c\u4e4b\u725b\u8033\uff0c\u535a\u591a\u6570\u4e4b\u4fe1\u5f92\u8005\u4e5f\u3002\u81ea\u540e\u76f8\u6cbf\u9012\u5b17\uff0c\u6d41\u4f20\u5404\u5730\u3002\u60df\u65e0\u4e13\u4e66\u8003\u8bc1\uff0c\u589e\u6dfb\u6539\u51cf\uff0c\u4e0d\u65e0\u5931\u771f\u3002\u8fe8\u6e05\u5eb7\u7199\u672b\u5e74\uff0c\u6709\u9c81\u4eba\u540d\u5b59\u901a\u8005\uff0c\u5b66\u827a\u5c11\u6797\u3002\u827a\u6210\u4e91\u6e38\u5404\u7701\uff0c\u9690\u4e8e\u6ca7\u5dde\u4e61\u95f4\uff0c\u6388\u5f92\u4e3a\u4e1a\uff0c\u9042\u5bb6\u7109\u3002\u81f3\u9053\u5149\u95f4\u5c24\u5065\u5728\u3002\u800c\u6ca7\u5dde\u4e3a\u6700\u5927\u4e4b\u4e00\u652f\uff0c\u81f3\u4eca\u5168\u53bf\u76db\u884c\u4e4b\u79d8\u5b97\u6d3e\uff0c\u7686\u5b59\u4e4b\u5ae1\u7cfb\u4e5f\u3002\u665a\u5e74\u5c1d\u6e38\u4e1c\u4e09\u7701\uff0c\u590d\u6388\u5f92\u4e8e\u5929\u6d25\u536b\u5357\u6d3c\uff0c\u9759\u6d77\u4e4b\u4e61\u95f4\u3002\u95fb\u970d\u5143\u7532\u541b\u4e4b\u66fe\u7956\u7cfb\u5b59\u4e4b\u5f1f\u5b50\uff0c\u5176\u8a00\u786e\u5426\uff0c\u8be2\u4e4b\u970d\u6c0f\u4e0d\u96be\u8bc1\u660e\u3002\u76d6\u970d\u6c0f\u6240\u4f20\u4e4b\u5168\u90e8\u5200\u68cd\u62f3\u68d2\uff0c\u52a8\u4f5c\u540d\u79f0\uff0c\u7406\u6cd5\u529f\u7528\uff0c\u7686\u4e0e\u5b59\u6c0f\u6240\u4f20\u5b8c\u5168\u76f8\u540c\uff0c\u5176\u4e3a\u79d8\u5b97\u4e4b\u6b63\u5b97\u4e5f\u660e\u77e3\u3002\u8003\u79d8\u5b97\u827a\u5728\u5927\u6c5f\u5357\u5317\u4e4b\u52bf\u529b\uff0c\u81f3\u5927\u4e14\u5e7f\uff0c\u5404\u7701\u5404\u53bf\u968f\u5904\u7686\u662f\u3002\u5373\u4eca\u4e4b\u56fd\u672f\u540d\u5bb6\uff0c\u591a\u6709\u66fe\u4e60\u65af\u672f\u8005\uff0c\u6545\u79d8\u5b97\u4e4b\u6e90\u6d41\uff0c\u7531\u6765\u4e45\u77e3\uff0c\u7279\u8ff0\u4e4b\u5982\u4e0a\u3002<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u79d8\u5b97\u827a\u4e4b\u540d\u79f0\u8003\">\u79d8\u5b97\u827a\u4e4b\u540d\u79f0\u8003<\/h1>\n\n\n\n<p>\u79d8\u5b97\u827a\u5176\u540d\u4e0d\u4e00\uff0c\u4ee5\u4f59\u6240\u77e5\u7ea6\u6709\u6570\u79cd\uff0c\u800c\u6570\u79cd\u540d\u79f0\uff0c\u53c8\u7686\u5404\u6709\u7531\u6765\u3002\u65af\u672f\u5728\u5317\u65b9\u6781\u76db\u884c\uff0c\u65e0\u8bba\u4f55\u7701\u4f55\u53bf\uff0c\u51e1\u6cbb\u6280\u8005\uff0c\u5c20\u6709\u4e0d\u77e5\u79d8\u5b97\u827a\u8005\u3002\u79d8\u5b97\u827a\u53c8\u540d\u8ff7\u8e2a\u827a\uff0c\u4ea6\u66f0\u730a\u7314\u827a\u7686\u4e3a\u4e00\u97f3\u4e4b\u8f6c\u3002\u5176\u5f97\u540d\u4e4b\u7531\u53ef\u4ee5\u8003\u89c1\uff0c\u636e\u5b59\u901a\u5927\u5e08\u4f20\u7559\u6ca7\u5dde\u5168\u5883\u8005\uff0c\u7edf\u66f0\u79d8\u5b97\uff0c\u5206\u4e24\u652f\uff0c\u4e0b\u6d3c\u4e00\u5e26\u7686\u66f0\u79d8\u5b97\u67b6\uff0c\u71d5\u9752\u62f3\u3002\u57ce\u53a2\u9644\u8fd1\uff0c\u5219\u4e3a\u71d5\u9752\u67b6\uff0c\u79d8\u5b97\u62f3\u3002\u5176\u6240\u4ee5\u540d\u79d8\u5b97\u8005\uff0c\u636e\u4f20\u8005\u8c13\uff0c\u5b8b\u4e4b\u5362\u4fca\u4e49\uff0c\u5b66\u4e8e\u5c11\u6797\uff0c\u5f97\u65af\u672f\u4e4b\u5927\u6210\u3002\u800c\u5bb6\u5bcc\u6709\uff0c\u4e0d\u4ee5\u6280\u4f20\u3002\u6709\u540d\u71d5\u9752\u8005\uff0c\u55dc\u62f3\u6280\uff0c\u95fb\u5362\u540d\uff0c\u82e6\u4e0d\u5f97\u5176\u4f20\u3002\u4f63\u4e8e\u5362\u5bb6\u82e5\u5e72\u5e74\uff0c\u827a\u6210\u540c\u5165\u6881\u5c71\u6cca\u3002\u6545\u4eca\u4e4b\u5156\u5dde\uff0c\u6d4e\u5b81\uff0c\u9752\u5dde\u5404\u5730\uff0c\u4ecd\u76f4\u547c\u4e3a\u71d5\u9752\u62f3\u3002\u81f3\u5317\u7701\u547c\u79d8\u5b97\u8005\uff0c\u56e0\u71d5\u9752\u4e3a\u6881\u5c71\u4e4b\u5bc7\uff0c\u6050\u65e0\u4ee5\u662d\u793a\u540e\u6765\uff0c\u6545\u66f0\u79d8\u5b97\uff0c\u5373\u79d8\u5176\u5b97\u6d3e\u4e4b\u610f\u4e5f\u3002\u82e5\u9759\u6d77\u970d\u6c0f\uff0c\u53ca\u5929\u6d25\u536b\u5357\u6d3c\u4e00\u5e26\uff0c\u5219\u7528\u8ff7\u8e2a\u4ee5\u4ee3\u4e4b\u3002\u8c13\u5e74\u6e6e\u4ee3\u8fdc\u5df2\u8ff7\u4f20\u8005\u4e4b\u8e2a\u8ff9\uff0c\u65e0\u4ece\u8003\u5bdf\u4e3a\u4f55\u4eba\u6240\u53d1\u660e\uff0c\u6545\u66f0\u8ff7\u8e2a\u3002\u53c8\u4e00\u8bf4\uff0c\u71d5\u9752\u4f63\u4e8e\u5362\u5bb6\uff0c\u827a\u6210\u800c\u53bb\u3002\u884c\u65f6\u9002\u96e8\u96ea\uff0c\u71d5\u9752\u60e7\u4e3a\u8ffd\u8005\u5bfb\u8e2a\u6240\u83b7\uff0c\u4ee5\u4e24\u8db3\u9000\u540e\u5012\u884c\uff0c\u4ee5\u4e24\u624b\u6478\u96ea\u4ee5\u8ff7\u8db3\u8ff9\uff0c\u662f\u4e3a\u8ff7\u8e2a\u3002\u4e8c\u8bf4\u672a\u77e5\u5b70\u662f\uff0c\u8981\u7686\u636e\u4e3a\u71d5\u9752\u6240\u4f20\u65e0\u7591\u77e3\u3002\u60df\u6700\u540e\u4e00\u8bf4\uff0c\u66f0\u730a\u7314\u4e3a\u6700\u6709\u6839\u636e\uff0c\u4ea6\u6700\u53ef\u4fe1\uff0c\u5f55\u4e4b\u4ee5\u544a\u6d77\u5185\u6cbb\u6280\u4e4b\u540c\u5fd7\uff0c\u5176\u80fd\u8868\u540c\u60c5\u4e4e\uff1f\u636e\u79f0\u730a\u7314\u4e4b\u8bf4\uff0c\u7cfb\u5510\u5b63\u5c11\u6797\u50e7\u67d0\uff0c\u4e3a\u8fbe\u6469\u7956\u5e08\u82e5\u5e72\u4e16\u5ae1\u7cfb\uff0c\u8bbf\u9053\u4e8e\u67d0\u5730\uff0c\u89c1\u6709\u7334\u7c7b\uff0c\u66f0\u730a\u7314\u8005\uff0c\u7fa4\u6597\u4e8e\u5c71\u9e93\u5f7c\u6765\u6b64\u5f80\uff0c\u7eaf\u4efb\u81ea\u7136\u3002\u53c8\u89c1\u4e00\u8001\u7334\u4f5c\u5a46\u6c99\u821e\u51dd\u6c14\u6b5b\u795e\uff0c\u521a\u67d4\u76f8\u6d4e\uff0c\u5f52\u6709\u6240\u609f\u3002\u9042\u53d1\u660e\u730a\u7314\u62f3\u67b6\uff08\u5373\u4eca\u4e4b\u79d8\u5b97\u67b6\uff09\u3002\u5bf9\u6218\u9760\u6253\uff08\u5373\u4eca\u4e4b\u79d8\u5b97\u5408\u6218\u9760\u6253\u662f\u4e5f\uff09\uff0c\u8fe8\u6709\u5362\u4fca\u4e49\u4f20\u4e0e\u71d5\u9752\uff0c\u4ee5\u81f3\u540e\u4e16\uff0c\u9042\u7ecf\u5386\u6b21\u5c55\u8f6c\uff0c\u6216\u547c\u4e4b\u4e3a\u79d8\u5b97\u6216\u547c\u4e4b\u4e3a\u79d8\u8e2a\uff0c\u5176\u5b9e\u7686\u975e\u71d5\u9752\u6240\u521b\u53c8\u4f55\u7528\u8bb3\u83ab\u5982\u6df1\u3002\u6e05\u5b63\u91cd\u6587\uff0c\u6cbb\u6280\u8005\u82df\u4e0d\u5bfb\u5176\u7531\u6765\uff0c\u53c8\u4f55\u80fd\u8fa9\u5176\u4e3a\u79d8\u5b97\uff0c\u8ff7\u8e2a\uff0c\u730a\u7314\u8036\uff1f<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u79d8\u5b97\u827a\u4e4b\u652f\u6d3e\u5f02\u540c\">\u79d8\u5b97\u827a\u4e4b\u652f\u6d3e\u5f02\u540c<\/h1>\n\n\n\n<p>\u79d8\u5b97\u827a\u4e4b\u6e90\u6d41\uff0c\u79d8\u5b97\u827a\u4e4b\u540d\u79f0\u8003\uff0c\u65e2\u5982\u4e0a\u8ff0\u77e3\uff0c\u60df\u543e\u56fd\u4e4b\u56fd\u672f\uff0c\u7701\u4e0e\u7701\u6b8a\uff0c\u53bf\u4e0e\u53bf\u522b\uff0c\u5e08\u751f\u5404\u5f02\uff0c\u95e8\u6237\u81ea\u5b88\u3002\u540c\u4e3a\u4e00\u5b97\uff0c\u800c\u62f3\u5251\u5404\u6709\u60ac\u6b8a\uff0c\u7686\u4e3a\u5e08\u4f20\uff0c\u800c\u529f\u7528\u4ea6\u5404\u81ea\u4e0d\u540c\uff0c\u6b64\u4ea6\u56fd\u672f\u6781\u5f85\u6574\u7406\u800c\u6539\u8fdb\u8005\u4e5f\u3002\u5728\u6614\u592a\u6781\u5f62\u610f\u516b\u5366\u5c1a\u672a\u53d1\u660e\u4e4b\u5148\uff0c\u79d8\u5b97\u62f3\u4e8e\u56fd\u672f\u4e2d\u5b9e\u5360\u6700\u91cd\u8981\u4e4b\u5730\u4f4d\u800c\u80fd\u4ee3\u8868\u592a\u6781\u8005\uff0c\u56e0\u65af\u672f\u5728\u5317\u6570\u7701\uff0c\u540d\u5bb6\u5de8\u5b50\uff0c\u968f\u5904\u53ef\u89c1\uff0c\u65e0\u8bba\u6cbb\u6280\u8005\u4e0e\u5426\uff0c\u4ea6\u5c20\u6709\u4e0d\u77e5\u79d8\u5b97\u62f3\uff0c\u71d5\u9752\u62f3\u8005\uff0c\u987e\u65af\u672f\u65e9\u5df2\u5931\u5374\u672c\u6765\u9762\u76ee\uff0c\u543e\u6562\u65ad\u8a00\u3002\u4f59\u56e0\u65af\u672f\uff0c\u9887\u8d1f\u7f8e\u8a89\uff0c\u77e5\u5176\u51b3\u975e\u4eca\u65e5\u6cbb\u6280\u8005\u6240\u6388\u4e4b\u79d8\u5b97\u53ef\u6bd4\uff0c\u9042\u4e0d\u60ee\u70e6\u96be\uff0c\u8bbf\u6c42\u5341\u4f59\u5e74\uff0c\u5386\u6570\u7701\uff0c\u7ecf\u4e8c\u5341\u4f59\u53bf\uff0c\u5e78\u5f97\u65af\u672f\u4e4b\u4e09\u6627\uff0c\u6df1\u89c9\u5176\u4e2d\u80fd\u6709\u4e09\u56db\u6210\u662f\u5904\u8005\u5219\u4ecd\u63a8\u6ca7\u5dde\u4e00\u6d3e\u3002\u82e5\u9759\u6d77\u970d\u6c0f\uff0c\u4ea6\u4ec5\u6b64\u4e00\u6210\u3002\u5176\u4f59\u5219\u7b49\u8bf8\u81ea\u90d0\u4ee5\u4e0b\u65e0\u8ba5\u8033\u3002\u6b64\u5c31\u6839\u672c\u4e4b\u79d8\u5b97\u67b6\u8a00\uff0c\u82e5\u5176\u4ed6\u5b97\u6d3e\u4e4b\u6742\u6280\uff0c\u4ea6\u786e\u6709\u80dc\u4e8e\u6614\u8005\u3002\u5179\u5c06\u65af\u672f\u652f\u6d3e\u4e4b\u4f18\u52a3\u5206\u758f\u5982\u4e0b\uff1a\u6ca7\u5dde\u5206\u4e24\u6d3e\uff0c\u79d8\u5b97\u67b6\u8f83\u5404\u7701\u540c\u95e8\u4e4b\u79d8\u5b97\u67b6\u4e3a\u4f18\uff0c\u80fd\u6709\u53e4\u6614\u56db\u6210\uff0c\u4e0d\u5931\u67d4\u672f\u4e0a\u4e58\u3002\u4f59\u5982\u5341\u516b\u52fe\uff0c\u5355\u5200\u62d0\uff0c\u7686\u4e0d\u5931\u771f\uff0c\u81f3\u7ec3\u624b\u62f3\uff0c\u7ef5\u638c\u62f3\uff0c\u79d8\u5b97\u9760\uff0c\u7686\u65e0\u4e00\u987e\u4e4b\u4ef7\u503c\u77e3\u3002\u9759\u6d77\u9752\u53bf\u4e4b\u4e24\u6d3e\uff0c\u7efc\u5176\u5404\u6280\uff0c\u4ec5\u6709\u79d8\u5b97\u4e00\u6210\u3002\u5929\u6d25\u536b\u5357\u6d3c\u4e0e\u5929\u6d25\u57ce\u4e4b\u4e24\u6d3e\uff0c\u8f83\u9759\u6d77\u9752\u53bf\u4e4b\u4e24\u6d3e\u7a0d\u4f18\uff0c\u7136\u4e0d\u8fc7\u5f97\u67d4\u672f\u4e8c\u6210\u3002\u6cb3\u95f4\uff0c\u732e\u53bf\uff0c\u4efb\u90b1\uff0c\u79d8\u5b97\u67b6\u5f31\u4e8e\u6ca7\u5dde\u3002\u5176\u4f59\u5747\u5728\u4f2f\u4ef2\u4e4b\u95f4\u3002\u9c81\u4e4b\u5fb7\u5dde\uff0c\u9752\u5dde\uff0c\u7eaf\u521a\u4e0d\u67d4\uff0c\u540d\u4e3a\u79d8\u5b97\uff0c\u800c\u5b9e\u65e0\u4e00\u6280\u3002\u9752\u5dde\u547c\u4e3a\u71d5\u9752\u795e\u6376\uff0c\u5176\u4fda\u4fd7\u5df2\u8fbe\u6781\u70b9\u3002\u5156\u5dde\uff0c\u6d4e\u5b81\uff0c\u6c76\u4e0a\uff0c\u7ea6\u6709\u6570\u6d3e\uff0c\u7686\u4e3a\u79d8\u5b97\uff0c\u5176\u62f3\u67b6\u4e0e\u6ca7\u5dde\u4e00\u6d3e\u5b8c\u5168\u4e0d\u540c\u3002\u867d\u591a\u7528\u9a6c\u6869\uff0c\u5b9e\u8f83\u5929\u6d25\uff0c\u9759\u6d77\u4e24\u6d3e\u4e3a\u4f18\u3002\u800c\u8be5\u4e09\u5904\uff0c\u72ec\u6709\u5f02\u4e8e\u4ed6\u5904\u8fd1\u4e8e\u53e4\u6614\u8005\uff0c\u53a5\u60df\u516b\u8d9f\u71d5\u9752\u9760\uff0c\u4e0d\u60df\u5404\u5730\u4e60\u79d8\u5b97\u8005\u671b\u5c18\u83ab\u53ca\uff0c\u5373\u5176\u4ed6\u5b97\u6d3e\u4e4b\u5408\u6218\uff0c\u4ea6\u4ece\u672a\u89c1\u82e5\u662f\u4e4b\u7cbe\u5999\u8005\u3002\u6c11\u4e5d\u9047\u4e00\u4eba\uff0c\u56e0\u8bbf\u6c42\u79d8\u5b97\u4e4b\u771f\u4f20\uff0c\u66fe\u8d74\u6ca7\u5dde\u4e3a\u4eba\u4f63\u5de5\u4e94\u5e74\u3002\u51e1\u79d8\u5b97\u6d3e\u5c71\u4e1c\u6240\u65e0\u8005\uff0c\u4f0a\u5747\u9971\u8f7d\u800c\u5f52\uff0c\u60df\u4f0a\u4e4b\u516b\u8d9f\u79d8\u5b97\u5408\u6218\uff0c\u66fe\u672a\u4ea4\u6362\u5176\u4e00\u3002\u76d6\u4f0a\u59cb\u7ec8\u4e0d\u80af\u4ee5\u6280\u81ea\u70ab\u8033\u3002\u60dc\u4f59\u5df2\u5fd8\u5176\u59d3\u5b57\u3002\u6c11\u4e03\u65b0\u7533\u62a5\u520a\u8f7d\u71d5\u9752\u62f3\uff0c\u7f16\u8005\u7cfb\u5510\u59d3\uff0c\u89c2\u5176\u6f14\u5f0f\uff0c\u5b9b\u4f3c\u5929\u6d25\u9759\u6d77\u4e4b\u4e00\u6d3e\u3002\u5176\u6869\u6cd5\u53c8\u4f3c\u5c71\u4e1c\u6d3e\u3002\u4eca\u6d77\u4e0a\u9887\u6709\u7cbe\u6b64\u8005\uff0c\u7136\u7686\u975e\u6b63\u5b97\uff0c\u60df\u7cbe\u6b66\u970d\u6c0f\u9057\u4f20\u4ecd\u5b58\u5c11\u8bb8\u4e4b\u53e4\u6d3e\u8033\u3002<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u8bba\u79d8\u5b97\u4e0e\u592a\u6781\u76f8\u540c\u4e4b\u70b9\">\u8bba\u79d8\u5b97\u4e0e\u592a\u6781\u76f8\u540c\u4e4b\u70b9<\/h1>\n\n\n\n<p>\u79d8\u5b97\u62f3\u5728\u6700\u521d\u53d1\u660e\u4e4b\u65f6\uff0c\u5176\u6280\u786e\u4e3a\u67d4\u672f\u4e0a\u4e58\uff0c\u5185\u5bb6\u6b63\u5b97\u3002\u5176\u59ff\u5f0f\u52a8\u4f5c\uff0c\u7406\u6cd5\u529f\u7528\uff0c\u65e0\u4e0d\u4e0e\u592a\u6781\u62f3\u606f\u606f\u76f8\u901a\u3002\u987e\u65af\u672f\u4f20\u8005\uff0c\u5076\u4e00\u4e0d\u614e\uff0c\u5dee\u6beb\u5398\u8c2c\u5fc5\u5343\u91cc\uff0c\u4e8e\u662f\u6108\u8d8b\u6108\u4e0b\uff0c\u8fe8\u81f3\u4eca\u65e5\uff0c\u4e0d\u60df\u5df2\u5165\u6b67\u9014\u4e14\u53d8\u4e3a\u5e02\u4e95\u4fda\u4fd7\u5916\u5bb6\u4e4b\u672b\u6280\uff0c\u826f\u53ef\u6168\u4e5f\u3002\u4f59\u8bbf\u6c42\u5341\u4f59\u5e74\uff0c\u5e78\u5f97\u65af\u672f\u4e4b\u98a0\u672b\uff0c\u51e1\u4f59\u6240\u5f97\uff0c\u77e5\u65e0\u4e0d\u8a00\uff0c\u5179\u5c06\u65af\u672f\u4e4b\u771f\u4f20\u4e0e\u592a\u6781\u76f8\u540c\u4e4b\u70b9\u548c\u76d8\u6258\u51fa\uff0c\u4ee5\u8bc1\u79d8\u5b97\u827a\u56fa\u975e\u5bfb\u5e38\u62f3\u6280\u6240\u53ef\u540c\u65e5\u8bed\u8005\u3002\u6b63\u5b97\u4e4b\u79d8\u5b97\u62f3\u67b6\uff0c\u6f14\u5f0f\u65f6\u5982\u56de\u7fd4\u4e4b\u9e1f\uff0c\u52a8\u4f5c\u4e0d\u505c\uff0c\u5076\u6216\u5de6\u624b\u505c\u53f3\u624b\u4e0d\u505c\uff0c\u5de6\u8db3\u867d\u6b62\u53f3\u8db3\u4ecd\u52a8\uff0c\u60df\u5b9a\u5f0f\u7a0d\u6709\u5206\u522b\u3002\u82e5\u592a\u6781\u65e0\u5b9a\u5f0f\uff0c\u6216\u6709\u6b64\u5f0f\u505c\u4f4f\u800c\u610f\u4ecd\u672a\u505c\u3002\u79d8\u5b97\u4e4b\u6613\u5165\u6b67\u9014\uff0c\u4ea6\u5373\u6b64\u4e00\u5239\u90a3\u4e4b\u65f6\u95f4\u8033\u3002\u79d8\u5b97\u62f3\u62f3\u67b6\u4e4b\u517b\u6c14\u8005\uff0c\u5168\u5728\u4e24\u79cd\u6b65\u6cd5\uff0c\u4e00\u4e3a\u63d0\u8e35\u5b50\u5348\u6b65\uff0c\u4e00\u4e3a\u91d1\u9e21\u72ec\u7acb\u6b65\uff0c\u6b64\u4e24\u79cd\u6b65\u6cd5\u80fd\u62ff\u4f4f\u4e39\u7530\u4e4b\u6c14\uff0c\u5982\u4e24\u624b\u643f\u7269\u7136\u7f13\u7f13\u800c\u4e0b\uff0c\u6c14\u4e0d\u5916\u6ea2\uff0c\u6b64\u4ea6\u79d8\u5b97\u72ec\u5f02\u4e8e\u666e\u901a\u62f3\u672f\u8005\u3002\u81f3\u82e5\u4e24\u817f\u4e24\u80f3\u818a\u4e4b\u9ad8\u77ee\u90e8\u4f4d\uff0c\u6c89\u80a9\u5760\u8098\uff0c\u5168\u4e0d\u7528\u529b\u800c\u5b9e\u6709\u5185\u52b2\u542b\u4e8e\u4e2d\uff0c\u4e00\u5947\u4e00\u6b63\uff0c\u5f2f\u66f2\u4e0d\u76f4\uff0c\u53c8\u80fd\u84c4\u795e\u987e\u4e8e\u5916\u3002\u592a\u6781\u6240\u8c13\u4e0d\u52a8\u5982\u5c71\uff0c\u52a8\u5982\u96f7\u9706\uff0c\u5347\u8fdb\u672a\u5b9a\uff0c\u6cbe\u7c98\u4e0d\u8131\uff0c\u65af\u672f\u517c\u800c\u6709\u4e4b\uff0c\u60df\u65af\u672f\u6613\u5b66\u4e0d\u6613\u7cbe\u3002\u56e0\u6f14\u5f0f\u65f6\u5185\u6709\u5403\u529b\u5904\uff0c\u5b66\u8005\u82df\u65e0\u6052\u5fc3\u5f80\u5f80\u534a\u9014\u800c\u5e9f\u3002\u4e00\u65e6\u529f\u6210\uff0c\u5176\u4e0d\u53ef\u601d\u8bae\u5904\uff0c\u8f83\u4e4b\u592a\u6781\u76f4\u6709\u8fc7\u4e4b\u65e0\u4e0d\u53ca\u8005\u3002\u76d6\u79d8\u5b97\u81f3\u6b64\u5316\u5883\uff0c\u5b9e\u975e\u6613\u4e8b\uff0c\u4ee5\u4f59\u6240\u77e5\uff0c\u4e0d\u8fc7\u4e8c\u4e09\u4eba\uff0c\u56e0\u65af\u672f\u4e0d\u82e5\u592a\u6781\u4e4b\u6108\u7ec3\u6108\u6709\u5174\u8da3\uff0c\u6b32\u7f62\u4e0d\u80fd\u8033\u3002<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u8bba\u79d8\u5b97\u5929\u7136\u4e4b\u5185\u529f\">\u8bba\u79d8\u5b97\u5929\u7136\u4e4b\u5185\u529f<\/h1>\n\n\n\n<p>\u62f3\u672f\u4e2d\u4e4b\u6709\u5185\u529f\uff0c\u4ee5\u4f59\u6240\u77e5\u8005\u4e3a\u592a\u6781\uff0c\u5f62\u610f\uff0c\u516b\u5366\u3002\u9664\u6b64\u4e09\u6d3e\u800c\u5916\uff0c\u5176\u4ed6\u62f3\u672f\u5b97\u6d3e\u6216\u4ea6\u6709\u5185\u529f\u8005\uff0c\u7136\u5747\u7cfb\u4e13\u4e60\uff0c\u4e0e\u62f3\u672f\u6beb\u65e0\u5173\u7cfb\uff0c\u6240\u8c13\u62f3\u672f\u81ea\u62f3\u672f\uff0c\u5185\u529f\u81ea\u5185\u529f\uff0c\u5404\u4e0d\u76f8\u5c5e\uff0c\u5206\u9053\u800c\u626c\u9573\u8005\u4e5f\u3002\u60df\u79d8\u5b97\u62f3\u67b6\u4e2d\uff0c\u5374\u6709\u5929\u7136\u4e4b\u5185\u529f\uff0c\u7136\u6b64\u4e3a\u6700\u521d\u4e4b\u6b63\u5b97\u3002\u82e5\u4eca\u65e5\u4e4b\u4e60\u79d8\u5b97\u8005\uff0c\u4e0d\u60df\u6beb\u65e0\u5185\u529f\u4e4b\u53ef\u8a00\uff0c\u4e14\u4e0d\u77e5\u79d8\u5b97\u62f3\u67b6\u4e4b\u5185\u529f\u5728\u4e8e\u4f55\u5904\uff0c\u4ee5\u81f4\u6bcf\u51b5\u6108\u4e0b\uff0c\u79d8\u5b97\u827a\u76f4\u65e0\u4e00\u987e\u4e4b\u4ef7\u503c\uff0c\u751a\u4e14\u6d41\u5165\u6c5f\u6e56\u672b\u6280\u3002\u6b64\u8fd1\u4ee3\u79d8\u5b97\u827a\u4e4b\u6d41\u5f0a\uff0c\u800c\u5931\u771f\u4f20\u4e4b\u660e\u8bc1\u4e5f\u3002\u4f59\u4eca\u5373\u4ee5\u79d8\u5b97\u67b6\u4e4b\u5f00\u95e8\u6570\u5f0f\u8bc1\u660e\u65af\u672f\u4e4b\u5185\u529f\uff0c\u5e76\u53ef\u77e5\u65af\u672f\u5bb9\u6613\u5165\u4e8e\u6b67\u9014\u4e4b\u7531\u6765\u77e3\u3002\u771f\u4f20\u4e4b\u79d8\u5b97\u67b6\uff0c\u5176\u7acb\u6b63\u59ff\u5f0f\u4e0e\u592a\u6781\u4e4b\u7acb\u6b63\u59ff\u5f0f\u65e0\u4e0d\u76f8\u540c\u3002\u7ad6\u9879\u9876\u52b2\uff0c\u5782\u80a9\u542b\u80f8\uff0c\u820c\u62b5\u4e0a\u816d\uff0c\u4e0b\u988c\u540e\u6536\uff0c\u4e39\u7530\u540e\u5438\uff0c\u63d0\u809b\u5982\u5fcd\u7caa\u72b6\uff0c\u6df7\u6df7\u6c8c\u6c8c\u7a7a\u7a7a\u6d1e\u6d1e\u3002\u6b64\u975e\u9759\u4e4b\u5219\u5408\u4e4b\u65e0\u6781\u5f0f\u8036\uff1f\u4ee5\u4e0b\u52a8\u4e4b\u5219\u5206\uff0c\u5c82\u975e\u65e0\u6781\u800c\u751f\u4e4b\u592a\u6781\u5f0f\u8036\uff1f\u7b2c\u4e8c\u5f0f\uff0c\u4e24\u624b\u7f13\u7f13\u5e73\u8d77\uff0c\u6c89\u80a9\u5760\u8098\uff0c\u63a5\u7b2c\u4e09\u5f0f\uff0c\u4e24\u624b\u7ffb\u800c\u671d\u4e0a\uff0c\u7f13\u7f13\u843d\u4e0b\uff0c\u518d\u8d77\u81f3\u80a9\u5e73\u3002\u63a5\u7b2c\u56db\u5f0f\uff0c\u4e24\u624b\u843d\u81f3\u8179\u90e8\uff0c\u518d\u5f80\u524d\u63a8\u3002\u63e1\u62f3\u540e\uff0c\u843d\u81f3\u4e24\u80ef\uff0c\u518d\u5f80\u4e0a\u63d0\u3002\u6b64\u6570\u5f0f\u8fde\u8d2f\u4e00\u6c14\uff0c\u867d\u4ec5\u4e24\u81c2\u6d3b\u52a8\uff0c\u800c\u5168\u8eab\u610f\u601d\u4ea6\u83ab\u4e0d\u968f\u4e4b\u800c\u52a8\u3002\u867d\u4e0d\u7528\u529b\uff0c\u800c\u5b9e\u5904\u5904\u6709\u529b\u3002\u867d\u4e0d\u84c4\u6c14\uff0c\u800c\u5b9e\u5168\u8eab\u8fd0\u6c14\uff0c\u4e14\u6613\u751f\u957f\u5185\u52b2\uff0c\u6b64\u5373\u65af\u672f\u5929\u7136\u4e4b\u5185\u529f\uff0c\u4e5f\u5373\u5168\u90e8\u4e4b\u7cbe\u91c7\uff0c\u5b66\u8005\u6240\u4e9f\u5b9c\u9075\u5b88\u8005\u4e5f\u3002\u82e5\u8fd1\u4e16\u4e4b\u4e60\u65af\u672f\u8005\uff0c\u4e00\u5473\u84c4\u6c14\u52aa\u529b\uff0c\u5165\u4e8e\u6b67\u9014\u4e0b\u4e58\u3002\u7686\u57fa\u4e8e\u6b64\uff0c\u4e0d\u60df\u6beb\u65e0\u5185\u529f\u4e4b\u53ef\u8a00\uff0c\u4e14\u6709\u767e\u5bb3\u800c\u65e0\u4e00\u5229\u3002\u5176\u5f0a\u5f53\u4e8e\u8bba\u4eca\u6614\u4e4b\u79d8\u5b97\u827a\u4e2d\u8be6\u8ff0\u4e4b\uff0c\u6df1\u613f\u5bf9\u6b64\u6781\u5e94\u6ce8\u610f\u4e4b\u79d8\u5b97\u5929\u7136\u4e4b\u5185\u529f\uff0c\u5e78\u52ff\u6ed1\u53e3\u8bfb\u8fc7\u3002<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u8bba\u4eca\u6614\u4e4b\u79d8\u5b97\u827a\">\u8bba\u4eca\u6614\u4e4b\u79d8\u5b97\u827a<\/h1>\n\n\n\n<p>\u79d8\u5b97\u62f3\u81f3\u4e8e\u4eca\u65e5\uff0c\u867d\u4ecd\u76db\u884c\u4e8e\u5317\u6570\u7701\uff0c\u7136\u56e0\u5f62\u610f\uff0c\u516b\u5366\uff0c\u592a\u6781\u4e4b\u7ade\u4e89\uff0c\u65af\u672f\u5df2\u65e0\u76f8\u5f53\u4e4b\u58f0\u8a89\uff0c\u4e14\u5df2\u6ca6\u843d\u5916\u5bb6\u4e4b\u4e00\u6d3e\u3002\u4f59\u4e3a\u65af\u672f\u60dc\uff0c\u60dc\u5176\u4eca\u4e0d\u5982\u6614\u4e5f\u3002\u590d\u4e3a\u65af\u672f\u60e7\uff0c\u60e7\u5176\u65e5\u4e45\u6df7\u6dc6\u4e5f\u3002\u4e43\u5e7f\u641c\u535a\u6c42\uff0c\u4ee5\u8bc1\u4eca\u6614\uff0c\u8003\u79d8\u5b97\u5728\u521d\u53d1\u660e\u65f6\u540d\u730a\u7314\uff08\u5df2\u8be6\u89c1\u4e0a\uff09\u4e43\u53d6\u7269\u8c61\u5f62\u4e4b\u610f\u3002\u5728\u6b64\u65f6\u4ee3\uff0c\u65af\u672f\u4e3a\u67d4\u672f\u4e0a\u4e58\uff0c\u5185\u5bb6\u6b63\u5b97\uff0c\u53ef\u65e0\u7591\u77e3\u3002\u56e0\u6700\u5148\u4e4b\u4e60\u79d8\u5b97\u8005\u5168\u90e8\u62f3\u67b6\u7531\u9996\u81f3\u5c3e\u5171\u767e\u4f59\u624b\uff0c\u7eaf\u4efb\u81ea\u7136\uff0c\u6beb\u4e0d\u7528\u529b\uff0c\u5347\u8fdb\u672a\u5b9a\uff0c\u5f80\u6765\u4e0d\u505c\uff0c\u867d\u659c\u800c\u6b63\uff0c\u4f3c\u629d\u800c\u5408\u3002\u4e0d\u7528\u771f\u529b\uff0c\u800c\u6709\u5185\u52b2\u3002\u4e0d\u84c4\u6c14\u805a\u6c14\uff0c\u800c\u6c14\u8d2f\u4e39\u7530\u3002\u4f3c\u76f4\u800c\u66f2\uff0c\u867d\u4f38\u800c\u7f29\u3002\u4e0a\u4e0b\u7eb5\u6a2a\uff0c\u8054\u7edc\u4e00\u6c14\u3002\u6f14\u5f0f\u65f6\u6c57\u6d41\u6d43\u80cc\u800c\u547c\u5438\u81ea\u7136\uff0c\u7edd\u65e0\u5927\u6c14\u51fa\u53e3\u3002\u6b64\u4f59\u7531\u5b9e\u9a8c\u5f97\u6765\uff0c\u6545\u6562\u4e3a\u6709\u529b\u4e4b\u8bc1\u660e\u3002\u65af\u672f\u4e0e\u592a\u6781\u7a0d\u5f02\u8005\uff0c\u5373\u4e3a\u6b65\u6cd5\u4e0e\u63a5\u7b0b\u5904\u4e4b\u5b9a\u5f0f\u8033\u3002\u60df\u65af\u672f\u8f83\u592a\u6781\u6613\u5165\u6b67\u9014\uff0c\u662f\u7686\u65e0\u4e13\u4e66\u53c2\u8003\u4e4b\u5f0a\u3002\u79d8\u5b97\u4e4b\u771f\u50cf\u65e2\u5982\u6b64\uff0c\u79d8\u5b97\u4e4b\u6613\u5165\u6b67\u9014\u53c8\u5982\u5f7c\uff0c\u662f\u5e94\u65a9\u9489\u622a\u94c1\u63ed\u53d1\u5176\u5f0a\u800c\u5220\u53bb\u4e4b\uff0c\u9610\u626c\u5176\u957f\u800c\u6269\u5145\u4e4b\u3002\u5179\u5c06\u8fd1\u4ee3\u8d8b\u4e8e\u4e0b\u4e58\u4e4b\u7531\u6765\uff0c\u5f55\u4e4b\u4ee5\u544a\u6d77\u5185\u540c\u5fd7\u3002\u6309\u543e\u56fd\u5728\u91cd\u6587\u8f7b\u6b66\u65f6\u4ee3\uff0c\u6587\u4eba\u58a8\u5ba2\u4e0d\u5c51\u8c08\u6b66\uff0c\u800c\u597d\u6b66\u4e4b\u4eba\u5927\u90fd\u6751\u91ce\u83bd\u592b\uff0c\u76ee\u4e0d\u8bc6\u4e01\uff0c\u65e0\u4ece\u7814\u7a76\u7406\u6cd5\u529f\u7528\uff0c\u52a8\u8f84\u4ee5\u529b\u81ea\u70ab\uff0c\u6b8a\u4e0d\u77e5\u62f3\u4e0d\u7528\u529b\uff0c\u4f0a\u5fc5\u52aa\u529b\u77dc\u5947\u5938\u8000\u4e8e\u4f17\u3002\u5373\u4ee5\u4e0a\u5f00\u95e8\u6570\u5f0f\uff0c\u8db3\u4ee5\u5fd8\u65af\u672f\u4e8e\u65e0\u5f62\u3002\u7acb\u6b63\u5168\u8eab\u7528\u529b\uff0c\u5377\u8d77\u81c0\u90e8\u8e22\u8170\u9f13\u80f8\uff0c\u7f29\u9888\u8038\u80a9\u3002\u63a5\u7b2c\u4e8c\u5f0f\uff0c\u4e24\u81c2\u633a\u76f4\uff0c\u805a\u6c14\u52aa\u529b\uff0c\u63a2\u8eab\u77aa\u773c\u3002\u63a5\u7b2c\u4e09\u5f0f\uff0c\u56db\u5f0f\uff0c\u4e24\u80a9\u65e2\u5df2\u9ad8\u8038\uff0c\u4e24\u8098\u590d\u9ad8\u4e8e\u4e24\u80a9\uff0c\u5c3d\u529b\u9f13\u6c14\uff0c\u8e22\u8170\u63a2\u8eab\u3002\u4e24\u817f\u4e24\u8db3\uff0c\u4ee5\u53ca\u5168\u8eab\uff0c\u5747\u7528\u529b\u81f3\u5341\u4e8c\u5206\uff0c\u4ee5\u805a\u6c14\u4e3a\u5999\u7528\uff0c\u800c\u6c14\u6ede\u4e3a\u5bb3\uff0c\u5168\u4e0d\u987e\u53ca\u3002\u6b64\u7b49\u59ff\u5f0f\uff0c\u5728\u4e0d\u77e5\u8005\u89c2\u4e4b\uff0c\u4e14\u7591\u4e3a\u5927\u529b\u58eb\u3002\u5b9e\u4e43\u5439\u6c14\u4e4b\u76ae\u7403\uff0c\u6c14\u6d6e\u4e2d\u5362\uff0c\u7740\u624b\u817e\u7a7a\u800c\u8d77\uff0c\u5c1a\u4f55\u5185\u529f\u4e4b\u53ef\u8a00\u3002\u6240\u8c13\u5760\u5165\u65c1\u95e8\uff0c\u4fbf\u662f\u5916\u5bb6\uff0c\u4ee5\u4e00\u4f8b\u5341\uff0c\u6b64\u543e\u9053\u4e4b\u6240\u4ee5\u65e5\u5b64\u4e5f\u3002<\/p>\n\n\n\n<h1 class=\"wp-block-heading\" id=\"\u8bba\u9759\u6d77\u970d\u6c0f\u4e4b\u79d8\u5b97\u827a\">\u8bba\u9759\u6d77\u970d\u6c0f\u4e4b\u79d8\u5b97\u827a<\/h1>\n\n\n\n<p>\u9759\u6d77\u5c0f\u5357\u6751\uff0c\u4e3a\u56fd\u672f\u540d\u5bb6\u970d\u5143\u7532\u541b\u6545\u5c45\u3002\u970d\u6c0f\u4ee5\u79d8\u5b97\u827a\u540d\u5929\u4e0b\u3002\u6e05\u5149\u7eea\u672b\u5e74\uff0c\u4f59\u5ba2\u6d25\u6cbd\uff0c\u5373\u8033\u5176\u540d\uff0c\u60df\u672a\u8bc6\u5176\u4eba\u53ca\u5176\u6280\u4e4b\u9020\u8be3\u82e5\u4f55\u3002\u8fe8\u95fb\u5176\u4e3a\u4eba\u6177\u6168\u597d\u4e49\uff0c\u5fc3\u5c24\u5411\u5f80\u3002\u540e\u591a\u65b9\u63a2\u5bfb\uff0c\u6089\u5176\u4e3a\u5bb6\u4f20\u79d8\u5b97\u827a\uff0c\u6216\u6709\u8c13\u5176\u66fe\u7956\u67d0\uff0c\u7cfb\u5b59\u901a\u5927\u5e08\u4e4b\u5f1f\u5b50\u3002\u662f\u5426\u5b59\u4f20\u5219\u65e0\u4ece\u8003\u3002\u60df\u6709\u53ef\u8bc1\u8005\uff0c\u5373\u970d\u6c0f\u4e4b\u62f3\u5200\u68cd\u68d2\u540d\u79f0\u52a8\u4f5c\uff0c\u7686\u4e0e\u5b59\u6c0f\u6240\u4f20\u5b8c\u5168\u76f8\u540c\u3002\u4e14\u636e\u4f59\u53d4\u8a00\uff0c\u5b59\u6c0f\u665a\u5e74\u6388\u5f92\u4e8e\u5929\u6d25\u536b\u5357\u6d3c\u66a8\u9759\u6d77\u4e24\u5904\u5341\u4f59\u5e74\u3002\u82e5\u7136\u8005\uff0c\u970d\u6c0f\u4e4b\u79d8\u5b97\u827a\u8fe8\u4e3a\u5b59\u6c0f\u5ae1\u7cfb\u65e0\u7591\u77e3\u3002\u6216\u6709\u95ee\u4f59\u66f0\uff0c\u970d\u6c0f\u4ee5\u79d8\u5b97\u827a\u540d\u4e8e\u5929\u4e0b\u5176\u827a\u8f83\u4e4b\u53e4\u4ee3\u4e4b\u730a\u7314\u7a76\u4f55\u82e5\uff0c\u4f59\u66f0\uff0c\u970d\u6c0f\u4e4b\u4e3a\u4eba\uff0c\u6177\u6168\u6fc0\u6602\uff0c\u6240\u4ea4\u7686\u6d77\u5185\u77e5\u540d\uff0c\u5176\u54c1\u683c\u5176\u62b1\u8d1f\u5b9e\u8db3\u538b\u5012\u4e00\u5207\uff0c\u5176\u56fd\u672f\u77e5\u8bc6\u4ea6\u5728\u5728\u9ad8\u4eba\u4e00\u7b49\u3002\u5176\u827a\u4e4b\u7cbe\u5230\u4ea6\u4e3a\u5e38\u4eba\u6240\u96be\u80fd\u3002\u81ea\u4e24\u6b21\u6218\u8d25\u5916\u4eba\u540e\uff0c\u76ca\u597d\u5b66\u4e0d\u5026\uff0c\u6d35\u4e3a\u56fd\u672f\u754c\u4e4b\u4eba\u624d\uff0c\u4e3a\u63d0\u5021\u56fd\u672f\u4e4b\u6709\u5fc3\u8005\uff0c\u60df\u95fb\u8bf8\u56fd\u672f\u754c\u4e4b\u5148\u89c9\u4e91\u3002\u970d\u6c0f\u6240\u5b66\uff0c\u7686\u8fd1\u4ee3\u4e4b\u79d8\u5b97\u827a\uff0c\u800c\u975e\u6700\u53e4\u8001\u4e4b\u730a\u7314\u827a\u3002\u4f3c\u4e4e\u504f\u4e8e\u4e00\u65b9\uff0c\u970d\u6c0f\u5bf9\u6b64\u4ea6\u9887\u81ea\u8ba4\uff0c\u4e14\u4e0d\u803b\u4e0b\u95ee\uff0c\u53ef\u89c1\u970d\u6c0f\u4e4b\u80af\u865a\u5fc3\uff0c\u80fd\u5bb9\u7eb3\u3002\u6545\u975e\u4e16\u4e4b\u4ee5\u4e00\u5f97\u81ea\u77dc\u8005\u6240\u80fd\u53ca\u5176\u9879\u80cc\uff0c\u751a\u613f\u543e\u56fd\u56fd\u672f\u540c\u5fd7\u6025\u8d77\u76f4\u8ffd\uff0c\u6b65\u970d\u6c0f\u4e4b\u540e\u5c18\uff0c\u4f7f\u56fd\u672f\u5927\u653e\u5149\u660e\u4e5f\u53ef\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u71d5\u9752\u62f3\u548c\u79d8\u5b97\u62f3\u5176\u5b9e\u662f\u4e00\u5bb6. \u00a0\u8bf4\u8d77\u71d5\u9752\u62f3,\u5f88\u591a\u4eba\u4f1a\u89c9\u5f97\u964c\u751f,\u4f46\u63d0\u53ca\u79d8\u5b97\u62f3,\u5927\u5bb6\u8033\u719f\u80fd\u8be6,\u4f46\u5b9e\u9645\u4e0a\u71d5\u9752\u62f3\u79d8\u5b97\u62f3\u4e0d\u5206\u5bb6\u3002\u201d\u5f20\u798f\u796f\u8bf4,\u71d5\u9752\u62f3\u76f8\u4f20\u7531\u5cb3\u98de\u7684\u5e08\u7236\u5468\u4f97\u6240\u521b,\u5468\u4f97\u7684\u53e6\u4e00\u540d\u5f1f\u5b50\u5362\u4fca\u4e49\u5c06\u6b64\u62f3\u4f20\u7ed9\u4e86\u6881\u5c71\u597d\u6c49\u71d5\u9752,\u540e\u4eba\u4ee5\u5176\u540d\u79f0\u4e3a\u201c\u71d5\u9752\u62f3\u201d\u3002\u00a0\u201c\u6709\u53f2\u6599\u8bb0\u8f7d\u7684\u71d5\u9752\u62f3\u6700\u65e9\u53ef\u8ffd\u6eaf\u5230\u4e7e\u9686\u5e74\u95f4\u7684\u6b66\u672f\u5927\u5e08\u5b59\u901a,\u4eba\u79f0\u2018\u4e07\u80fd\u624b\u2019,\u5584\u4e8e\u6b64\u62f3\u3002\u4ed6\u5c06\u6b64\u62f3\u4f20\u7ed9\u5929\u6d25\u9759\u6d77\u5c0f\u6cb3\u5357\u6751\u970d\u5143\u7532\u7684\u66fe\u7956\u4ee5\u53ca\u5c71\u4e1c\u3001\u6ca7\u5dde\u7b49\u5730\u3002\u201d\u5f20\u798f\u796f\u7684\u5f92\u5f1f\u674e\u658c\u8bf4,\u73b0\u5728\u5f88\u5c11\u6709\u4eba\u628a\u71d5\u9752\u62f3\u548c\u970d\u5143\u7532\u8054\u7cfb\u5728\u4e00\u8d77,\u970d\u5143\u7532\u66fe\u7528\u6b64\u62f3\u6253\u8d25\u4e86\u4fc4\u56fd\u5927\u529b\u58eb,\u4e3a\u56fd\u4e89\u5149,\u970d\u5143\u7532\u7684\u79d8\u5b97\u62f3\u548c\u71d5\u9752\u62f3\u662f\u540c\u4e00\u4e2a\u62f3\u79cd,\u53ea\u662f\u540d\u5b57\u4e0d\u4e00\u6837\u800c\u5df2\u3002\u3000<\/p>\n","protected":false},"author":1,"featured_media":1553,"comment_status":"closed","ping_status":"closed","sticky":false,"template":"","format":"standard","meta":{"pgc_sgb_lightbox_settings":"","footnotes":""},"categories":[5],"tags":[],"_links":{"self":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/249"}],"collection":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/comments?post=249"}],"version-history":[{"count":3,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/249\/revisions"}],"predecessor-version":[{"id":1544,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/posts\/249\/revisions\/1544"}],"wp:featuredmedia":[{"embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/media\/1553"}],"wp:attachment":[{"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/media?parent=249"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/categories?post=249"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/taipinginstitute.com\/wp-json\/wp\/v2\/tags?post=249"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}
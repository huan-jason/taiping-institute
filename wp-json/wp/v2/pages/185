:\"image\",\"width\":1134,\"height\":638,\"sizes\":{\"thumbnail\":{\"height\":150,\"width\":150,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014418-150x150.jpg\",\"orientation\":\"landscape\"},\"medium\":{\"height\":169,\"width\":300,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014418-300x169.jpg\",\"orientation\":\"landscape\"},\"large\":{\"height\":576,\"width\":1024,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014418-1024x576.jpg\",\"orientation\":\"landscape\"},\"full\":{\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014418.jpg\",\"height\":638,\"width\":1134,\"orientation\":\"landscape\"}},\"meta\":false,\"postlink\":\"http:\/\/taipinginstitute.com\/hung-kuen-%e6%b4%aa%e6%8b%b3\/cof\/\"},{\"id\":1403,\"title\":\"dig\",\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014145.jpg\",\"link\":\"http:\/\/taipinginstitute.com\/hung-kuen-%e6%b4%aa%e6%8b%b3\/dig\/\",\"alt\":\"\",\"description\":\"\",\"caption\":\"dig\",\"mime\":\"image\/jpeg\",\"type\":\"image\",\"width\":1600,\"height\":900,\"sizes\":{\"thumbnail\":{\"height\":150,\"width\":150,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014145-150x150.jpg\",\"orientation\":\"landscape\"},\"medium\":{\"height\":169,\"width\":300,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014145-300x169.jpg\",\"orientation\":\"landscape\"},\"large\":{\"height\":576,\"width\":1024,\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014145-1024x576.jpg\",\"orientation\":\"landscape\"},\"full\":{\"url\":\"http:\/\/taipinginstitute.com\/wp-content\/uploads\/2022\/02\/PSX_20220210_014145.jpg\",\"height\":900,\"width\":1600,\"orientation\":\"landscape\"}},\"meta\":false,\"postlink\":\"http:\/\/taipinginstitute.com\/hung-kuen-%e6%b4%aa%e6%